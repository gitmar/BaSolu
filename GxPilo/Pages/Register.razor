@page "/register"
@using System.ComponentModel.DataAnnotations
@using GxShared.ShdServices
@using GxShared.Sess

@inject IHttpClientFactory _httpClientFactory
@inject NavigationManager Nav

<h2>ENREGISTREMENT SUR GX-SOLUTIONS</h2> 

@if (!string.IsNullOrEmpty(Imessage))
{
    <div class="alert @(isSuccess ? "alert-success" : "alert-danger")">
        @Imessage
    </div>
}

@if (!isLoaded)
{
    <p>Loading...</p>
}
else
{
    @* class= " @(isRegistered ? "readonly -form" : "" )" *@
    <EditForm Model="@MyRegisDto" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="d-flex flex-row align-items-center g-2"> 
        <!-- Organisation info -->
            <label class="fw-bold">@OgSigle</label>
            <label>-</label>
            <label class="fw-bold">@OgRaison</label>
        </div>
        <div class="d-flex flex-row align-items-center  g-2">
            <!-- Organisation info -->
            <label class="fw-bold">@ResNom</label>
            <label>..</label>
            <label class="fw-bold">@ResPnom</label>
        </div>

        <div class="row g-3">
            <!-- Email (readonly) -->
            <label>Email</label>
            <div class="col-md-4">
                <InputText class="form-control" @bind-Value="MyRegisDto.Email" disabled />
            </div>
        </div>
        @* <div class="row g-3">
            <!-- Email (readonly) -->
            <label>Email or Username</label>
            <div class="col-md-4">
                <InputText class="form-control" @bind-Value="MyRegisDto.EmailOrUsername" />
                @if (!MyRegisDto.IsValidEmailOrUsername())
                {
                    <div class="text-danger">
                        Must be a valid email OR a username (7–15 letters/digits, no spaces or accents).
                    </div>
                }
            </div>
        </div> *@
        @if (!isSuccess)
        {
            <div class="row g-3">
                <!-- Nom -->
                <label>Nom</label>
                <div class="col-md-4">
                    <InputText class="form-control" @bind-Value="MyRegisDto.Nom" />
                </div>
            </div>
            <div class="row g-3">
                <!-- Pnom -->
                <label>Pnom</label>
                <div class="col-md-4">
                    <InputText class="form-control" @bind-Value="MyRegisDto.Pnom" />
                </div>
            </div>
            <!-- Username -->
            <div class="row g-3">
                <label>Pseudo<span class="fw-bold text-danger">(7-15 chars, no space/accent)</span></label>
                <div class="col-md-4">
                    <InputText class="form-control" @bind-Value="MyRegisDto.Username" />
                    <ValidationMessage For="@(() => MyRegisDto.Username)" />
                </div>
            </div>
            <!-- Password -->
            <div class="row g-3">
                <label>Password</label>
                <div class="col-md-4">
                    <InputText type="password" class="form-control" @bind-Value="MyRegisDto.Password" />
                </div>
            </div>
            <!-- Confirm -->
            <div class="row g-3 mb-3">
                <label>Confirm Password</label>
                <div class="col-md-4">
                    <InputText type="password" class="form-control" @bind-Value="MyRegisDto.ConfirmPassword" />
                </div>
            </div>
            @if(!string.IsNullOrEmpty(MyRegisDto.Username))
            {
                if(MyRegisDto.Username.Length >= 7)
                {
                    <button class="btn btn-primary" disabled="@isSubmitting">
                        @(isSubmitting ? "Registering..." : "Register")
                    </button>
                }
                else
                {
                    <div>La longueur doit etre au moins egal a 7</div>
                }
            }
        }
    </EditForm>
}
<style>
    .readonly-form {
        pointer-events: none;
        opacity: 0.7;
    }
</style>
@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "cdlink")]

    public string? CdLink { get; set; }
    private HttpClient _apiClient;
    private RegisterDto MyRegisDto = new();
    private InviteLinkData? InviteData;

    private bool isLoaded = false, isSuccess = false;
    private bool isSubmitting = false;
    //private bool isRegistered = false;

    private string? Imessage = "";

    // UI fields
    private string OgRaison = "";
    private string OgSigle = "";
    private string OgWeb = "";
    private string OgDom = "";
    private string OgSDom = "";
    private string OgNatio = "";
    private string ResNom = "";
    private string ResPnom = "";

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("A BIEN ATTERRI");
        _apiClient = _httpClientFactory.CreateClient("AuthClient");

        if (string.IsNullOrEmpty(CdLink))
        {
            isLoaded = true;
            return;
        }

        // Use CdLink directly
        var cdlink = CdLink;

        Console.WriteLine($"cdlink  : {cdlink}");
        if (string.IsNullOrEmpty(cdlink))
        {
            isLoaded = true;
            return;
        }

        try
        {
            // 🔥 IMPORTANT: move decoding to API (recommended)
            var response = await _apiClient.GetFromJsonAsync<InviteLinkData>(
                $"regis/decode?cdlink={cdlink}");

            if (response == null)
                return;

            InviteData = response;
            //user Idorg data
            var usrorg = await _apiClient.GetFromJsonAsync<Gporga>($"lgauth/tetorga/{InviteData.Idorg}");
            if (usrorg == null)
                return;
            // Prefill DTO (same as you if (response == null)
            MyRegisDto.Email = InviteData.Email;
            MyRegisDto.Username = "";
            MyRegisDto.Nom = InviteData.Nom;
            MyRegisDto.Pnom = InviteData.Pnom;
            MyRegisDto.PhoneNumber = InviteData.PhoneNumber;
            MyRegisDto.Idorg = InviteData.Idorg;
            OgRaison = usrorg.Raison;
            OgSigle = usrorg.Sigle;
            OgWeb = usrorg.Weburl;
            OgDom = usrorg.Sidom;
            OgSDom = usrorg.Sjdom;
            OgNatio = usrorg.Natio;
            ResNom = usrorg.Rnom;
            ResPnom = usrorg.Rpnom;

            // org info (you may also fetch via API)
            //Raison = InviteData.Raison;
            //Sigle = InviteData.Sigle;

            //isValid = true;
        }
        catch
        {
            //isValid = false;
        }

        isLoaded = true;
    }

    private async Task HandleRegister()
    {
        isSubmitting = true;
        Imessage = "Enregistrement en cours...";
        await InvokeAsync(StateHasChanged);
        await Task.Yield(); // allow render
        try
        {
            // merge invite data (like your OnPost)
            MyRegisDto.Idorg = InviteData.Idorg;
            MyRegisDto.Ivrole = InviteData.Ivrole;
            MyRegisDto.Itoken = InviteData.Itoken;
            MyRegisDto.SendEmail = InviteData.SendEmail;

            var response = await _apiClient.PostAsJsonAsync(
                "regis/register",
                MyRegisDto);
            if (!response.IsSuccessStatusCode)
            {
                //Imessage = await response.Content.ReadAsStringAsync();
                Imessage = "Echec, deja enregistre ou lien expire";
                isSuccess = false;
            }
            else
            {
                Imessage = "Registration successful! Please check your email for confirmation.";
                isSuccess = true;
            }
        }
        catch
        {
            Imessage = "Registration failed.";
        }
        finally
        {
            isSubmitting = false;
            //isRegistered = true;
            await InvokeAsync(StateHasChanged);
        }
        //StateHasChanged();
    }
}