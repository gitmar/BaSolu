    private List<TieatrDto> LsAtrs = new();
    private Guid? editRowguid;
    private bool isAdding = false;
    private TieatrDto draftAtr = new();

    private void CancelAdd() => isAdding = false;


    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            // if (toChild == null || curOrga == null)
            // {
            //     Console.WriteLine("Missing parent data");
            //     return;
            // }
            // isAuthenticated = toChild.isAuthenticated;
            // authUser = toChild.authUser;
            // if (!isAuthenticated)
            // {
            //     Imessage = "CONNEXION, Utilisateur non authentifie";
            //     return;
            // }
            // //LsVars = toChild.LsVars;
            // LsFixes = toChild.LsFixes;
            //LsDoms = toChild.LsFixes.Where(ut => ut.Gvars == 36 && ut.Itb == 4 && ut.Gp1 == 3 && ut.Elea != 0).ToList();
            //LsDoms = LsFixes.Where(ut => ut.Gvars == 36 && ut.Itb == 4 && ut.Gp1 == 3 && ut.Elea != 0).ToList();
            //LsSites = toChild.LsSites;
