    private object GetEntityKey<TDto>(TDto entity)
    {
        switch (entity)
        {
            case TieatrDto pln:
                return pln.Id;
            // case RubhieDto rub:
            //     return rub.Id;
            // case RubpstDto fmt:
            //     return fmt.Id;
            default:
                throw new InvalidOperationException($"Unknown entity type {typeof(TDto).Name}");
        }
    }
    private string GetSatyp(int? atyp)
    {
        if (atyp == null) return "string";
        var strAtyp = "";
        switch (atyp)
        {
            case 1:
                strAtyp = "string";
                break;
            case 2:
                strAtyp = "int";
                break;
            case 3:
                strAtyp = "decimal";
                break;
            case 4:
                strAtyp = "bool";
                break;
            case 5:
                strAtyp = "date";
                break;
            case 6:
                strAtyp = "adresse";
                break;
            default:
                strAtyp = "string";
                break;
        }
        return strAtyp;
    }
    // Notify guard/UI of pending changes
    private async Task NotifyPendingChanges()
    {
        await OnPendingStateChanged.InvokeAsync(new PendingState(
            _guard.HasPendingChanges(),
            _guard.GetPendingChangesCount()
        ));

        NbChanges = _guard.GetPendingChangesCount();
        await NbChangesChanged.InvokeAsync(NbChanges);
        StateHasChanged();
    }
