    private void CancelEdit() => editRowguid = null;

    private async Task DeleteAttribute(TieatrDto atr)
    {
        curOrga.Tieatrs.Remove(atr);

        // Register delete with OData context
        // Extract PK using your helper
        var key = GetEntityKey(atr);
        var rowguid = atr.Rowguid;
        // Queue delete in guard
        //await _guard.TrackDelete<TDto>(GetEntitySetName<TDto>(), key);
        await _guard.TrackDelete("Tieatrs", key, rowguid);
        Console.WriteLine($"🗑️ {atr.Liba} queued for delete");

        await NotifyPendingChanges();
    }

    private void StartAdd()
    {
        isAdding = true;
        draftAtr = new TieatrDto();
        draftAtr.Rowguid = Guid.NewGuid();
        draftAtr.Idorg = curOrga.Idorg;
        draftAtr.Zfro = 0;
        draftAtr.Ztbl = 0;
        draftAtr.Liba = "";
        draftAtr.Abg = "";
        draftAtr.Eta = 1;
        inZfro = 1;
    }

    private async Task SaveAdd(TieatrDto atr)
    {
        atr.Zfro = inZfro;
        if (atr.Zfro == 2 && atr.Atyp != 2)
            atr.Atyp = 1;
        atr.Satyp = GetSatyp(atr.Atyp);

        await _guard.TrackInsert("Tieatrs", atr);

        if (curOrga.Tieatrs.All(x => x.Rowguid != atr.Rowguid))
            curOrga.Tieatrs.Add(atr);

        editRowguid = null;
        tieatrkey = Guid.NewGuid().ToString();
        await NotifyPendingChanges();
        await InvokeAsync(StateHasChanged);
    }
    private async Task SaveEdit(TieatrDto atr)
    {
        if (atr.Zfro == 2 && atr.Atyp != 2)
            atr.Atyp = 1;

        atr.Satyp = GetSatyp(atr.Atyp);

        await _guard.TrackUpdate("Tieatrs", GetEntityKey(atr), atr);

        Uihelper.ReplaceItem(curOrga.Tieatrs, x => x.Rowguid == atr.Rowguid, atr);

        editRowguid = null;
        tieatrkey = Guid.NewGuid().ToString();
        await NotifyPendingChanges();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveDele(TieatrDto atr)
    {
        await _guard.TrackDelete("Tieatrs", GetEntityKey(atr), atr.Rowguid);
        Uihelper.RemoveItem(curOrga.Tieatrs, x => x.Rowguid == atr.Rowguid);
        if (editRowguid == atr.Rowguid)
            editRowguid = null;

        tieatrkey = Guid.NewGuid().ToString();
        await NotifyPendingChanges();
        await InvokeAsync(StateHasChanged);
    }
