@page "/categstk"
@using BlazorBootstrap
@using Blazored.LocalStorage
@using GxShared.Helpers
@using GxPilo.Services
@using Simple.OData.Client
@using AutoMapper
@using GxShared.GxDtos
@using GxShared.Interfaces
@using GxShared.Sess
@using GxShared.Others
@* @using Microsoft.EntityFrameworkCore *@
@using Newtonsoft.Json

@inject ILocalStorageService _localStorage
@inject NavigationManager _navManager
@inject HttpClientService _clieManager
@inject IMapper Mapper
@inject IJSRuntime _jsRun

<div class="container mt-3">

    <Button Color="ButtonColor.Success" @onclick="() => StartAdd()">New Category</Button>
    @if (draftCat != null)
    {
        <Grid TItem="StkcatDto"
              Data="@curOrga?.Stkcats.ToList()"
              @key="stkcatkey"
              AllowPaging="true"
              Responsive="true">
            <GridColumns>
                <GridColumn TItem="StkcatDto" HeaderText="No" Class="xcol1">
                    <ChildContent Context="item">
                        @item.Elea
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkcatDto" HeaderText="Label" Class="xcol3">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputText @bind-Value="draftCat.Liba" />
                        }
                        else
                        {
                            @item.Liba
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkcatDto" HeaderText="Parent" Class="xcol2">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputSelect @bind-Value="draftCat.Pid" class="me-3" style="width:auto">
                                <option value=0>?choisir</option>
                                @foreach (var utb in curOrga?.Tiecats.Where(c => c.Id != draftCat.Id))
                                {
                                    <option value=@utb.Id>@utb.Liba</option>
                                }
                            </InputSelect>
                        }
                        else
                        {
                            <InputSelect @bind-Value="item.Pid" class="me-3" style="width:auto" disabled>
                                <option value=0>aucun</option>
                                @foreach (var utb in curOrga?.Tiecats.Where(c => c.Id != item.Id))
                                {
                                    <option value=@utb.Id>@utb.Liba</option>
                                }
                            </InputSelect>
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkcatDto" HeaderText="Valeur" Class="xcol1">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputNumber @bind-Value="draftCat.Ival" placeholder="Lot" />
                        }
                        else
                        {
                            @item.Ival
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkcatDto" HeaderText="Lot" Class="xcol1">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputText @bind-Value="draftCat.Alot" placeholder="Lot" />
                        } else
                        {
                            @item.Alot
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkcatDto" HeaderText="Prix" Class="xcol1">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputNumber @bind-Value="draftCat.Prix" placeholder="Lot" />
                        }
                        else
                        {
                            @item.Prix
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkcatDto" HeaderText="Q.init" Class="xcol1">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputNumber @bind-Value="draftCat.Kinit" placeholder="Lot" />
                        }
                        else
                        {
                            @item.Kinit
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkcatDto" HeaderText="Q.Alert" Class="xcol1">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputNumber @bind-Value="draftCat.Kalert" placeholder="Lot" />
                        }
                        else
                        {
                            @item.Kalert
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkcatDto" HeaderText="Eta">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputSelect @bind-Value="draftCat.Eta">
                                <option class="jchx" value=0>?choisir</option>
                                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                {
                                    <option value=@tob.Elea>@tob.Liba</option>
                                }
                            </InputSelect>
                        }
                        else
                        {
                            <InputSelect @bind-Value="item.Eta" disabled="true">
                                <option class="jchx" value=0>aucun</option>
                                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                {
                                    <option value=@tob.Elea>@tob.Liba</option>
                                }
                            </InputSelect>
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkcatDto" HeaderText="Actions">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <Button Color="ButtonColor.Primary" Size="ButtonSize.Small"
                                    @onclick="() => SaveEdit(draftCat)">
                                Save
                            </Button>
                            <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                    @onclick="() => CancelEdit()">
                                Cancel
                            </Button>
                        }
                        else
                        {
                            @if (item.Id > 0)@* Prevent deletion of unsaved new entry *@
                            {
                                <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                        @onclick="() => StartEdit(item)">
                                    Edit
                                </Button>
                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                        @onclick="() => SaveDele(item)">
                                    Delete
                                </Button>
                            }
                            @* else
                            {
                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                        @onclick="() => CancelAdd(2, item)">
                                    Cancel
                                </Button>
                            } *@
                        }
                    </ChildContent>
                </GridColumn>
            </GridColumns>
        </Grid>
    }
    @if (isAdding)
    {
        <div class="flex-row align-items-center mt-3">
            <h5>New Category</h5>
            <InputText @bind-Value="draftCat.Liba" placeholder="Label" />
            <InputSelect @bind-Value="draftCat.Pid" class="me-3" style="width:auto">
                <option value=0>?choisir</option>
                @foreach (var utb in curOrga?.Stkcats.Where(c => c.Id != draftCat.Id))
                {
                    <option value=@utb.Id>@utb.Liba</option>
                }
            </InputSelect>
            <InputNumber @bind-Value="draftCat.Ival" placeholder="Valeur" />
            <InputText @bind-Value="draftCat.Alot" placeholder="Lot" />
            <InputNumber @bind-Value="draftCat.Prix" placeholder="Price" />
            <InputNumber @bind-Value="draftCat.Kinit" placeholder="Q.init" />
            <InputNumber @bind-Value="draftCat.Kalert" placeholder="Q.alert" />
            <InputSelect @bind-Value="draftCat.Eta">
                <option class="jchx" value=0>?choisir</option>
                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                {
                    <option value=@tob.Elea>@tob.Liba</option>
                }
            </InputSelect>
            <Button Color="ButtonColor.Success" @onclick="() => SaveAdd(draftCat)">Add</Button>
            <Button Color="ButtonColor.Secondary" @onclick="() => CancelAdd(1, draftCat)">Cancel</Button>
        </div>
    }
</div>
<style>
    .xcolx {
        width: 40px !important;
    }

    .xcol1 {
        width: 60px;
    }

    .xcol2 {
        width: 120px;
    }

    .xcol3 {
        width: 180px;
    }

    .xcol4 {
        width: 240px;
    }
        /* Ensure inputs inside these columns fill the width */
        .xcol1 input,
        .xcol2 input,
        .xcol3 input,
        .xcol4 input {
            width: 100%;
            box-sizing: border-box; /* prevents overflow due to padding/border */
        }

    .editing-row {
        pointer-events: none; /* Blocks all clicks on row */
    }

        .editing-row * {
            pointer-events: auto; /* Re-enables clicks on buttons/inputs */
        }
</style>
@code {
    private bool isLoading = true;

    [Parameter]
    public IODataClient _InODaClient { get; set; }
    [Parameter]
    public GxorgaDto curOrga { get; set; }
    [Parameter]
    public int Orig { get; set; }
    [Parameter]
    public ChildVars toChild { get; set; }
    [Parameter]
    public int toMenu { get; set; }
    [Parameter]
    public RenderFragment ChildContent { get; set; }
    [Parameter]
    public List<Gpdivh> LsDivs { get; set; }
    [Parameter]
    public List<Gtabl> EnsTbls { get; set; } // Dropdown options

    // Guard
    [Parameter]
    public IPendingChangesGuard _guard { get; set; }
    [Parameter]
    public EventCallback<PendingState> OnPendingStateChanged { get; set; }
    [Parameter]
    public int NbChanges { get; set; }
    [Parameter]
    public EventCallback<int> NbChangesChanged { get; set; }

    //[Parameter] public ItemClientService ItemService { get; set; }
    //[Parameter] public StockClientService StockService { get; set; }
    private List<StkcatDto> LsCats = new();
    private List<Gpfixe> LsFixes = new();
    private Guid? editRowguid;
    private string stkcatkey = ""; // Force grid refresh
    private bool isAdding = false;
    private StkcatDto draftCat = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            // if (toChild == null || curOrga == null)
            // {
            //     Console.WriteLine("Missing parent data");
            //     return;
            // }
            // isAuthenticated = toChild.isAuthenticated;
            // authUser = toChild.authUser;
            // if (!isAuthenticated)
            // {
            //     Imessage = "CONNEXION, Utilisateur non authentifie";
            //     return;
            // }
            // //LsVars = toChild.LsVars;
            // LsFixes = toChild.LsFixes;
            //LsDoms = toChild.LsFixes.Where(ut => ut.Gvars == 36 && ut.Itb == 4 && ut.Gp1 == 3 && ut.Elea != 0).ToList();
            //LsDoms = LsFixes.Where(ut => ut.Gvars == 36 && ut.Itb == 4 && ut.Gp1 == 3 && ut.Elea != 0).ToList();
            //LsSites = toChild.LsSites;
            //_lgcdu = 3;
            LsCats = curOrga?.Stkcats.ToList();
            LsFixes = toChild.LsFixes.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"22error loading cat-Tie: {ex.Message}");
        }
    }
    // and call this in OnParametersSet
    protected override void OnParametersSet()
    {
        SubscribeToGuard();
    }
    // set up subscription locally
    private void SubscribeToGuard()
    {
        _guard.OnChanges += async () =>
        {
            NbChanges = _guard.GetPendingChangesCount();
            await NbChangesChanged.InvokeAsync(NbChanges);
            StateHasChanged();
        };
    }
    private void StartEdit(StkcatDto atr)
    {
        editRowguid = atr.Rowguid;
        draftCat = new StkcatDto
        {
            Id = atr.Id,
            Idorg = atr.Idorg,
            Liba = atr.Liba,
            Abg = atr.Abg,
            Pid = atr.Pid,
            Xtyp = atr.Xtyp,
            Prix = atr.Prix,
            Kinit = atr.Kinit,
            Kalert = atr.Kalert,
            Eta = atr.Eta,
            Rowguid = atr.Rowguid
        };
    }

    private void CancelEdit() => editRowguid = null;

    private void StartAdd()
    {
        isAdding = true;
        draftCat = new StkcatDto();
        draftCat.Rowguid = Guid.NewGuid();
        draftCat.Idorg = curOrga.Idorg;
        draftCat.Pid = null;
        draftCat.Eta = 1;
    }
    private async Task SaveAdd(StkcatDto cat)
    {
        draftCat.Idorg = curOrga.Idorg;

        await _guard.TrackInsert("Stkcats", cat);

        if (curOrga.Stkcats.All(x => x.Rowguid != cat.Rowguid))
            curOrga.Stkcats.Add(cat);

        editRowguid = null;
        stkcatkey = Guid.NewGuid().ToString();
        await NotifyPendingChanges();
        await InvokeAsync(StateHasChanged);
    }
    private async Task SaveEdit(StkcatDto cat)
    {
        await _guard.TrackUpdate("Stkcats", GetEntityKey(cat), cat);

        Uihelper.ReplaceItem(curOrga.Stkcats, x => x.Rowguid == cat.Rowguid, cat);

        editRowguid = null;
        stkcatkey = Guid.NewGuid().ToString();
        await NotifyPendingChanges();
        await InvokeAsync(StateHasChanged);
    }
    private async Task SaveDele(StkcatDto cat)
    {
        await _guard.TrackDelete("Stkcats", GetEntityKey(cat), cat.Rowguid);
        Uihelper.RemoveItem(curOrga.Stkcats, x => x.Rowguid == cat.Rowguid);
        if (editRowguid == cat.Rowguid)
            editRowguid = null;

        stkcatkey = Guid.NewGuid().ToString();
        await NotifyPendingChanges();
        await InvokeAsync(StateHasChanged);
    }

    // private async Task SaveAdd()
    // {
    //     draftCat.Idorg = curOrga.Idorg;
    //     // Register add with OData context
    //     curOrga.Stkcats.Add(draftCat);
    //     await _guard.TrackInsert("Stkcats", draftCat);
    //     Console.WriteLine($"➕ NEW {draftCat.Liba} → TrackInsert");
    //     isAdding = false;
    //     await NotifyPendingChanges();
    //     StateHasChanged();
    // }
    private void CancelAdd(int orig, StkcatDto uncat)
    {
        if (orig == 2)
        {
            curOrga.Stkcats.Remove(uncat);
        }
        else
        {
            draftCat = new();
        }
        isAdding = false;
    }
    private object GetEntityKey<TDto>(TDto entity)
    {
        switch (entity)
        {
            case StkcatDto pln:
                return pln.Id;
            // case RubhieDto rub:
            //     return rub.Id;
            // case RubpstDto fmt:
            //     return fmt.Id;
            default:
                throw new InvalidOperationException($"Unknown entity type {typeof(TDto).Name}");
        }
    }
    // 🔥 Generic Rowguid (no reflection)
    private static Guid GetRowguid<T>(T entity) where T : class
        => ((dynamic)entity).Rowguid;  // Or property expression
    // Notify guard/UI of pending changes
    private async Task NotifyPendingChanges()
    {
        await OnPendingStateChanged.InvokeAsync(new PendingState(
            _guard.HasPendingChanges(),
            _guard.GetPendingChangesCount()
        ));

        NbChanges = _guard.GetPendingChangesCount();
        await NbChangesChanged.InvokeAsync(NbChanges);
        StateHasChanged();
    }
}