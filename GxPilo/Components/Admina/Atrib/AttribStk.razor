    // set up subscription locally
    private void SubscribeToGuard()
    {
        _guard.OnChanges += async () =>
        {
            NbChanges = _guard.GetPendingChangesCount();
            await NbChangesChanged.InvokeAsync(NbChanges);
            StateHasChanged();
        };
    }
    private void StartEdit(StkatrDto atr)
    {
        editRowguid = atr.Rowguid;
        draftAtr = new StkatrDto
        {
            Id = atr.Id,
            Idorg = atr.Idorg,
            Elea = atr.Elea,
            Zfro = atr.Zfro,
            Ztbl = atr.Ztbl,
            Liba = atr.Liba,
            Abg = atr.Abg,
            Atyp = atr.Atyp,
            Eta = atr.Eta,
            Rowguid = atr.Rowguid
        };
    }
    private async Task SaveAdd(StkatrDto atr)
    {
        atr.Zfro = inZfro;
        if (atr.Zfro == 2 && atr.Atyp != 2)
            atr.Atyp = 1;
        atr.Satyp = GetSatyp(atr.Atyp);

        await _guard.TrackInsert("Stkatrs", atr);

        if (curOrga.Stkatrs.All(x => x.Rowguid != atr.Rowguid))
            curOrga.Stkatrs.Add(atr);

        editRowguid = null;
        stkatrkey = Guid.NewGuid().ToString();
        await NotifyPendingChanges();
        await InvokeAsync(StateHasChanged);
    }
    private async Task SaveEdit(StkatrDto atr)
    {
        if (atr.Zfro == 2 && atr.Atyp != 2)
            atr.Atyp = 1;

        atr.Satyp = GetSatyp(atr.Atyp);

        await _guard.TrackUpdate("Stkatrs", GetEntityKey(atr), atr);

        Uihelper.ReplaceItem(curOrga.Stkatrs, x => x.Rowguid == atr.Rowguid, atr);

        editRowguid = null;
        stkatrkey = Guid.NewGuid().ToString();
        await NotifyPendingChanges();
        await InvokeAsync(StateHasChanged);
    }
    private async Task SaveDele(StkatrDto atr)
    {
        await _guard.TrackDelete("Stkatrs", GetEntityKey(atr), atr.Rowguid);
        Uihelper.RemoveItem(curOrga.Stkatrs, x => x.Rowguid == atr.Rowguid);
        if (editRowguid == atr.Rowguid)
            editRowguid = null;

        stkatrkey = Guid.NewGuid().ToString();
        await NotifyPendingChanges();
        await InvokeAsync(StateHasChanged);
    }
