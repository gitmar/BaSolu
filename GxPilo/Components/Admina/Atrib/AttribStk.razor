@page "/attribstk"
@layout AtribMenu

@using BlazorBootstrap
@using Blazored.LocalStorage
@using GxShared.Helpers
@using GxPilo.Services
@using Simple.OData.Client
@using AutoMapper
@using GxShared.GxDtos
@using GxShared.Interfaces
@using GxShared.Sess
@using GxShared.Others
@* @using Microsoft.EntityFrameworkCore *@
@using Newtonsoft.Json

@inject ILocalStorageService _localStorage
@inject NavigationManager _navManager
@inject HttpClientService _clieManager
@inject IMapper Mapper
@inject IJSRuntime _jsRun

<div class="container mt-3">

    <Button Color="ButtonColor.Success" @onclick="() => StartAdd()">New Attribute</Button>
    @if (draftAtr != null)
    {
        <Grid TItem="StkatrDto"
              Data="@curOrga?.Stkatrs.ToList()"
              @key="stkatrkey"
              AllowPaging="true"
              Responsive="true">
            <GridColumns>
                <GridColumn TItem="StkatrDto" HeaderText="No" Class="xcol1">
                    <ChildContent Context="item">
                        @item.Elea
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkatrDto" HeaderText="Label" Class="xcol3">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputText @bind-Value="draftAtr.Liba" />
                        }
                        else
                        {
                            @item.Liba
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkatrDto" HeaderText="Origine" Class="xcol1">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputSelect @bind-Value="draftAtr.Zfro" class="me-3" style="width:auto">
                                <option value=1>constante</option>
                                <option value=2>table</option>
                            </InputSelect>
                        }
                        else
                        {
                            <InputSelect @bind-Value="item.Zfro" class="me-3" style="width:auto" disabled>
                                <option value=1>constante</option>
                                <option value=2>table</option>
                            </InputSelect>
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkatrDto" HeaderText="Table" Class="xcol1">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputSelect @bind-Value="draftAtr.Ztbl">
                                <option value=0>aucun</option>
                                @foreach (var fx in EnsTbls.Where(t => t.Tenr == 1 && t.Btyp == 2))
                                {
                                    <option value=@fx.Tref>@fx.Liba</option>
                                }
                            </InputSelect>
                        }
                        else
                        {
                            <InputSelect @bind-Value="item.Ztbl" class="me-3" style="width:auto" disabled>
                                <option value=0>aucun</option>
                                @foreach (var fx in EnsTbls.Where(t => t.Tenr == 1 && t.Btyp == 2))
                                {
                                    <option value=@fx.Tref>@fx.Liba</option>
                                }
                            </InputSelect>
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkatrDto" HeaderText="Type" Class="xcol2">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputSelect @bind-Value="draftAtr.Atyp" class="me-3" style="width:auto">
                                <option value=0>?choisir</option>
                                @foreach (var fx in LsFixes.Where(u => u.Gvars == 32 && u.Itb == 2 && u.Elea != 0))
                                {
                                    <option value=@fx.Elea>@fx.Liba</option>
                                }
                            </InputSelect>
                        }
                        else
                        {
                            <InputSelect @bind-Value="item.Atyp" class="me-3" style="width:auto" disabled>
                                <option value=0>?choisir</option>
                                @foreach (var fx in LsFixes.Where(u => u.Gvars == 32 && u.Itb == 2 && u.Elea != 0))
                                {
                                    <option value=@fx.Elea>@fx.Liba</option>
                                }
                            </InputSelect>
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkatrDto" HeaderText="Eta">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputSelect @bind-Value="draftAtr.Eta">
                                <option class="jchx" value=0>?choisir</option>
                                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                {
                                    <option value=@tob.Elea>@tob.Liba</option>
                                }
                            </InputSelect>
                        }
                        else
                        {
                            <InputSelect @bind-Value="item.Eta" disabled>
                                <option class="jchx" value=0>?choisir</option>
                                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                {
                                    <option value=@tob.Elea>@tob.Liba</option>
                                }
                            </InputSelect>
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkatrDto" HeaderText="Actions">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <Button Color="ButtonColor.Primary" Size="ButtonSize.Small"
                                    @onclick="() => SaveEdit(draftAtr)">
                                Save
                            </Button>
                            <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                    @onclick="() => CancelEdit()">
                                Cancel
                            </Button>
                        }
                        else
                        {
                            @if (item.Id > 0)@* Prevent deletion of unsaved new entry *@
                            {
                                <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                        @onclick="() => StartEdit(item)">
                                    Edit
                                </Button>
                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                        @onclick="() => SaveDele(item)">
                                    Delete
                                </Button>
                            }
                            @* else
                            {
                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                        @onclick="() => CancelAdd(2, item)">
                                    Cancel
                                </Button>
                            } *@
                        }
                    </ChildContent>
                </GridColumn>
            </GridColumns>
        </Grid>
    }
    @if (isAdding)
    {
        <div class="mt-3">
            <h5>New Attribute</h5>
            <InputText @bind-Value="draftAtr.Liba" placeholder="Label" />
            <InputSelect @bind-Value="inZfro" class="me-3" style="width:auto">
                <option value=1>constante</option>
                <option value=2>table</option>
            </InputSelect>
            @if (inZfro == 2)
            {
                <InputSelect @bind-Value="draftAtr.Ztbl" class="me-3" style="width:auto">
                    @foreach (var fx in EnsTbls.Where(t => t.Tenr == 1 && t.Btyp == 2))
                    {
                        <option value=@fx.Tenr>@fx.Liba</option>
                    }
                </InputSelect>
            }
            <InputSelect @bind-Value="draftAtr.Atyp" class="me-3" style="width:auto">
                <option value=0>?type</option>
                @foreach (var fx in LsFixes.Where(u => u.Gvars == 32 && u.Itb == 2 && u.Elea != 0))
                {
                    <option value=@fx.Elea>@fx.Liba</option>
                }
            </InputSelect>
            <InputSelect @bind-Value="draftAtr.Eta">
                <option class="jchx" value=0>?etat</option>
                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                {
                    <option value=@tob.Elea>@tob.Liba</option>
                }
            </InputSelect>
            <Button Color="ButtonColor.Success" @onclick="() => SaveAdd(draftAtr)">Add</Button>
            <Button Color="ButtonColor.Secondary" @onclick="() => CancelAdd(1, draftAtr)">Cancel</Button>
        </div>
    }
</div>
<style>
    .xcolx {
        width: 40px !important;
    }

    .xcol1 {
        width: 60px;
    }

    .xcol2 {
        width: 120px;
    }

    .xcol3 {
        width: 180px;
    }

    .xcol4 {
        width: 240px;
    }
        /* Ensure inputs inside these columns fill the width */
        .xcol1 input,
        .xcol2 input,
        .xcol3 input,
        .xcol4 input {
            width: 100%;
            box-sizing: border-box; /* prevents overflow due to padding/border */
        }

    .editing-row {
        pointer-events: none; /* Blocks all clicks on row */
    }

        .editing-row * {
            pointer-events: auto; /* Re-enables clicks on buttons/inputs */
        }
</style>
