@page "/attribstk"
@layout AtribMenu

@using BlazorBootstrap
@using Blazored.LocalStorage
@using GxShared.Helpers
@using GxPilo.Services
@using Simple.OData.Client
@using AutoMapper
@using GxShared.GxDtos
@using GxShared.Interfaces
@using GxShared.Sess
@* @using Microsoft.EntityFrameworkCore *@
@using Newtonsoft.Json

@inject ILocalStorageService _localStorage
@inject NavigationManager _navManager
@inject HttpClientService _clieManager
@inject IMapper Mapper
@inject IJSRuntime _jsRun

<div class="container mt-3">

    <Button Color="ButtonColor.Success" @onclick="() => StartAdd()">Add New Attribute</Button>
    @if (draftAtr != null)
    {
        <Grid TItem="StkatrDto" 
        Data="@curOrga?.Stkatrs.ToList()" 
        AllowPaging="true" 
        Responsive="true">
            <GridColumns>
                <GridColumn TItem="StkatrDto" HeaderText="Id" Class="xcol1">
                    <ChildContent Context="item">@item.Id</ChildContent>
                </GridColumn>
                <GridColumn TItem="StkatrDto" HeaderText="Label" Class="xcol3">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputText @bind-Value="draftAtr.Liba" />
                        }
                        else
                        {
                            @item.Liba
                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkatrDto" HeaderText="Type" Class="xcol2">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputSelect @bind-Value="draftAtr.Atyp" class="me-3" style="width:auto">
                                <option value="0">?choisir</option>
                                @foreach (var fx in LsFixes.Where(u => u.Gvars == 32 && u.Itb == 2 && u.Elea != 0))
                                {
                                    <option value="@fx.Elea">@fx.Liba</option>
                                }
                            </InputSelect>
                        }
                        else
                        {
                            <InputSelect @bind-Value="draftAtr.Atyp" class="me-3" style="width:auto" disabled>
                                <option value="0">?choisir</option>
                                @foreach (var fx in LsFixes.Where(u => u.Gvars == 32 && u.Itb == 2 && u.Elea != 0))
                                {
                                    <option value="@fx.Elea">@fx.Liba</option>
                                }
                            </InputSelect>
                        }
                    </ChildContent>
                </GridColumn>
                @* <GridColumn TItem="StkatrDto" HeaderText="Parent" Class="xcol2">
                <ChildContent Context="item">
                    @if (editRowguid == item.Rowguid)
                    {
                        <InputSelect @bind-Value="draftAtr.Pid" class="me-3" style="width:auto">
                            <option value="0">?choisir</option>
                            @foreach (var utb in LsAtrs.Where(u => u.Id != draftAtr.Id))
                            {
                                <option value="@utb.Id">@utb.Liba</option>
                            }
                        </InputSelect>
                    }
                    else
                    {
                        <InputSelect @bind-Value="draftAtr.Pid" class="me-3" style="width:auto" disabled>
                            <option value="0">?choisir</option>
                            @foreach (var utb in LsAtrs.Where(u => u.Id != draftAtr.Id))
                            {
                                <option value="@utb.Id">@utb.Liba</option>
                            }
                        </InputSelect>
                    }
                </ChildContent>
            </GridColumn> *@
                <GridColumn TItem="StkatrDto" HeaderText="Actions">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <Button Color="ButtonColor.Primary" Size="ButtonSize.Small"
                            @onclick="() => SaveEdit(item)">
                                Save
                            </Button>
                            <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                            @onclick="() => CancelEdit()">
                                Cancel
                            </Button>
                        }
                        else
                        {
                            @if (item.Id > 0)@* Prevent deletion of unsaved new entry *@
                            {
                                <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                @onclick="() => StartEdit(item)">
                                    Edit
                                </Button>
                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                @onclick="() => DeleteAttribute(item)">
                                    Delete
                                </Button>
                            }
                            @* else
                            {
                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                        @onclick="() => CancelAdd(2, item)">
                                    Cancel 
                                </Button>
                            } *@
                        }
                    </ChildContent>
                </GridColumn>
            </GridColumns>
        </Grid>
    }
    @if (isAdding)
    {
        <div class="mt-3">
            <h5>New Attribute</h5>
            <InputText @bind-Value="draftAtr.Liba" placeholder="Label" />
            <InputSelect @bind-Value="draftAtr.Atyp" class="me-3" style="width:auto">
                <option value="0">?choisir</option>
                @foreach (var fx in LsFixes.Where(u => u.Gvars == 32 && u.Itb == 2 && u.Elea != 0))
                {
                    <option value="@fx.Elea">@fx.Liba</option>
                }
            </InputSelect>
            <Button Color="ButtonColor.Success" @onclick="() => SaveAdd()">Add</Button>
            <Button Color="ButtonColor.Secondary" @onclick="() => CancelAdd(1, draftAtr)">Cancel</Button>
        </div>
    }
</div>
<style>
    .xcolx {
        width: 40px !important;
    }

    .xcol1 {
        width: 60px;
    }

    .xcol2 {
        width: 120px;
    }

    .xcol3 {
        width: 180px;
    }

    .xcol4 {
        width: 240px;
    }
        /* Ensure inputs inside these columns fill the width */
        .xcol1 input,
        .xcol2 input,
        .xcol3 input,
        .xcol4 input {
            width: 100%;
            box-sizing: border-box; /* prevents overflow due to padding/border */
        }

    .editing-row {
        pointer-events: none; /* Blocks all clicks on row */
    }

        .editing-row * {
            pointer-events: auto; /* Re-enables clicks on buttons/inputs */
        }
</style>
@code {
    private bool isLoading = true;

    [Parameter] 
    public IODataClient _InODaClient { get; set; }
    [Parameter] 
    public GxorgaDto curOrga { get; set; }
    [Parameter]
    public int Orig { get; set; }
    [Parameter] 
    public ChildVars toChild { get; set; }
    [Parameter] 
    public int toMenu { get; set; }
    [Parameter]
    public RenderFragment ChildContent { get; set; }
    [Parameter]
    public List<Gpdivh> LsDivs { get; set; }

    // Guard
    [Parameter] 
    public IPendingChangesGuard _guard { get; set; }
    [Parameter] 
    public EventCallback<PendingState> OnPendingStateChanged { get; set; }
    [Parameter] 
    public int NbChanges { get; set; }
    [Parameter] 
    public EventCallback<int> NbChangesChanged { get; set; }

    //[Parameter] public ItemClientService ItemService { get; set; }
    //[Parameter] public StockClientService StockService { get; set; }
    private List<StkatrDto> LsAtrs = new();
    private List<Gpfixe> LsFixes = new();
    private Guid? editRowguid;
    private bool isAdding = false;
    private StkatrDto draftAtr = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            // if (toChild == null || curOrga == null)
            // {
            //     Console.WriteLine("Missing parent data");
            //     return;
            // }
            // isAuthenticated = toChild.isAuthenticated;
            // authUser = toChild.authUser;
            // if (!isAuthenticated)
            // {
            //     Imessage = "CONNEXION, Utilisateur non authentifie";
            //     return;
            // }
            // //LsVars = toChild.LsVars;
            // LsFixes = toChild.LsFixes;
            //LsDoms = toChild.LsFixes.Where(ut => ut.Gvars == 36 && ut.Itb == 4 && ut.Gp1 == 3 && ut.Elea != 0).ToList();
            //LsDoms = LsFixes.Where(ut => ut.Gvars == 36 && ut.Itb == 4 && ut.Gp1 == 3 && ut.Elea != 0).ToList();
            //LsSites = toChild.LsSites;
            //_lgcdu = 3;
            LsAtrs = curOrga?.Stkatrs.ToList();
            LsFixes = toChild.LsFixes.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"22error loading atr-Stk: {ex.Message}");
        }
    }
    // and call this in OnParametersSet
    protected override void OnParametersSet()
    {
        SubscribeToGuard();
    }
    // set up subscription locally
    private void SubscribeToGuard()
    {
        _guard.OnChanges += async () =>
        {
            NbChanges = _guard.GetPendingChangesCount();
            await NbChangesChanged.InvokeAsync(NbChanges);
            StateHasChanged();
        };
    }
    private void StartEdit(StkatrDto atr)
    {
        editRowguid = atr.Rowguid;
        draftAtr = new StkatrDto { Id = atr.Id, Liba = atr.Liba, Atyp = atr.Atyp, Rowguid = atr.Rowguid };
    }

    private async Task SaveEdit(StkatrDto atr)
    {
        atr.Liba = draftAtr.Liba;
        atr.Atyp = draftAtr.Atyp;
        // Register update with OData context
        var key = GetEntityKey(atr); // helper to extract PK
        _guard.TrackUpdate("Stkatrs", key, atr);
        editRowguid = null;
        await NotifyPendingChanges();
    }

    private void CancelEdit() => editRowguid = null;

    private async Task DeleteAttribute(StkatrDto atr)
    {
        curOrga.Stkatrs.Remove(atr);

        // Register delete with OData context
        // Extract PK using your helper
        var key = GetEntityKey(atr);

        // Queue delete in guard
        //_guard.TrackDelete<TDto>(GetEntitySetName<TDto>(), key);
        _guard.TrackDelete("Stkatrs", key);
        Console.WriteLine($"🗑️ {atr.Liba} queued for delete");

        await NotifyPendingChanges();
    }

    private void StartAdd()
    {
        isAdding = true;
        draftAtr = new StkatrDto();
        draftAtr.Idorg = curOrga.Idorg;
    }

    private async Task SaveAdd()
    {
        draftAtr.Rowguid = Guid.NewGuid();
        draftAtr.Idorg = curOrga.Idorg;
        // Register add with OData context
        curOrga.Stkatrs.Add(draftAtr);
        _guard.TrackInsert("Stkatrs", draftAtr);
        Console.WriteLine($"➕ NEW {draftAtr.Liba} → TrackInsert");
        isAdding = false;
        await NotifyPendingChanges();
    }
    private void CancelAdd(int orig, StkatrDto unatr)
    {
        if (orig == 2)
        {
            var key = GetEntityKey(unatr);
            //curOrga.Stkatrs.Remove(unatr);
            //_guard.TrackDelete("Stkatrs", key);
        } else
        {
            draftAtr = new();
        }
        isAdding = false;
    }
    private object GetEntityKey<TDto>(TDto entity)
    {
        switch (entity)
        {
            case StkatrDto pln:
                return pln.Id;
            // case RubhieDto rub:
            //     return rub.Id;
            // case RubpstDto fmt:
            //     return fmt.Id;
            default:
                throw new InvalidOperationException($"Unknown entity type {typeof(TDto).Name}");
        }
    }
    // Notify guard/UI of pending changes
    private async Task NotifyPendingChanges()
    {
        await OnPendingStateChanged.InvokeAsync(new PendingState(
            _guard.HasPendingChanges(),
            _guard.GetPendingChangesCount()
        ));

        NbChanges = _guard.GetPendingChangesCount();
        await NbChangesChanged.InvokeAsync(NbChanges);
        StateHasChanged();
    }
}
