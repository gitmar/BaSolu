    private void StartAdd()
    {
        isAdding = true;
        draftAtr = new StkatrDto();
        draftAtr.Rowguid = Guid.NewGuid();
        draftAtr.Idorg = curOrga.Idorg;
        draftAtr.Zfro = 0;
        draftAtr.Ztbl = 0;
        draftAtr.Liba = "";
        draftAtr.Abg = "";
        draftAtr.Satyp = "";
        draftAtr.Eta = 1;
        inZfro = 1;
    }

    private void CancelAdd(int orig, StkatrDto unatr)
    {
        if (orig == 2)
        {
            var key = GetEntityKey(unatr);
            //curOrga.Stkatrs.Remove(unatr);
            //await _guard.TrackDelete("Stkatrs", key);
        }
        else
        {
            draftAtr = new();
        }
        isAdding = false;
    }
    private object GetEntityKey<TDto>(TDto entity)
    {
        switch (entity)
        {
            case StkatrDto pln:
                return pln.Id;
            // case RubhieDto rub:
            //     return rub.Id;
            // case RubpstDto fmt:
            //     return fmt.Id;
            default:
                throw new InvalidOperationException($"Unknown entity type {typeof(TDto).Name}");
        }
    }
    private static Guid GetRowguid<T>(T entity) where T : class
    {
        switch (entity)
        {
            case StkatrDto pln:
                return pln.Rowguid;
            // case RubhieDto rub:
            //     return rub.Rowguid;
            // case RubpstDto fmt:
            //     return fmt.Rowguid;
            default:
                throw new InvalidOperationException($"Unknown entity type {typeof(T).Name}");
        }
    }
    private string GetSatyp(int? atyp)
    {
        if (atyp == null) return "string";
        var strAtyp = "";
        switch (atyp)
        {
            case 1:
                strAtyp = "string";
                break;
            case 2:
                strAtyp = "int";
                break;
            case 3:
                strAtyp = "decimal";
                break;
            case 4:
                strAtyp = "bool";
                break;
            case 5:
                strAtyp = "date";
                break;
            case 6:
                strAtyp = "adresse";
                break;
            default:
                strAtyp = "string";
                break;
        }
        return strAtyp;
    }
    // Notify guard/UI of pending changes
    private async Task NotifyPendingChanges()
    {
        await OnPendingStateChanged.InvokeAsync(new PendingState(
            _guard.HasPendingChanges(),
            _guard.GetPendingChangesCount()
        ));

        NbChanges = _guard.GetPendingChangesCount();
        await NbChangesChanged.InvokeAsync(NbChanges);
        StateHasChanged();
    }
}
