    // Remove from parent collection
    private void RemoveFromParentCollection<T>(T entity)
    {
        // Plngen: top-level
        if (entity is PlngenDto pln && MyDaPlans.Any(p => p.Rowguid == pln.Rowguid))
            MyDaPlans.Remove(pln);
        // Rubhie: parent Plngen.Rubhies
        else if (entity is RubhieDto rub)
        {
            var parent = MyDaPlans.FirstOrDefault(p => p.Id == rub.Ipln);
            parent?.Rubhies?.Remove(rub);
        }
        // Rubpst: parent Rubhie.Rubpsts
        else if (entity is RubpstDto fmt)
        {
            var parentRub = MyDaPlans.SelectMany(p => p.Rubhies).FirstOrDefault(r => r.Id == fmt.Ihie);
            parentRub?.Rubpsts?.Remove(fmt);
        }
    }
