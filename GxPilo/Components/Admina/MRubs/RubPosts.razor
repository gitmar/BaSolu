    private void StartCancelAdd(EntityLevel level, object entity)
    {
        var rowguid = MLEntityKeyHelper.GetRowguidAsGuid(entity);
        switch (level)
        {
            case EntityLevel.Plan:
                CancelAdd(level, entity);
                curOrga.Plngens.RemoveAll(x => x.Rowguid == rowguid);
                PlnRenderKey = Guid.Empty;
                break;
            case EntityLevel.Hie:
                CancelAdd(level, entity);
                curPlan.Rubhies.RemoveAll(x => x.Rowguid == rowguid);
                RubRenderKey = Guid.Empty;
                break;
            case EntityLevel.Pst:
                CancelAdd(level, entity);
                curRubr.Rubpsts.RemoveAll(x => x.Rowguid == rowguid);
                FmtRenderKey = Guid.Empty;
                break;
        }
    }
