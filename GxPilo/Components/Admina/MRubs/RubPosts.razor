            if (rowguid == Guid.Empty) return;
            if (IsAnyRowEditing && !IsRowEditing(rowguid)) return;
            myhie.Xedt1 = -1;
            _edHieOriginals[rowguid] = DeepClone(myhie);
            draftRub = DeepClone(myhie);

            RubRenderKey = rowguid;
            BeginEdit(EntityLevel.Hie, rowguid, draftRub);
            rHieModal.BodyCssClass = (orig == 1) ? "editable" : "readonly";
            Console.WriteLine("DETAILS HAS BEEN SHOWNED");
            rHieModal.ShowAsync();
        } else
        {
            Imessage = "details indisponible";
        }
    }
