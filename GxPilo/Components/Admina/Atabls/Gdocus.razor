    private async Task MarkAsModified<TDto>(TDto item, string entitySet) where TDto : class
    {
        // Reset flags (your convention)
        SetFlags(item, 0, 0, 0);  // Xadd1=Xedt1=Xdel1=0

        // Extract PK using your helper
        var key = GetEntityKey(item);

        // Queue update in guard
        await _guard.TrackUpdate(entitySet, key, item);

        Console.WriteLine($"modified liba {((dynamic)item).Liba} et abg {((dynamic)item).Abg}");
        Console.WriteLine($"✅ {entitySet} marked Modified (queued for update)");
    }
    private object DeepClone(object entity)
    {
        var settings = new JsonSerializerSettings
        {
            ReferenceLoopHandling = ReferenceLoopHandling.Ignore
        };

        var json = JsonConvert.SerializeObject(entity, settings);
        return JsonConvert.DeserializeObject(json, entity.GetType(), settings)!;
    }
    private object GetEntityKey<TDto>(TDto entity)
    {
        switch (entity)
        {
            case GsgfixDto pln:
                return pln.Xseq;
            default:
                throw new InvalidOperationException($"Unknown entity type {typeof(TDto).Name}");
        }
    }
    bool AreRowsEqual(GsgfixDto row1, GsgfixDto row2) =>
        row1.Liba == row2.Liba && row1.Abg == row2.Abg;
    private int NextSeq<T>(IEnumerable<T> source, Func<T, int?> selector)
    {
        int maxSeq = source.Any() ? source.Max(selector) ?? 0 : 0;
        return maxSeq + 1;
    }
