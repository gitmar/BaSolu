            MyDaDocus = new ObservableCollection<GsgfixDto>(curOrga.Gsgfixes
              .Where(uv => uv.Gvars == 3 && uv.Itb == xdom && uv.Elea >= 1)
              .ToList());
        } else if (xdom == 3)
        {
            MyDaDocus = new ObservableCollection<GsgfixDto>(curOrga.Gsgfixes
              .Where(uv => uv.Gvars == 41 && uv.Itb == 1 && uv.Elea != 0)
              .ToList());
        } else
        {
           MyDaDocus = new ObservableCollection<GsgfixDto>();
        }
        Console.WriteLine($"Nb. documents : {MyDaDocus.Count}");
        StateHasChanged();
    }
    
