    //Global
    private int _lgcdu = 0;
    //private int ITyDoc = 1; //1Actes
    private int _iTyDoc = 1; //1Actes
    public int ITyDoc
    {
        get => _iTyDoc;
        set
        {
            _iTyDoc = value;
            SelTypDoc(value);
        }
    }
    private string atrTitle = "";

    //data
    private ObservableCollection<GsgfixDto> MyDaDocus { get; set; } = new();
