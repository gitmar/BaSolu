    private Guid? EdFixRowguid = null;// Currently editing row ID
    private Guid? DlFixRowguid = null;

    bool IsFixRowLocked(Guid rowGuid) =>
        !AllowMultipleEdits &&
        (EdFixRowguid.HasValue || DlFixRowguid.HasValue) &&
        EdFixRowguid != rowGuid &&
        DlFixRowguid != rowGuid;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            if (toChild == null || curOrga == null)
            {
                Console.WriteLine("Missing parent data");
                return;
            }
            isAuthenticated = toChild.isAuthenticated;
            authUser = toChild.authUser;
            if (!isAuthenticated)
            {
                Imessage = "CONNEXION, Utilisateur non authentifie";
                return;
            }
            //LsVars = toChild.LsVars;
            LsFixes = toChild.LsFixes;
            //LsDoms = LsFixes.Where(ut => ut.Gvars == 36 && ut.Itb == 4 && ut.Gp1 == 3 && ut.Elea != 0).ToList();
            //LsSites = toChild.LsSites;
            _lgcdu = 3;
            //var noslims = LsVars.Where(uv => uv.Idhie == 0 && uv.Gvars == 21 && uv.Itb == 1 && uv.Elea == 1);
            //if (noslims.Any()) _lgcdu = noslims.FirstOrDefault().Ivala;
            //ChargeParentData;
            Console.WriteLine($"Child init: Gsgfixes={curOrga.Gsgfixes?.Count ?? 0}");

            // 🔥 SAFE - Only initialize if Gsgfixs EXISTS
            if (curOrga.Gsgfixes != null && curOrga.Gsgfixes.Any())
            {
                MyDaDocus = new ObservableCollection<GsgfixDto>(curOrga.Gsgfixes
                    .Where(uv => uv.Gvars == 3 && uv.Itb == 1 && uv.Elea >= 1)
                    .ToList());
                Console.WriteLine($"Gsgfixes loaded: {curOrga.Gsgfixes.Count}");
            }
            else
            {
                Console.WriteLine("Gsgfixes null/empty - initializing empty collections");
                MyDaDocus = new ObservableCollection<GsgfixDto>();
            }
            atrTitle = "Saisie";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Child crash: {ex.Message}");
            Console.WriteLine($"Stack: {ex.StackTrace}");  // 🔥 More debug info
            Imessage = $"Erreur chargement: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
    // and call this in OnParametersSet
    protected override void OnParametersSet()
    {
        SubscribeToGuard();
    }
    // set up subscription locally
    private void SubscribeToGuard()
    {
        _guard.OnChanges += async () =>
        {
            NbChanges = _guard.GetPendingChangesCount();
            await NbChangesChanged.InvokeAsync(NbChanges);
            StateHasChanged();
        };
    }
    private async Task StartDocuNew(int tydoc)
    {
        Console.WriteLine("🚨 StartPlnNew");
        var lsnb = NextSeq(MyDaDocus, p => p.Iui);
        var newDoc = new GsgfixDto();
        if (tydoc == 1)
        {//docS
            newDoc = new GsgfixDto
            {
                Rowguid = Guid.NewGuid(),
                Idorg = curOrga.Idorg, //pere Id
                Iui = lsnb,
                Gvars = 3,
                Itb = 1,
                Gtyp = 1,
                Etyp = 1,
                Eta = 1,
                Xadd1 = -1, //newly added
                Xedt1 = 0,
                Xdel1 = 0
            };
        }
        else if (tydoc == 2)
        {//docP
            newDoc = new GsgfixDto
            {
            //Rowguid = Guid.NewGuid(),
                Rowguid = Guid.NewGuid(),
                Idorg = curOrga.Idorg, //pere Id
                Iui = lsnb,
                Gvars = 3,
                Itb = 2,
                Gtyp = 2,
                Etyp = 1,
                Totyp = 0,
                Tstyp = 0,
                Eta = 1,
                Xadd1 = -1, //newly added
                Xedt1 = 0,
                Xdel1 = 0
            };
        } //session pas creation
        else
        {
            return;
        }
        SetRowState(newDoc.Rowguid, RowState.AddPending);
        SetLightBackground(newDoc.Rowguid, true);
        MyDaDocus.Insert(0, newDoc);
        draftFix = (GsgfixDto)DeepClone(newDoc);
        EdFixRowguid = draftFix.Rowguid;
        isAddFix = true;
        isEdtFix = true;
        SetRowState(draftFix.Rowguid, RowState.EditPending);  // Shows Confirm/Cancel ✓
        FixeRenderKey = draftFix.Rowguid;
        //Console.WriteLine($"✅ New row added to curOrga.Gsgfixes - Count: {curOrga.Gsgfixes.Count}");
        StartRowEdit(draftFix.Rowguid, EntityLevel.Plan);
        StateHasChanged();
    }
    private async Task StartDocuEdit(GsgfixDto item, Guid rowguid)
    {
        //var client = (ODataClient)_InODaClient;
        //bool isNew = await client.IsNewAsync<GsgfixDto>("Gsgfixes", item.Xseq);
        bool isNew = item.Xseq == default; // for int, default == 0
        if (isNew)
        {
            Imessage = "🚫 Cannot edit new Plan: Please save it first.";
            return;
        }

        if (isNew)
        { //not saved yet
            Imessage = "🚫 Cannot edit new Plan: Please save it first.";
            return;
        }
        if (rowguid == Guid.Empty) return;
        item.Xedt1 = -1;
        if (item.Jele != 0) item.Iui = (int)item.Jele;
        SetRowState(rowguid, RowState.EditPending);  // Shows Confirm/Cancel buttons
        _edFixOriginals[rowguid] = (GsgfixDto)DeepClone(item);
        EdFixRowguid = AllowMultipleEdits ? null : rowguid;
        draftFix = (GsgfixDto)DeepClone(item);
        isEdtFix = true;
        StartRowEdit(rowguid, EntityLevel.Plan);
        StateHasChanged();
    }

    // ✅ 2.1 CONFIRM OPERATIONS
    private async Task ConfirmDocuEdit(GsgfixDto item) =>
        await UnifiedEditAction(item, true, EntityLevel.Plan);

    // ✅ 2.2 CANCEL OPERATIONS
    private async Task CancelDocuEdit(GsgfixDto item) =>
        await UnifiedEditAction(item, false, EntityLevel.Plan);

    private async Task UnifiedEditAction(object item, bool isConfirm, EntityLevel level)
    {
        switch (level)
        {
            case EntityLevel.Plan:
                await ProcessPlan((GsgfixDto)item, isConfirm);
                break;
        }
    }

    private async Task ProcessPlan(GsgfixDto pln, bool isConfirm)
    {
        await ProcessEntity(pln, isConfirm, "Gsgfixes", p => ValidatePln(p));
    }

    private async Task ProcessEntity<T>(T entity, bool isConfirm, string entitySet, Func<T, bool> validate)
    where T : class
    {
        Console.WriteLine($"🔄 Process{typeof(T).Name}: {(isConfirm ? "CONFIRM" : "CANCEL")}");
    
        if (entity == null)
        {
            Imessage = "entity nulle";
            StateHasChanged();
            return;
        }

        if (isConfirm)
        {
            // 🔥 1. Copy draft → entity (for validation)
            CopyDraftToGridItem(entity);
        
            // 🔥 2. VALIDATE (now has updated values)
            if (!validate(entity))
            {
                Console.WriteLine($"❌ Validation failed: {Imessage}");
                StateHasChanged();
                return;
            }
        
            // 🔥 3. NEW vs EXISTING (SINGLE operation)
            bool isNew = GetXadd1(entity) == -1;  // Assumes GetXadd1<T>
            if (isNew)
            {
                await _guard.TrackInsert(entitySet, entity);
                Console.WriteLine($"➕ NEW {typeof(T).Name} → TrackInsert");
            }
            else
            {
                var key = GetEntityKey(entity); // helper to extract PK
                await _guard.TrackUpdate(entitySet, key, entity);
                Console.WriteLine($"✏️ EXISTING {typeof(T).Name} → TrackUpdate");
            }
        
            // 🔥 4. Confirm flags ONCE
            SetFlags(entity, 0, -1, 0);  // Xadd1=0 confirmed
        
            // 🔥 6. UI + notify
            var rowguid = GetRowguid(entity);  // Generic helper
            ResetRowState(rowguid);
            SetLightBackground(rowguid, false);
            ResetEntityUIState<T>();
            await NotifyPendingChanges();
            Imessage = $"✅ {typeof(T).Name} confirmed";
        }
        else  // CANCEL (unchanged - perfect)
        {
            if (GetXadd1(entity) == -1) // New only
            {
                RemoveFromParentCollection(entity);
                Console.WriteLine($"🗑️ Removed new {typeof(T).Name}");
            }
            else
            {
                ClearDraft<T>();
            }

            var rowguid = GetRowguid(entity);
            ResetRowState(rowguid);
            ResetEntityUIState<T>();
            Imessage = "";
        }
        StateHasChanged();
    }
