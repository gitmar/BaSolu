<!-- InscTiewComponent.razor -->
<PageTitle>Table.Documents</PageTitle>

@if (isLoading)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" Size="SpinnerSize.Medium" />
        <p>Table.Documents Loading...</p>
    </div>
}
else
{
    <div class="d-flex flex-column">
        <div class="my-container">
            @if (toChild != null)
            {
                @ChildContent
            }
        </div>
    </div>
    <AuthorizeView>
        <Authorized Context="AuthContext">
            <div class="row">
                <div class="col-md-12 input-group align-middle">
                    <span><b>Message :</b></span>
                    &nbsp;&nbsp;
                    @if (!String.IsNullOrEmpty(Imessage))
                    {
                        <span class="bg-info bg-opacity-10" style="font-style:italic;color:red">&nbsp;--> @Imessage</span>
                    }
                </div>
            </div>
            <div class="form-group">
                <label class="fw-bold">Gpe document :</label>
                <InputSelect @bind-Value="ITyDoc" class="me-3" style="width:auto">
                    <option value=0>?gpdoc</option>
                    @foreach (var tob in LsDocs)
                    {
                        <option value=@tob.Key>@tob.Value</option>
                    }
                </InputSelect>
                @* <InputSelect @bind-Value="ITyDoc" class="me-3" style="width:auto" @onchange="OnDocChanged">
                    <option value=0>?gpdoc</option>
                    @foreach (var tob in LsDocs)
                    {
                        <option value=@tob.Key>@tob.Value</option>
                    }
                </InputSelect> *@
                @* <InputSelect @bind-Value="ITyDoc" class="me-3" style="width:auto">
                    <option class="jchx" value=0>?gpdoc</option>
                    @foreach (var tob in LsDocs) //LsFixes.Where(ut => ut.Gvars == 61 && ut.Itb == 1 & ut.Elea != 0))
                    {
                        <option value=@tob.Key @onclick="() => SelTypDoc(tob.Key)">@tob.Value</option>
                    }
                </InputSelect> *@
            </div>
            <div class="container-fluid-fixed-top">
                @if (curOrga == null)
                {
                    <p style="color:red;">Warning: curOrga is unexpectedly null.</p>
                }
                else
                {
                    <EditForm Context="invform" Model="@curOrga">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        <div class="row">
                            @if (!String.IsNullOrEmpty(Kmessage))
                            {
                                <span class="bg-info bg-opacity-10" style="font-style:italic;color:red">&nbsp;--> @Jmessage</span>
                            }
                        </div>
                        <div class="row">
                            @if (ITyDoc != 0)
                            {
                                <Grid TItem="GsgfixDto"
                                Data="@MyDaDocus"
                                @key="FixeRenderKey"
                                AllowDetailView="true"
                                AllowPaging="true"
                                RowClass="@((item) => GetPlnRowClass(item))"
                                Responsive="true">
                                    <GridColumns>
                                        <GridColumn TItem="GsgfixDto" HeaderText="No" Class="xcol1">
                                            <ChildContent Context="item">
                                                @if (item.Elea == 0)
                                                {
                                                    <span>?@item.Iui</span>
                                                }
                                                else
                                                {
                                                    @item.Elea
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="GsgfixDto" HeaderText="Designation" Class="xcol3">
                                            <ChildContent Context="item">
                                                @if (EdFixRowguid == item?.Rowguid)
                                                { // show draftPln inputs
                                                  <InputText @bind-Value="draftFix.Liba" />
                                                }
                                                else
                                                { // show item as read-only
                                                  @item?.Liba
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="GsgfixDto" HeaderText="Taille" class="xcol1" >
                                            <ChildContent Context="item">
                                                @if (EdFixRowguid == item?.Rowguid)
                                                { // show draftPln inputs
                                                  <InputNumber @bind-Value="draftFix.Ivala"
                                                               style="font-weight:bold; width:60px" />
                                                }
                                                else
                                                { // show item as read-only
                                                  @item?.Ivala
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="GsgfixDto" HeaderText="Methode" IsVisible="ITyDoc == 3" Class="xcol1">
                                            <ChildContent Context="item">
                                                <InputSelect @bind-Value="item.Ityp" disabled>
                                                    @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 33 && ut.Itb == 8 && ut.Gp1 == 1 && ut.Elea != 0))
                                                    {
                                                        <option value=@tob.Elea>@tob.Liba</option>
                                                    }
                                                </InputSelect>
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="GsgfixDto" HeaderText="Frequence" IsVisible="ITyDoc == 3" Class="xcol1">
                                            <ChildContent Context="item">
                                                <InputSelect @bind-Value="item.Jtyp" disabled>
                                                    @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 33 && ut.Itb == 8 && ut.Gp1 == 2 && ut.Elea != 0))
                                                    {
                                                        <option value=@tob.Elea>@tob.Liba</option>
                                                    }
                                                </InputSelect>
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="GsgfixDto" HeaderText="jeton" IsVisible="ITyDoc == 3" Class="xcol1">
                                            <ChildContent Context="item">
                                                <InputSelect @bind-Value="item.Ktyp" disabled>
                                                    <option value=0>sans</option>
                                                    <option value=1>oui</option>
                                                    <option value=2>non</option>
                                                </InputSelect>
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="GsgfixDto" HeaderText="Eta" Class="xcol1">
                                            <HeaderContent>
                                                @if (ITyDoc == 1 || ITyDoc == 2)
                                                {
                                                    <button class="btn btn-primary btn-sm @(isAddFix || isEdtFix ? "disabled-action" : "")"
                                                    @onclick="() => StartDocuNew(ITyDoc)">
                                                        <span style="display:inline-flex; align-items:center; gap:2px;">
                                                            <span>➕</span>
                                                            <span>Add</span>
                                                        </span>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span>Eta</span>
                                                }
                                            </HeaderContent>
                                            <ChildContent Context="item">
                                                @if (EdFixRowguid == item.Rowguid)
                                                {
                                                    <InputSelect @bind-Value="draftFix.Eta">
                                                        <option class="jchx" value=0>?choisir</option>
                                                        @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                        {
                                                            <option value=@tob.Elea>@tob.Liba</option>
                                                        }
                                                    </InputSelect>
                                                }
                                                else
                                                {
                                                    <InputSelect @bind-Value="item.Eta" disabled="true">
                                                        <option class="jchx" value=0>?choisir</option>
                                                        @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                        {
                                                            <option value=@tob.Elea>@tob.Liba</option>
                                                        }
                                                    </InputSelect>
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="GsgfixDto" HeaderText="Actions" Filterable="false" Class="xcol2 actions-col">
                                            <ChildContent Context="item">
                                                @switch (GetRowState(item.Rowguid))
                                                {
                                                    case RowState.Locked:
                                                        <span class="text-muted">—</span>
                                                        break;

                                                    case RowState.DeletePending:
                                                        <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                        @onclick="() => ConfirmDelete(item, EntityLevel.Plan)">
                                                            ⚠️ Confirm
                                                        </Button>
                                                        <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                        @onclick="() => CancelDelete(item, EntityLevel.Plan)">
                                                            ❎ Cancel
                                                        </Button>
                                                        break;
                                                    case RowState.EditPending:
                                                        @if (draftFix != null)
                                                        {
                                                            <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                            @onclick="() => ConfirmEdit(draftFix, EntityLevel.Plan)">
                                                                ✅ Confirm
                                                            </Button>
                                                            <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                            @onclick="() => CancelEdit(draftFix, EntityLevel.Plan)">
                                                                ❌ Cancel
                                                            </Button>
                                                        }
                                                        break;
                                                    default:
                                                        <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                                        @onclick="() => StartDocuEdit(item, item.Rowguid)">
                                                            ✏️ Edit
                                                        </Button>
                                                        @if (item.Eaut != 9)
                                                        {
                                                            <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                @onclick="() => StartRowDelete(item.Rowguid, EntityLevel.Plan)">
                                                                    🗑 Delete
                                                            </Button>
                                                        }
                                                        break;
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                    </GridColumns>
                                </Grid>
                            }
                        </div>
                    </EditForm>
                }
            </div>
        </Authorized>
    </AuthorizeView>
}
