                                                        <InputSelect @bind-Value="curOrga.Kpoint" disabled="@(!isEdOrg)" style="font-weight:bold">
                                                            <option value=0>integre</option>
                                                            <option value=1>flottant</option>
                                                        </InputSelect>
                                                    </td>
                                                </tr> 
                                                <tr>
                                                    <td>Si jeton:</td>
                                                    <td class="text-right">
                                                        <InputNumber class="my-input" @bind-Value="curOrga.Sijet" required
                                                                     style="font-weight:bold" readonly="@(isEdOrg ? null : "readonly")" />
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>No RCM:</td>
