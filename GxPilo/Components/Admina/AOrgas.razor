                            <Tab Title="Domaines">
                                <Content>
                                    <EditForm EditContext="edFixContext">
                                        <DataAnnotationsValidator />
                                    <div class="mb-3">
                                        <!-- Domaines grid -->
                                        <div class="row mt-2">
                                            <div class="form-group">
                                                <label style="font-weight:bold">Limites :</label>
                                                <InputSelect @bind-Value="Rubtto">
                                                    @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 39 && ut.Itb == 1 && ut.Elea < 3 && ut.Elea != 0))
                                                    {
                                                        <option value=@tob.Elea>@tob.Liba</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                        </div>
                                        @* @orgFixes.Where(utl => utl.Gvars == 21 && utl.Itb == Rubtto && utl.Elea != 0) *@
                                        <Grid TItem="GsgfixDto"
                                              Data="@MyDaDoms.Where(utl => utl.Itb == Rubtto)"
                                              Responsive="true">
                                            <GridColumns>
                                                <GridColumn TItem="GsgfixDto" HeaderText="No" Class="xcol1">
                                                    <ChildContent Context="item">@item.Elea</ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="GsgfixDto" HeaderText="Libelle" Class="xcol3">
                                                    <ChildContent Context="item">
                                                        @item.Liba
                                                        @if (Rubtto == 1)
                                                        {
                                                            <span>&nbsp;</span>
                                                            <span style="width:75px">
                                                                @if (item.Elea == 1)
                                                                {
                                                                    <span>(3..6)</span>
                                                                }
                                                                @if (item.Elea == 2)
                                                                {
                                                                    <span>(5..12)</span>
                                                                }
                                                                @if (item.Elea == 3)
                                                                {
                                                                    <span>(3..7)</span>
                                                                }
                                                                @if (item.Elea == 4)
                                                                {
                                                                    <span>(5..20)</span>
                                                                }
                                                                @if (item.Elea == 5)
                                                                {
                                                                    <span>(5..10)</span>
                                                                }
                                                                @if (item.Elea == 6)
                                                                {
                                                                    <span>(5..10)</span>
                                                                }
                                                                @if (item.Elea == 7)
                                                                {
                                                                    <span>(6..50)</span>
                                                                }
                                                                @if (item.Elea == 8)
                                                                {
                                                                    <span>(5..30)</span>
                                                                }
                                                            </span>
                                                        }
                                                    </ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="GsgfixDto" HeaderText="Valeur" Class="xcol1">
                                                    <ChildContent Context="item">
                                                        @if (item.Rowguid == EdDomRowguid)
                                                        {
                                                            <InputNumber class="my-input" @bind-Value="draftDom.Ivala"
                                                                style="font-weight:bold;width:50px" placeholder="annee" />
                                                        } 
                                                        else
                                                        {
                                                            <span style="font-weight:bold; width:100%">@item.Ivala</span>
                                                        }
                                                    </ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="GsgfixDto" HeaderText="Format" Class="xcol2">
                                                    <ChildContent Context="item">
                                                        @if (Rubtto == 1)
                                                        {
                                                            <span class="col-md-2">
                                                                @if (item.Elea != 1 && item.Elea != 2)
                                                                {
                                                                    <span>
                                                                        @if (item.Rowguid == EdDomRowguid)
                                                                        {
                                                                            <InputText class="my-input" @bind-Value="draftDom.Lgft"
                                                                                   style="font-weight:bold; width:100%" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <span style="font-weight:bold; width:100%">@item.Lgft</span>
                                                                        }
                                                                    </span>
                                                                }
                                                                @if (item.Elea == 1 && item.Elea == 2)
                                                                {
                                                                    <span>
                                                                        <div>.....</div>
                                                                    </span>
                                                                }
                                                            </span>
                                                        }
                                                    </ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="GsgfixDto" HeaderText="Actions" Class="xcol2">
                                                    <ChildContent Context="item">
                                                         <div class="col-md-2 d-flex gap-2">
                                                            @if (EdDomRowguid  != item.Rowguid)
                                                            {
                                                                <button class="btn btn-warning btn-sm @(!isEdingDom && EdDomRowguid != item.Rowguid ? "" : "disabled-action")" @onclick="() => StartDomEdit(item)">Edit</button>
                                                            }
                                                            else
                                                            {
                                                                <button class="btn btn-warning btn-sm @(EdDomRowguid  == item.Rowguid ? "" : "disabled-action")" @onclick="() => ConfGdom(draftDom)">Confirm</button>
                                                                <button class="btn btn-danger btn-sm @(EdDomRowguid  == item.Rowguid ? "" : "disabled-action")" @onclick="() => CancGdom(item)">Annul</button>
                                                            }
                                                        </div>
                                                    </ChildContent>
                                                </GridColumn>
                                            </GridColumns>
                                        </Grid>
                                        <!-- Filiation affilies -->
                                        <div class="row mt-3">
                                            <label style="font-weight:bold">Autres options (si auto):</label>
                                        </div>
                                        <div class="row">
                                            <label>Numerotation candidat :</label>
                                        </div>
                                        <div class="row">
                                            <label>Immatriculation :</label>
                                        </div>
                                        <DropdownDivider />
                                        <div class="row">
                                            <label>Numerotation article :</label>
                                        </div>
                                        <div class="row">
                                            <label>Nomenclature :</label>
                                        </div>
                                    </div>
                                    </EditForm>
                                </Content>
