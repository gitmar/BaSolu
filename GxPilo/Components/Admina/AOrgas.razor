    private async Task OnEntitySaved(EntityOgpe groupe, object entity)
    {
        switch (groupe)
        {
             case EntityOgpe.Org:
                {
                    var src = (GxorgaDto)entity;
                    var target = curOrga; //MyDaOrgs.FirstOrDefault(x => x.Rowguid == src.Rowguid);
                    if (target != null) CommitOrgDraft(target, src);
                    await InvokeAsync(StateHasChanged);
                    break;
                }
            case EntityOgpe.Gdom:
                {
                    var src = (GsgfixDto)entity;
                    var target = MyDaDoms.FirstOrDefault(x => x.Rowguid == src.Rowguid);
                    if (target != null) CommitDomDraft(target, src);
                    await InvokeAsync(StateHasChanged);
                    break;
                }
            case EntityOgpe.Gapt:
                {
                    var src = (GsgfixDto)entity;
                    var target = MyDaApts.FirstOrDefault(x => x.Rowguid == src.Rowguid);
                    if (target != null) CommitAptDraft(target, src);
                    await InvokeAsync(StateHasChanged);
                    break;
                }
            case EntityOgpe.Gafl:
                {
                    var src = (GsgfixDto)entity;
                    var target = MyDaAfls.FirstOrDefault(x => x.Rowguid == src.Rowguid);
                    if (target != null) CommitAflDraft(target, src);
                    await InvokeAsync(StateHasChanged);
                    break;
                }
        }
    }
