                                                        @* <InputSelect @bind-Value="curOrga.Jpoint" disabled="@(!isEdOrg)" style="font-weight:bold">
                                                            <option value=0>Noeud</option>
                                                            <option value=1>Libre</option>
                                                        </InputSelect> *@
                                                        <InputSelect @bind-Value="curOrga.Jpoint" disabled="@(!isEdOrg)" style="font-weight:bold">
                                                            <option value=0>?hierarch.</option>
                                                            @foreach (var pln in LsPlans.Where(p => p.Ptyp == 4 && p.Todom == 1).ToList())
