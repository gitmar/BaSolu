    public async Task StartFmtEdit(RubpstDto item)
    {
        var rowguid = item.Rowguid;
        if (item.Id == default)
        {
            Imessage = "🚫 Cannot edit new Fmt: Please save it first.";
            return;
        }

        if (rowguid == Guid.Empty) return;
        if (IsAnyRowEditing && !IsRowEditing(rowguid)) return;

        item.Xedt1 = -1;
        if (item.Iele != 0) item.Iui = (int)item.Iele;

        _edPstOriginals[rowguid] = DeepClone(item);
        draftFmt = DeepClone(item);

        FmtRenderKey = rowguid;
        BeginEdit(EntityLevel.Pst, rowguid, draftFmt);

        StateHasChanged();
    }
    private void StartCancelAdd(EntityLevel level, object entity)
    {
        var rowguid = MLEntityKeyHelper.GetRowguidAsGuid(entity);
        Console.WriteLine($"EST CANCELLED : {level}");
        switch (level)
        {
            case EntityLevel.Plan:
                CancelAdd(level, entity);
                curOrga.Plngens.RemoveAll(x => x.Rowguid == rowguid);
                //ResetRowState(level, rowguid);
                PlnRenderKey = Guid.Empty;
                break;
            case EntityLevel.Hie:
                CancelAdd(level, entity);
                curPlan.Rubhies.RemoveAll(x => x.Rowguid == rowguid);
                //ResetRowState(level, rowguid);
                RubRenderKey = Guid.Empty;
                break;
            case EntityLevel.Pst:
                CancelAdd(level, entity);
                curRubr.Rubpsts.RemoveAll(x => x.Rowguid == rowguid);
                //ResetRowState(level, rowguid);
                FmtRenderKey = Guid.Empty;
                break;
        }
    }

