@page "/ictposts"
@inherits CompUICrudBase
@namespace GxPilo.Components.Admina.Ictvars

@layout PrubMenu


@using System
@using GxShared.Helpers
@using GxShared.Sess
@using Simple.OData.Client
@using GxShared.GxDtos
@using GxShared.Interfaces
@using GxShared.Helpers.CrudHelpers
@using Microsoft.AspNetCore.Components.Forms

@using System.Text.RegularExpressions
@using System.Security.Claims
@using GxPilo.Components.Plans
@using GxPilo.Components.Admina.MRubs
@using GxPilo.Services
@using BlazorBootstrap
@using Blazored.LocalStorage
@using AutoMapper

@inject NavigationManager _navManager
@inject IJSRuntime _JsRUN
@inject IMessageService _messageService
<!-- InscTiewComponent.razor -->
<PageTitle>Saisie.Postes</PageTitle>

@if (isLoading)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" Size="SpinnerSize.Medium" />
        <p>Saisie.Postes Loading...</p>
    </div>
}
else
{
    <div class="d-flex flex-column">
        <div class="my-container">
            @if (toChild != null)
            {
                @ChildContent
            }
        </div>
    </div>
    <AuthorizeView>
        <Authorized Context="AuthContext">
            <div class="row">
                <div class="col-md-12 input-group align-middle">
                    <span><b>Message :</b></span>
                    &nbsp;&nbsp;
                    @if (!String.IsNullOrEmpty(Imessage))
                    {
                        <span class="bg-info bg-opacity-10" style="font-style:italic;color:red">&nbsp;--> @Imessage</span>
                    }
                </div>
            </div>
            <div class="form-group">
                <div class="btn btn-group">
                    <label class="fw-bold">Domaine :</label>
                    <InputSelect @bind-Value="IMyDom" @onclick="() => curPlanDom(IMyDom)" class="me-3" style="width:auto">
                        <option value=0>?domaine</option>
                        @foreach (var tob in LsDoms)
                        {
                            <option value=@tob.Gp2>@tob.Liba</option>
                        }
                    </InputSelect>
                    <label class="me-2">Modele :</label>
                    <InputSelect @bind-Value="IMyPlan" @onclick="() => curPlanPlan(IMyPlan)" class="me-3" style="width:auto">
                        <option value=0>?modele</option>
                        @foreach (var upl in LsPlans.Where(pl => pl.Todom == IMyDom).ToList())
                        {
                            <option value=@upl.Id>@upl.Liba</option>
                        }
                    </InputSelect>
                </div>
            </div>
            <div class="container-fluid-fixed-top">
                @if (curOrga == null)
                {
                    <p style="color:red;">Warning: curOrga is unexpectedly null.</p>
                }
                else
                {
                    <EditForm Context="invform" Model="@curOrga">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        <div class="row">
                            @if (!String.IsNullOrEmpty(Kmessage))
                            {
                                <span class="bg-info bg-opacity-10" style="font-style:italic;color:red">&nbsp;--> @Jmessage</span>
                            }
                        </div>
                        <div class="row">
                            @if (curPlan != null && IMyPlan != 0)
                            {
                                <div class="mt-2 border-start border-primary border-3 bg-light bg-opacity-25 rounded-end">
                                    <div class="row">
                                        <div class="col-12">
                                            <Grid TItem="RubhieDto"
                                                  Data="@MyDaHies"
                                                  AllowDetailView="true"
                                                  AllowRowClick="true"
                                                  OnRowClick="OnPstRowClick"
                                                  RowClass="@((item) => GetHieRowClass(item))"
                                                  Responsive="true">
                                                <GridColumns>
                                                    <GridColumn TItem="RubhieDto" HeaderText="No" Class="xcol1">
                                                        <ChildContent Context="item">
                                                            @if (item.Xadd1 == -1)
                                                            {
                                                                <span>?@item?.Iui</span>
                                                            }
                                                            else
                                                            {
                                                                <span>
                                                                    @(item.Xedt1 == -1 ? item?.Iui : (item?.Iui == 0 ? item?.Iele : item?.Iui))
                                                                </span>
                                                            }
                                                        </ChildContent>
                                                    </GridColumn>
                                                    <GridColumn TItem="RubhieDto" HeaderText="" Class="xcol1">
                                                        <!--
                                                                    <HeaderContent>
                                                                        Code
                                                                        if (!String.IsNullOrEmpty(Jmessage))
                                                                        {
                                                                            <span class="bg-info bg-opacity-10" style="font-style:italic;color:red">&nbsp; Jmessage</span>
                                                                        }
                                                                    </HeaderContent>
                                                                    -->
                                                        <ChildContent Context="item">
                                                            @item.Scdrub
                                                        </ChildContent>
                                                    </GridColumn>
                                                    <GridColumn TItem="RubhieDto" HeaderText="Designation" Class="xcol3">
                                                        <ChildContent Context="item">
                                                            @item.Liba
                                                        </ChildContent>
                                                    </GridColumn>
                                                    <GridColumn TItem="RubhieDto" HeaderText="Abrege" Class="xcol2">
                                                        <ChildContent Context="item">
                                                            @item.Abg
                                                        </ChildContent>
                                                    </GridColumn>
                                                    <GridColumn TItem="RubhieDto" HeaderText="Refer" Class="xcol1">
                                                        <ChildContent Context="item">
                                                            @item.Zcod
                                                        </ChildContent>
                                                    </GridColumn>
                                                    <GridColumn TItem="RubhieDto" HeaderText="Atyp">
                                                        <ChildContent Context="item">
                                                            <InputSelect @bind-Value="item.Atyp" class="col-md-1" style="width:auto" disabled>
                                                                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 2 && ut.Elea != 0))
                                                                {
                                                                    <option value=@tob.Elea>@tob.Liba</option>
                                                                }
                                                            </InputSelect>
                                                        </ChildContent>
                                                    </GridColumn>
                                                    <GridColumn TItem="RubhieDto" HeaderText="Formule" Class="xcol1">
                                                        <ChildContent Context="item">
                                                            <Button Color="ButtonColor.Secondary" Class="btn btn-default btn-sm d-inline-flex align-items-center gap-1"
                                                                    @onclick="() => showFrRubModal(item, 2)">
                                                                <i class="bi bi-pencil-square"></i>
                                                                <span class="text-truncate flex-grow-1">@item.Frsrc</span>
                                                            </Button>
                                                        </ChildContent>
                                                    </GridColumn>
                                                    <GridColumn TItem="RubhieDto" HeaderText="Eta">
                                                        <ChildContent Context="item">
                                                            <InputSelect @bind-Value="item.Eta" class="col-md-1" style="width:auto" disabled>
                                                                <option class="jchx" value=0>?etat</option>
                                                                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                                {
                                                                    <option value=@tob.Elea>@tob.Liba</option>
                                                                }
                                                            </InputSelect>
                                                        </ChildContent>
                                                    </GridColumn>
                                                    <GridColumn TItem="RubhieDto" HeaderText="Actions" Filterable="false" Class="xcol2 actions-col">
                                                        <HeaderContent>
                                                            @if (!isFiltre)
                                                            {
                                                                <button class="btn btn-info btn-sm" @onclick="ToggleRubFiltering">
                                                                    @(isRubFilteringEnabled ? "🚫 Out Filter" : "🔍 In Filter")
                                                                </button>
                                                            }
                                                        </HeaderContent>
                                                        <ChildContent Context="item">
                                                            @switch (GetRowState(EntityLevel.Hie, item.Rowguid))
                                                            {
                                                                case RowState.Locked:
                                                                    <span class="text-muted">—</span>
                                                                    break;
                                                                default:
                                                                    <Button Color="ButtonColor.Dark" Size="ButtonSize.Small"
                                                                            @onclick="() => ShowHieDetails(item, 2)">
                                                                        Details
                                                                    </Button>
                                                                    break;
                                                            }
                                                        </ChildContent>
                                                    </GridColumn>
                                                </GridColumns>
                                                <GridDetailView TItem="RubhieDto" Context="selectedRub">
                                                    @if (selectedRub != null)
                                                    {
                                                        <div class="mt-2 border-start border-primary border-3 bg-light bg-opacity-25 rounded-end">
                                                            <div class="row align-items-center mb-2">
                                                                <div class="col-auto">
                                                                    <i class="bi bi-chevron-right text-primary"></i>
                                                                </div>
                                                                <div class="col">
                                                                    <small class="text-muted fw-semibold">
                                                                        Rubrique ← @selectedRub.Liba (No: @selectedRub.Iele)
                                                                    </small>
                                                                </div>
                                                            </div>
                                                            <Grid TItem="RubpstDto"
                                                                  Data="@selectedRub.Rubpsts.ToList()"
                                                                  AllowPaging="true"
                                                                  RowClass="@((rf) => GetPstRowClass(rf))"
                                                                  Responsive="true">
                                                                <GridColumns>
                                                                    <GridColumn TItem="RubpstDto" HeaderText="No" Class="xcol1">
                                                                        <ChildContent Context="rf">
                                                                            @if (rf.Xadd1 == -1)
                                                                            {
                                                                                <span>?@rf?.Iui</span>
                                                                            }
                                                                            else
                                                                            {
                                                                                <span>
                                                                                    @(rf.Xedt1 == -1 ? rf?.Iui : (rf?.Iui == 0 ? rf?.Iele : rf?.Iui))
                                                                                </span>
                                                                            }
                                                                        </ChildContent>
                                                                    </GridColumn>
                                                                    <GridColumn TItem="RubpstDto" HeaderText="Adresse" Class="xcol1">
                                                                        <ChildContent Context="rf">
                                                                            @if (IsPstEditing(rf) && draftFmt is not null)
                                                                            {
                                                                                <InputText @bind-Value="rf.Padres"
                                                                                           @oninput="e => OnChlInput(e, rf)"
                                                                                           @onfocus="() => OnChlFocusHandler(selectedRub, rf)"
                                                                                           @onfocusout="() => OnChlBlurHandler(selectedRub, rf)"
                                                                                           class="@(string.IsNullOrEmpty(Jmessage) ? "" : "is-invalid")" />

                                                                                @if (!string.IsNullOrEmpty(Jmessage))
                                                                                {
                                                                                    <div class="text-danger small">@Jmessage</div>
                                                                                }
                                                                            }
                                                                            else
                                                                            {
                                                                                @rf.Padres
                                                                            }
                                                                        </ChildContent>
                                                                    </GridColumn>
                                                                    <GridColumn TItem="RubpstDto" HeaderText="Libelle" Class="xcol3">
                                                                        <ChildContent Context="rf">
                                                                            @if (IsPstEditing(rf) && draftFmt is not null)
                                                                            {
                                                                                <input @bind="draftFmt.Liba" />
                                                                            }
                                                                            else
                                                                            {
                                                                                @rf.Liba
                                                                            }
                                                                        </ChildContent>
                                                                    </GridColumn>
                                                                    <GridColumn TItem="RubpstDto" HeaderText="Abrege" Class="xcol1">
                                                                        <ChildContent Context="rf">
                                                                            @if (IsPstEditing(rf) && draftFmt is not null)
                                                                            {
                                                                                <input @bind="draftFmt.Abg" />
                                                                            }
                                                                            else
                                                                            {
                                                                                @rf.Abg
                                                                            }
                                                                        </ChildContent>
                                                                    </GridColumn>
                                                                    <GridColumn TItem="RubpstDto" HeaderText="Eta" Class="xcol1">
                                                                        <ChildContent Context="rf">
                                                                            @if (IsPstEditing(rf) && draftFmt is not null)
                                                                            { // show draftPln inputs
                                                                                <InputSelect @bind-Value="draftFmt.Eta" class="col-md-1" style="width:auto">
                                                                                    <option class="jchx" value=0>?etat</option>
                                                                                    @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 2 && ut.Elea != 0))
                                                                                    {
                                                                                        <option value=@tob.Elea>@tob.Liba</option>
                                                                                    }
                                                                                </InputSelect>
                                                                            }
                                                                            else
                                                                            { // show item as read-only
                                                                                <select @bind="rf.Eta" class="col-md-1" style="width:auto" disabled>
                                                                                    <option class="jchx" value=0>?etat</option>
                                                                                    @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                                                    {
                                                                                        <option value=@tob.Elea>@tob.Liba</option>
                                                                                    }
                                                                                </select>
                                                                            }
                                                                        </ChildContent>
                                                                    </GridColumn>
                                                                    <GridColumn TItem="RubpstDto" HeaderText="Actions" Class="xcol2 actions-col">
                                                                        <HeaderContent>
                                                                            <button class="btn btn-primary btn-sm @(IsLevelBusy(EntityLevel.Pst) ? "disabled-action" : "")"
                                                                                    disabled="@IsLevelBusy(EntityLevel.Pst)"
                                                                                    @onclick="() => StartFmtNew(selectedRub)">
                                                                                <span style="display:inline-flex; align-items:center; gap:4px;">
                                                                                    <span>➕</span>
                                                                                    <span>Add</span>
                                                                                </span>
                                                                            </button>
                                                                        </HeaderContent>
                                                                        <ChildContent Context="rf">
                                                                            @switch (GetRowState(EntityLevel.Pst, rf.Rowguid))
                                                                            {
                                                                                case RowState.Locked:
                                                                                    <span class="text-muted">—</span>
                                                                                    break;

                                                                                case RowState.AddPending:
                                                                                    <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                                            @onclick="() => ConfirmAdd(EntityLevel.Pst, draftFmt, true)">
                                                                                        ✅ Confirm
                                                                                    </Button>
                                                                                    <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                                            @onclick="() => StartCancelAdd(EntityLevel.Pst, draftFmt)">
                                                                                        ❌ Cancel
                                                                                    </Button>
                                                                                    break;
                                                                                case RowState.EditPending:
                                                                                    <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                                            @onclick="() => ConfirmEdit(EntityLevel.Pst, draftFmt, true)">
                                                                                        ✅ Confirm
                                                                                    </Button>
                                                                                    <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                                            @onclick="() => CancelEdit(EntityLevel.Pst, rf)">
                                                                                        ❌ Cancel
                                                                                    </Button>
                                                                                    break;
                                                                                case RowState.DeletePending:
                                                                                    <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                                            @onclick="() => ConfirmDelete(EntityLevel.Pst, rf, true)">
                                                                                        ⚠️ Confirm
                                                                                    </Button>
                                                                                    <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                                            @onclick="() => CancelDelete(EntityLevel.Pst, rf)">
                                                                                        ❎ Cancel
                                                                                    </Button>
                                                                                    break;
                                                                                default:
                                                                                    <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                                                                            @onclick="() => StartFmtEdit(rf)">
                                                                                        ✏️ Edit
                                                                                    </Button>
                                                                                    <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                                            @onclick="() => StartRowDelete(EntityLevel.Pst, rf.Rowguid)">
                                                                                        🗑 Delete
                                                                                    </Button>
                                                                                    break;
                                                                            }
                                                                        </ChildContent>
                                                                    </GridColumn>
                                                                </GridColumns>
                                                            </Grid>
                                                        </div>
                                                    }
                                                </GridDetailView>
                                            </Grid>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </EditForm>
                }
            </div>
            <!-- Modal for RUBHIE EDIT -->
            <Modal @ref="rHieModal" Size="ModalSize.Large" Title="Vue Division" ShowCloseButton="true">
                <BodyTemplate>
                    <div class="row">
                        <div class="table-responsive">
                            <table class="table w-auto" style="margin-left:10px">
                                <tbody>
                                    <tr>
                                        <td>Raison sociale:</td>
                                        <td class="text-right">
                                            <InputText class="my-input" @bind-Value="draftRub.Raison" required
                                                       style="font-weight:bold" />
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Sigle:</td>
                                        <td class="text-right">
                                            <InputText class="my-input" @bind-Value="draftRub.Sigle" required
                                                       style="font-weight:bold" />
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Nom Cible:</td>
                                        <td class="text-right">
                                            <InputText class="my-input" @bind-Value="draftRub.Stcible" required
                                                       style="font-weight:bold" />
                                        </td>
                                    </tr>
                                    @* <tr>
                                        <td>Poste Principal:</td>
                                        <td class="text-right">
                                            <InputSelect @bind-Value="draftRub.Kpst">
                                                <option value=0>choisir</option>
                                                @foreach (var udp in LsDivs.Where(dv => dv.Simain == 1))
                                                {
                                                    <option value=@udp.Ihie>@udp.Liba</option>
                                                }
                                            </InputSelect>
                                        </td>
                                    </tr> *@
                                    @* <tr>
                                        <td>Sigle:</td>
                                        <td class="text-right">
                                            <InputNumber class="my-input" @bind-Value="draftRub.Sigle" required
                                                         style="font-weight:bold" />
                                        </td>
                                    </tr> *@
                                    <tr>
                                        <td>Adresse:</td>
                                        <td class="text-right">
                                            <InputText class="my-input" @bind-Value="draftRub.Adr"
                                                       style="font-weight:bold" />
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Ville:</td>
                                        <td class="text-right">
                                            <InputNumber class="my-input" @bind-Value="draftRub.Icity"
                                                         style="font-weight:bold" />
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Province:</td>
                                        <td class="text-right">
                                            <InputNumber class="my-input" @bind-Value="draftRub.Iprovi"
                                                         style="font-weight:bold" />
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Region:</td>
                                        <td class="text-right">
                                            <InputNumber class="my-input" @bind-Value="draftRub.Iregio"
                                                         style="font-weight:bold" />
                                        </td>
                                    </tr>


                                </tbody>
                            </table>
                        </div>
                    </div>
                </BodyTemplate>
                <FooterTemplate>
                    <Button Color="ButtonColor.Secondary" @onclick="() => rHieModal.HideAsync()">Fermer</Button>
                </FooterTemplate>
            </Modal>
            <!-- Modal for FORMULE PLAN -->
            <Modal @ref="pForuModal" Size="ModalSize.Large" Title="Vue Plan Formula" ShowCloseButton="false">
                <BodyTemplate>
                    <div class="mb-3">
                        <label class="form-label">Formula</label>
                        <InputTextArea class="form-control"
                                       @bind-Value="curPlan.Fpsrc"
                                       rows="8"
                                       style="resize: vertical;" />
                    </div>
                </BodyTemplate>
                <FooterTemplate>
                    <Button Color="ButtonColor.Secondary" @onclick="() => pForuModal.HideAsync()">Fermer</Button>
                </FooterTemplate>
            </Modal>
            <!-- Modal for FORMULE RUB -->
            <Modal @ref="rForuModal" Size="ModalSize.Large" Title="Vue Rubrique Formula" ShowCloseButton=false>
                <BodyTemplate>
                    <div class="mb-3">
                        <label class="form-label">Formula</label>
                        <InputTextArea class="form-control"
                                       @bind-Value="curRubr.Frsrc"
                                       rows="6"
                                       style="resize: vertical;" />
                    </div>
                </BodyTemplate>
                <FooterTemplate>
                    <Button Color="ButtonColor.Secondary" @onclick="() => rForuModal.HideAsync()">Fermer</Button>
                </FooterTemplate>
            </Modal>
            <!-- Modal for FORMULE FMT -->
            @* <Modal @ref="gForuModal" Size="ModalSize.Large" Title="Edit Formula">
                <BodyTemplate>
                    <div class="mb-3">
                        <label class="form-label">Formula</label>
                        <InputTextArea class="form-control"
                                       @bind-Value="curFmat.Ftsrc"
                                       rows="3"
                                       style="resize: vertical;" />
                    </div>
                </BodyTemplate>
                <FooterTemplate>
                    <Button Color="ButtonColor.Secondary" @onclick="() => gForuModal.HideAsync()">Cancel</Button>
                </FooterTemplate>
            </Modal> *@
        </Authorized>
    </AuthorizeView>
}
<style>
    .modal-wide .modal-dialog {
        max-width: 50vw;
        width: auto;
        margin: auto;
    }

    .rubModal-wide .modal-dialog {
        max-width: 65vw;
        width: auto;
        margin: auto;
    }

    .disabled-action {
        pointer-events: none;
        opacity: 0.5;
    }

    .formul.button {
        pointer-events: none;
        opacity: 0.5;
        height: 160px;
    }

    .plnpoint {
        font-weight: bold;
        background-color: blue;
        color: white;
    }

    .rubpoint {
        font-weight: bold;
        background-color: yellow;
        color: black;
    }

    .fmtpoint {
        font-weight: bold;
        background-color: darkolivegreen;
        color: black;
    }

    .xcolx {
        width: 40px !important;
    }

    .xcol1 {
        width: 60px;
    }

    .xcol2 {
        width: 120px;
    }

    .xcol3 {
        width: 180px;
    }

    .xcol4 {
        width: 240px;
    }
        /* Ensure inputs inside these columns fill the width */
        .xcol1 input,
        .xcol2 input,
        .xcol3 input,
        .xcol4 input {
            width: 100%;
            box-sizing: border-box; /* prevents overflow due to padding/border */
        }

    .editing-row {
        pointer-events: none; /* Blocks all clicks on row */
    }

        .editing-row * {
            pointer-events: auto; /* Re-enables clicks on buttons/inputs */
        }

    .new-add-indicator::after {
        content: "➕ NEW";
        float: right;
        margin-left: 8px;
        background: #ffc107;
        color: #000;
        font-size: 0.65em;
        padding: 1px 4px;
        border-radius: 8px;
        font-weight: bold;
    }

    .readonly input,
    .readonly textarea,
    .readonly select,
    .readonly button {
        pointer-events: none;
        background-color: #f8f9fa; /* light gray to indicate disabled */
        opacity: 0.8;
    }
    /* Add to your CSS */
    .row-active-edit {
        background-color: #fff3cd !important; /* Light yellow */
        border-left: 5px solid #ffc107 !important; /* Thick yellow border */
        box-shadow: 0 2px 8px rgba(255,193,7,0.3);
        z-index: 10;
    }

    .row-readonly {
        opacity: 0.65 !important;
        background-color: #f8f9fa !important;
        cursor: not-allowed !important;
    }

        .row-readonly button,
        .row-readonly .btn {
            pointer-events: none !important;
            opacity: 0.4 !important;
        }

    /* Make the whole cell a flex container so buttons line up horizontally */
    .actions-col {
        display: flex;
        flex-direction: row;
        gap: 6px; /* spacing between buttons */
        align-items: center; /* vertical alignment */
        justify-content: flex-start;
    }
        /* Apply to all buttons in your grid (or globally if you prefer) */
        .actions-col .btn {
            display: inline-flex; /* flex container */
            flex-direction: row; /* horizontal layout */
            align-items: center; /* vertical centering */
            gap: 4px; /* spacing between emoji and text */
            white-space: nowrap; /* prevent wrapping onto two lines */
            line-height: 1.2; /* normalize baseline */
        }

</style>

@code {
    public bool isLoading = true;
    public string Imessage = "", Jmessage = "", Kmessage = "";
    public bool yaPgLink = false;
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }
    [Parameter]
    public RenderFragment ChildContent { get; set; }
    [Parameter]
    public GxorgaDto curOrga { get; set; } = new();
    [Parameter]
    public IODataClient _InODaClient { get; set; }
    [Parameter]
    public ChildVars toChild { get; set; }
    [Parameter]
    public int toMenu { get; set; }
    // Guard
    [Parameter]
    public IPendingChangesGuard _guard { get; set; }
    [Parameter]
    public EventCallback<PendingState> OnPendingStateChanged { get; set; }
    [Parameter]
