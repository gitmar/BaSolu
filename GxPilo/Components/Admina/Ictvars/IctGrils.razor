                                                                            disabled="@IsLevelBusy(EntityLevel.Fmt)"
                                                                            @onclick="() => StartFmtNew(curRubr)">
                                                                        <span style="display:inline-flex; align-items:center; gap:4px;">
                                                                            <span>➕</span>
                                                                            <span>Add</span>
                                                                        </span>
                                                                    </button>
                                                                </HeaderContent>
                                                                <ChildContent Context="rf">
                                                                    @switch (GetRowState(EntityLevel.Fmt, rf.Rowguid))
                                                                    {
                                                                        case RowState.Locked:
                                                                            <span class="text-muted">—</span>
                                                                            break;

                                                                        case RowState.AddPending:
                                                                            <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
