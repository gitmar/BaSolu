    public async Task StartFmtNew(RubvarDto myrub)
    {
        if (myrub.Id <= 0)
        {
            Imessage = "🚫 Cannot add Format: Rubrique must be saved first.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (IsAnyRowEditing)
        {
            Imessage = "fmt cannot be added when any row is editing";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var lsnb = NextSeq(MyDaFmts, p => p.Iui);
        var newFmt = new RubfmtDto
        {
            Rowguid = Guid.NewGuid(),
            Prowguid = myrub.Rowguid,
            Irub = myrub.Id,
            Iui = lsnb,
            Idzon = lsnb,
            Zcdrub = lsnb.ToString(),
            Ftsrc = "",
            Liba = "",
            Abg = "",
            Tperi = 1,
            Col = 1,
            Lne = 1,
            Ztyp = 4,
            Eint = 0,
            Eta = 1,
            Xadd1 = -1,
            Xedt1 = 0
        };

        FmtItems.Insert(0, newFmt);
        myrub.Rubfmts.Insert(0, newFmt);

        //SetRowState(EntityLevel.Fmt, newFmt.Rowguid, RowState.AddPending);

        draftFmt = DeepClone(newFmt);
        BeginAdd(EntityLevel.Fmt, newFmt.Rowguid, draftFmt);

        FmtRenderKey = newFmt.Rowguid;
        await InvokeAsync(StateHasChanged);
    }
    public async Task StartPlnEdit(PlngenDto item)
    {
        var rowguid = item.Rowguid;
        if (item.Id == default) return;
        if (rowguid == Guid.Empty) return;
        if (IsAnyRowEditing && !IsRowEditing(rowguid)) return;

        _edPlnOriginals[rowguid] = DeepClone(item);
        draftPln = DeepClone(item);

        BeginEdit(EntityLevel.Plan, rowguid, draftPln);
        _rowPendingOpTypeByRow[rowguid] = PendingOpType.Update;

        StateHasChanged();
    }
    public async Task StartRubEdit(RubvarDto item)
    {
        var rowguid = item.Rowguid;
        if (item.Id == default)
        {
            Imessage = "🚫 Cannot edit new Rubrique: Please save it first.";
            return;
        }

        if (rowguid == Guid.Empty) return;
        if (IsAnyRowEditing && !IsRowEditing(rowguid)) return;

        item.Xedt1 = -1;
        if (item.Iele != 0) item.Iui = (int)item.Iele;

        _edRubOriginals[rowguid] = DeepClone(item);
        draftRub = DeepClone(item);

        RubRenderKey = rowguid;
        BeginEdit(EntityLevel.Rub, rowguid, draftRub);

        StateHasChanged();
    }
