                                                                                    @onclick="() => ConfirmEdit(EntityLevel.Fmt, draftFmt, true)">
                                                                                ✅ Confirm
                                                                            </Button>
                                                                            <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                                    @onclick="() => CancelEdit(EntityLevel.Fmt, rf)">
                                                                                ❌ Cancel
                                                                            </Button>
                                                                            break;
                                                                        case RowState.DeletePending:
                                                                            <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                                    @onclick="() => ConfirmDelete(EntityLevel.Fmt, rf, true)">
                                                                                ⚠️ Confirm
                                                                            </Button>
                                                                            <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                                    @onclick="() => CancelDelete(EntityLevel.Fmt, rf)">
                                                                                ❎ Cancel
                                                                            </Button>
                                                                            break;
                                                                        default:
                                                                            <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                                                                    @onclick="() => StartFmtEdit(rf)">
                                                                                ✏️ Edit
                                                                            </Button>
                                                                            <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                                    @onclick="() => StartRowDelete(EntityLevel.Fmt, rf.Rowguid)">
                                                                                🗑 Delete
                                                                            </Button>
                                                                            break;
