            Col = 1,
            Lne = 1,
            Ztyp = 4,
            Eint = 0,
            Eta = 1,
            Xadd1 = -1,
            Xedt1 = 0
        };

        FmtItems.Insert(0, newFmt);
        myrub.Rubfmts.Insert(0, newFmt);

