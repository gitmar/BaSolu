@page "/prubsaie"
@inherits CompUICrudBase
@namespace GxPilo.Components.Admina.PRubs

@layout PrubMenu

@using System
@using GxShared.Helpers
@using GxShared.Helpers.CrudHelpers
@using GxShared.Sess
@using Simple.OData.Client
@using GxShared.GxDtos
@using GxShared.Interfaces
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.RegularExpressions
@using System.Security.Claims
@using GxPilo.Components.Uifrags
@using GxPilo.Services
@using BlazorBootstrap
@using Blazored.LocalStorage
@using AutoMapper
@using Microsoft.AspNetCore.Components.Forms

@inject NavigationManager _navManager
@inject IJSRuntime _JsRUN
@inject IMessageService _messageService

<!-- InscTiew Component.razor -->
<PageTitle>Prog.Saisie</PageTitle>

@if (isLoading)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" Size="SpinnerSize.Medium" />
        <p>Prog.Saisie Loading...</p>
    </div>
}
else
{
    <div class="d-flex flex-column">
        <div class="my-container">
            @if (toChild != null)
            {
                @ChildContent
            }
        </div>
    </div>
    <AuthorizeView>
        <Authorized Context="AuthContext">
            <div class="row">
                <div class="col-md-12 input-group align-middle">
                    <span><b>Message :</b></span>
                    &nbsp;&nbsp;
                    @if (!String.IsNullOrEmpty(Imessage))
                    {
                        <span class="bg-info bg-opacity-10" style="font-style:italic;color:red">&nbsp;--> @Imessage</span>
                    }
                </div>
            </div>
            <div class="form-group">
                <label class="fw-bold">Grpe Progr.:</label>
                    <InputSelect @bind-Value="IMyAtr" class="me-3" style="width:auto">
                        <option value=1>Complet</option>
                        <option value=2>Partiel</option>
                    </InputSelect>
                <label class="fw-bold">Base :</label>
                <InputSelect @bind-Value="IMyVue" class="me-3" style="width:auto">
                    <option value=0>?util</option>
                    @foreach (var tob in LsVues)
                    {
                        <option value=@tob.Elea>@tob.Liba</option>
                    }
                </InputSelect>
            </div>
            <div class="container-fluid-fixed-top">
                @if (curOrga == null)
                {
                    <p style="color:red;">Warning: curOrga is unexpectedly null.</p>
                }
                else
                {
                  <EditForm Context="invform" Model="@curOrga">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        <div class="row">
                            @if (!String.IsNullOrEmpty(Kmessage))
                            {
                                <span class="bg-info bg-opacity-10" style="font-style:italic;color:red">&nbsp;--> @Jmessage</span>
                            }
                        </div>
                        <div class="row">
                            @if (IMyDom != 0 && IMyVue != 0 && IMyAtr != 0)
                            {
                                <Grid TItem="PlngenDto"
                                      Data="@MyDaPlans"
                                      @key="PlnRenderKey"
                                      AllowDetailView="true"
                                      RowClass="@((item) => GetPlanRowClass(item))"
                                      Responsive="true">
                                    <GridColumns>
                                        <GridColumn TItem="PlngenDto" HeaderText="No" Class="xcol1">
                                            <ChildContent Context="item">
                                                    @if (item.Xadd1 == -1)
                                                    {
                                                        <span>@item?.Iui</span>
                                                    }
                                                    else
                                                    {
                                                    <span>@(item.Xedt1 == -1 ? item?.Iui : (item?.Iui == 0 ? item?.Iele : item?.Iui))</span>
                                                    }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="PlngenDto" HeaderText="Designation" Class="xcol3">
                                            <ChildContent Context="item">
                                                @if (IsPlanEditing(item) && draftPln is not null)
                                                {

                                                    <InputText @bind-Value="draftPln.Liba" />
                                                }
                                                else
                                                {
                                                    @item.Liba
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="PlngenDto" HeaderText="abrege" Class="xcol2">
                                            <ChildContent Context="item">
                                                @if (IsPlanEditing(item) && draftPln is not null)
                                                {

                                                    <InputText @bind-Value="draftPln.Abg" />
                                                }
                                                else
                                                {
                                                    @item.Abg
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="PlngenDto" HeaderText="Formule" Class="xcol1">
                                            <ChildContent Context="item">
                                                @if (IsPlanEditing(item) && draftPln is not null)
                                                { // show draftPln inputs
                                                      <Button Color="ButtonColor.Secondary" Class="btn btn-default btn-sm d-inline-flex align-items-center gap-1"
                                                              @onclick="() => showFrPlnModal(draftPln, 1)">
                                                          <i class="bi bi-pencil-square"></i>
                                                          <span class="text-truncate flex-grow-1">@draftPln?.Fpsrc</span>
                                                      </Button>
                                                }
                                                else
                                                { // show item as read-only
                                                      <Button Color="ButtonColor.Secondary" Class="btn btn-default btn-sm d-inline-flex align-items-center gap-1"
                                                              @onclick="() => showFrPlnModal(item, 2)">
                                                          <i class="bi bi-pencil-square"></i>
                                                          <span class="text-truncate flex-grow-1">@item.Fpsrc</span>
                                                      </Button>
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="PlngenDto" HeaderText="Eta" Class="xcol1">
                                            <HeaderContent>
                                                @if (IMyDom != 0 && IMyVue != 0)
                                                {
                                                    <button class="btn btn-primary btn-sm @(IsLevelBusy(EntityLevel.Plan) ? "disabled-action" : "")"
                                                            disabled="@IsLevelBusy(EntityLevel.Plan)"
                                                            @onclick="StartPlnNew">
                                                        <span style="display:inline-flex; align-items:center; gap:4px;">
                                                            <span>➕</span>
                                                            <span>Add</span>
                                                        </span>
                                                    </button>
                                                }
                                            </HeaderContent>
                                            <ChildContent Context="item">
                                                @if (IsPlanEditing(item) && draftPln is not null)
                                                {
                                                    <InputSelect @bind-Value="draftPln.Eta">
                                                        <option class="jchx" value=0>?choisir</option>
                                                        @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                        {
                                                            <option value=@tob.Elea>@tob.Liba</option>
                                                        }
                                                    </InputSelect>
                                                }
                                                else
                                                {
                                                    <InputSelect @bind-Value="item.Eta" disabled="true">
                                                        <option class="jchx" value=0>?choisir</option>
                                                        @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                        {
                                                            <option value=@tob.Elea>@tob.Liba</option>
                                                        }
                                                    </InputSelect>
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="PlngenDto" HeaderText="Actions" Filterable="false" Class="xcol2 actions-col">
                                            <ChildContent Context="item">
                                                @switch (GetRowState(EntityLevel.Plan, item.Rowguid))
                                                {
                                                    case RowState.Locked:
                                                        <span class="text-muted">—</span>
                                                        break;

                                                    case RowState.AddPending:
                                                        <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                @onclick="() => ConfirmAdd(EntityLevel.Plan, draftPln, true)">
                                                            ✅ Confirm
                                                        </Button>
                                                        <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                @onclick="() => StartCancelAdd(EntityLevel.Plan, draftPln)">
                                                            ❌ Cancel
                                                        </Button>
                                                        break;
                                                    case RowState.EditPending:
                                                        <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                @onclick="() => ConfirmEdit(EntityLevel.Plan, draftPln, true)">
                                                            ✅ Confirm
                                                        </Button>
                                                        <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                @onclick="() => CancelEdit(EntityLevel.Plan, item)">
                                                            ❌ Cancel
                                                        </Button>
                                                        break;
                                                    case RowState.DeletePending:
                                                        <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                @onclick="() => ConfirmDelete(EntityLevel.Plan, item, true)">
                                                            ⚠️ Confirm
                                                        </Button>
                                                        <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                @onclick="() => CancelDelete(EntityLevel.Plan, item)">
                                                            ❎ Cancel
                                                        </Button>
                                                        break;
                                                    default:
                                                        <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                                                @onclick="() => StartPlnEdit(item)">
                                                            ✏️ Edit
                                                        </Button>
                                                        <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                @onclick="() => StartRowDelete(EntityLevel.Plan, item.Rowguid)">
                                                            🗑 Delete
                                                        </Button>
                                                        break;
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                    </GridColumns>
                                    <GridDetailView TItem="PlngenDto" Context="selectedPln">
                                        @if (selectedPln is not null)
                                        {
                                            <div class="mt-2 border-start border-primary border-3 bg-light bg-opacity-25 rounded-end">
                                                <div class="row align-items-center mb-2">
                                                    <div class="col-auto">
                                                        <i class="bi bi-chevron-right text-primary"></i>
                                                    </div>
                                                    <div class="col">
                                                        <small class="text-muted fw-semibold">
                                                            Plan ← @selectedPln.Liba (No: @selectedPln.Iele)
                                                        </small>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-2">
                                                        <Button Color="ButtonColor.Secondary" Class="btn btn-default btn-sm" @onclick="() => showPgLink()">
                                                            Dpdce
                                                        </Button>
                                                    </div>
                                                    @if (yaPgLink)
                                                    {
                                                        <div class="col-3">
                                                            <label>Division</label>
                                                        </div>
                                                        <div class="col-3">
                                                            <label>Grille</label>
                                                        </div>
                                                        <div class="col-3">
                                                            <label>Echeancier</label>
                                                        </div>
                                                    }
                                                </div>
                                                <div class="row">
                                                    <div class="xcol2"></div>
                                                    @if (yaPgLink)
                                                    {
                                                        @if (draftPln?.Rowguid == selectedPln.Rowguid)
                                                        {
                                                            <div class="col-3">
                                                                <InputSelect @bind-Value="draftPln.Plsdiv"
                                                                             class="w-100">
                                                                    <option value=0>?choisir</option>
                                                                    @foreach (var tob in LsPlsDivs)
                                                                    {
                                                                        <option value=@tob.Id>@tob.Abg-@tob.Liba</option>
                                                                    }
                                                                </InputSelect>
                                                            </div>
                                                            <div class="col-3">
                                                                <InputSelect @bind-Value="draftPln.Plsgri" class="w-100">
                                                                    <option value=0>?choisir</option>
                                                                    @foreach (var tob in LsPlsGris)
                                                                    {
                                                                        <option value=@tob.Id>@tob.Abg-@tob.Liba</option>
                                                                    }
                                                                </InputSelect>
                                                            </div>
                                                            <div class="col-3">
                                                                <InputSelect @bind-Value="draftPln.Plsech" class="w-100">
                                                                    <option value=0>?choisir</option>
                                                                    @foreach (var tob in LsPlsEchs)
                                                                    {
                                                                        <option value=@tob.Id>@tob.Abg-@tob.Liba</option>
                                                                    }
                                                                </InputSelect>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="col-3">
                                                                <InputSelect @bind-Value="selectedPln.Plsdiv" disabled="true" class="w-100">
                                                                    <option value=0>?choisir</option>
                                                                    @foreach (var tob in LsPlsDivs)
                                                                    {
                                                                        <option value=@tob.Id>@tob.Abg-@tob.Liba</option>
                                                                    }
                                                                </InputSelect>
                                                            </div>
                                                            <div class="col-3">
                                                                <InputSelect @bind-Value="selectedPln.Plsgri" disabled="true" class="w-100">
                                                                    @foreach (var tob in LsPlsGris)
                                                                    {
                                                                        <option value=@tob.Id>@tob.Abg-@tob.Liba</option>
                                                                    }
                                                                </InputSelect>
                                                            </div>
                                                            <div class="col-3">
                                                                <InputSelect @bind-Value="selectedPln.Plsech" disabled="true" class="w-100">
                                                                    @foreach (var tob in LsPlsEchs)
                                                                    {
                                                                        <option value=@tob.Id>@tob.Abg-@tob.Liba</option>
                                                                    }
                                                                </InputSelect>
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                                <div class="row">
                                                    <div class="col-12">
                                                        <Grid TItem="RubvarDto"
                                                              Data="@selectedPln.Rubvars"
                                                              AllowDetailView="true"
                                                              RowClass="@((item) => GetRubRowClass(item))"
                                                              Responsive="true">
                                                            <GridColumns>
                                                                <GridColumn TItem="RubvarDto" HeaderText="No" Class="xcol1">
                                                                    <ChildContent Context="item">
                                                                        @if (item.Xadd1 == -1)
                                                                        {
                                                                            <span>?@item?.Iui</span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span>
                                                                                @(item.Xedt1 == -1 ? item?.Iui : (item?.Iui == 0 ? item?.Iele : item?.Iui))
                                                                            </span>
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="">
                                                                    <HeaderContent>
                                                                        Code
                                                                        @if (!String.IsNullOrEmpty(Jmessage))
                                                                        {
                                                                            <span class="bg-info bg-opacity-10" style="font-style:italic;color:red">&nbsp;--> @Jmessage</span>
                                                                        }
                                                                    </HeaderContent>
                                                                    <ChildContent Context="item">
                                                                        <div style="width:90px" class="rubpoint">
                                                                            @if (IsRubEditing(item) && draftRub is not null)
                                                                            {
                                                                                <InputText @bind-Value="draftRub.Scdrub"
                                                                                           placeholder="code"
                                                                                           class="w-100"
                                                                                           maxlength="@_lgcdu"
                                                                                           @onblur="@(() => OnChlBlurHandler(selectedPln, draftRub))"
                                                                                           @onfocus="@(() => OnChlFocusHandler(selectedPln, draftRub))"
                                                                                           pattern="@($"[0-9]{{{_lgcdu}}}")"
                                                                                           title="@($"{_lgcdu} chiffres obligatoires et unique")"
                                                                                           required />
                                                                            }
                                                                            else
                                                                            {
                                                                                @item.Scdrub
                                                                            }
                                                                        </div>
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Designation" Class="xcol3">
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item) && draftRub is not null)
                                                                            {
                                                                                <InputText @bind-Value="draftRub.Liba" />
                                                                            }
                                                                            else
                                                                            {
                                                                                @item.Liba
                                                                            }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Abrege" Class="xcol2">
                                                                    <ChildContent Context="item">
                                                                            @if (IsRubEditing(item) && draftRub is not null)
                                                                            {
                                                                                <InputText @bind-Value="draftRub.Abg" />
                                                                            }
                                                                            else
                                                                            {
                                                                                @item.Abg
                                                                            }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Refer" Class="xcol1">
                                                                    <ChildContent Context="item">
                                                                            @* @if (EdRubRowguid == item.Rowguid)
                                                                            { // show draftPln inputs
                                                                              <InputText @bind-Value="draftRub.Zcod" />
                                                                            }
                                                                            else
                                                                            { // show item as read-only
                                                                              @item.Zcod
                                                                            } *@
                                                                            @item.Zcod
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Atyp">
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item) && draftRub is not null)
                                                                        {
                                                                            <InputSelect @bind-Value="draftRub.Atyp" class="col-md-1" style="width:auto">
                                                                                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 2 && ut.Elea != 0))
                                                                                {
                                                                                    <option value=@tob.Elea>@tob.Liba</option>
                                                                                }
                                                                            </InputSelect>
                                                                        }
                                                                        else
                                                                        { // show item as read-only
                                                                          <InputSelect @bind-Value="item.Atyp" class="col-md-1" style="width:auto" disabled>
                                                                                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 2 && ut.Elea != 0))
                                                                                {
                                                                                    <option value=@tob.Elea>@tob.Liba</option>
                                                                                }
                                                                            </InputSelect>
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Formule" Class="xcol1">
                                                                    <ChildContent Context="item">
                                                                            @if (IsRubEditing(item) && draftRub is not null)
                                                                            { // show draftPln inputs
                                                                              <Button Color="ButtonColor.Secondary" Class="btn btn-default btn-sm d-inline-flex align-items-center gap-1"
                                                                                      @onclick="() => showFrRubModal(draftRub, 1)">
                                                                                  <i class="bi bi-pencil-square"></i>
                                                                                  <span class="text-truncate flex-grow-1">@draftRub?.Frsrc</span>
                                                                              </Button>
                                                                            }
                                                                            else
                                                                            { // show item as read-only
                                                                              <Button Color="ButtonColor.Secondary" Class="btn btn-default btn-sm d-inline-flex align-items-center gap-1"
                                                                                      @onclick="() => showFrRubModal(item, 2)">
                                                                                  <i class="bi bi-pencil-square"></i>
                                                                                  <span class="text-truncate flex-grow-1">@item.Frsrc</span>
                                                                              </Button>
                                                                            }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Eta">
                                                                    <HeaderContent>
                                                                        @if (selectedPln is not null)
                                                                        {
                                                                            <button class="btn btn-primary btn-sm @(IsLevelBusy(EntityLevel.Rub) ? "disabled-action" : "")"
                                                                                disabled="@IsLevelBusy(EntityLevel.Rub)"
                                                                                    @onclick="() => StartRubNew(selectedPln)">
                                                                                <span style="display:inline-flex; align-items:center; gap:4px;">
                                                                                    <span>➕</span>
                                                                                    <span>Add</span>
                                                                                </span>
                                                                            </button>
                                                                        }
                                                                    </HeaderContent>
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item) && draftRub is not null)
                                                                        { // show draftPln inputs
                                                                          <InputSelect @bind-Value="draftRub.Eta" class="col-md-1" style="width:auto">
                                                                              <option class="jchx" value=0>?etat</option>
                                                                                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                                                {
                                                                                    <option value=@tob.Elea>@tob.Liba</option>
                                                                                }
                                                                            </InputSelect>
                                                                        }
                                                                        else
                                                                        { // show item as read-only
                                                                          <InputSelect @bind-Value="item.Eta" class="col-md-1" style="width:auto" disabled>
                                                                              <option class="jchx" value=0>?etat</option>
                                                                                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                                                {
                                                                                    <option value=@tob.Elea>@tob.Liba</option>
                                                                                }
                                                                            </InputSelect>
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Actions" Filterable="false" Class="xcol2 actions-col">
                                                                    <HeaderContent>
                                                                        @if (!isFiltre)
                                                                        {
                                                                            <button class="btn btn-info btn-sm" @onclick="ToggleRubFiltering">
                                                                                @(isRubFilteringEnabled ? "🚫 Out Filter" : "🔍 In Filter")
                                                                            </button>
                                                                        }
                                                                    </HeaderContent>
                                                                    <ChildContent Context="item">
                                                                        @switch (GetRowState(EntityLevel.Rub, item.Rowguid))
                                                                        {
                                                                            case RowState.Locked:
                                                                                <span class="text-muted">—</span>
                                                                                break;

                                                                            case RowState.AddPending:
                                                                                <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                                        @onclick="() => ConfirmAdd(EntityLevel.Rub, draftRub, true)">
                                                                                    ✅ Confirm
                                                                                </Button>
                                                                                <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                                        @onclick="() => StartCancelAdd(EntityLevel.Rub, draftRub)">
                                                                                    ❌ Cancel
                                                                                </Button>
                                                                                break;
                                                                            case RowState.EditPending:
                                                                                <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                                        @onclick="() => ConfirmEdit(EntityLevel.Rub, draftRub, true)">
                                                                                    ✅ Confirm
                                                                                </Button>
                                                                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                                        @onclick="() => CancelEdit(EntityLevel.Rub, item)">
                                                                                    ❌ Cancel
                                                                                </Button>
                                                                                break;
                                                                            case RowState.DeletePending:
                                                                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                                        @onclick="() => ConfirmDelete(EntityLevel.Rub, item, true)">
                                                                                    ⚠️ Confirm
                                                                                </Button>
                                                                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                                        @onclick="() => CancelDelete(EntityLevel.Rub, item)">
                                                                                    ❎ Cancel
                                                                                </Button>
                                                                                break;
                                                                            default:
                                                                                <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                                                                        @onclick="() => StartRubEdit(item)">
                                                                                    ✏️ Edit
                                                                                </Button>
                                                                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                                        @onclick="() => StartRowDelete(EntityLevel.Rub, item.Rowguid)">
                                                                                    🗑 Delete
                                                                                </Button>
                                                                                break;
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                            </GridColumns>
                                                            <GridDetailView TItem="RubvarDto" Context="selectedRub">
                                                                @if (selectedRub is not null)
                                                                {
                                                                    <div class="mt-2 border-start border-primary border-3 bg-light bg-opacity-25 rounded-end">
                                                                        <div class="row align-items-center mb-2">
                                                                            <div class="col-auto">
                                                                                <i class="bi bi-chevron-right text-primary"></i>
                                                                            </div>
                                                                            <div class="col">
                                                                                <small class="text-muted fw-semibold">
                                                                                    Rubrique ← @selectedRub.Liba (No: @selectedRub.Iele)
                                                                                </small>
                                                                            </div>
                                                                        </div>
                                                                <Grid TItem="RubfmtDto"
                                                                      Data="@selectedRub.Rubfmts"
                                                                      AllowPaging="true"
                                                                      RowClass="@((rf) => GetFmtRowClass(rf))"
                                                                      Responsive="true">
                                                                    <GridColumns>
                                                                        <GridColumn TItem="RubfmtDto" HeaderText="Code" Class="xcol1">
                                                                            <ChildContent Context="rf">
                                                                                @if (rf.Xadd1 == -1)
                                                                                {
