@page "/ptestechs"
@inherits CompUICrudBase
@namespace GxPilo.Components.Admina.PRubs

@layout PrubMenu

@using System
@using GxShared.Helpers
@using GxShared.Sess
@using Simple.OData.Client
@using GxShared.GxDtos
@using GxShared.Interfaces
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.RegularExpressions
@using System.Security.Claims
@using GxPilo.Components.Plans
@using GxPilo.Services
@using Microsoft.AspNetCore.WebUtilities
@using Newtonsoft.Json

@if (isLoading) 
{
    <p>Loading...</p> 
}
else
{
    <p>@Imessage</p>
}
@if (isLoading)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" Size="SpinnerSize.Medium" />
        <p>Plan.Echeancier Loading...</p>
    </div>
}
else
{
    <div class="d-flex flex-column">
        <div class="my-container">
            @if (toChild != null)
            {
                @ChildContent
            }
        </div>
    </div>
    <AuthorizeView>
        <Authorized Context="AuthContext">
            <div class="row">
                <div class="col-md-12 input-group align-middle">
                    <span><b>Message :</b></span>
                    &nbsp;&nbsp;
                    @if (!String.IsNullOrEmpty(Imessage))
                    {
                        <span class="bg-info bg-opacity-10" style="font-style:italic;color:red">&nbsp;--> @Imessage</span>
                    }
                </div>
            </div>
            <div class="form-group">
                @* <label class="fw-bold">Domaine :</label>
                <InputSelect @bind-Value="ItkDom" class="me-3" style="width:auto">
                    <option value=0>?domaine</option>
                    @foreach (var tob in LsDoms)
                    {
                        <option value=@tob.Gp2>@tob.Liba</option>
                    }
                </InputSelect> *@

                <label class="fw-bold">G.Tiers :</label>
                <InputSelect @bind-Value="IMyGtie" @onchange="() => curPlanTier(IMyGtie)" class="me-3" style="width:auto">
                    <option value=0>?gtiers</option>
                    @foreach (var tob in LsGties)
                    {
                        <option value=@tob.Elea>@tob.Liba</option>
                    }
                </InputSelect>

                @* <label class="fw-bold">Base :</label>
                <InputSelect @bind-Value="IMyVue" class="me-3" style="width:auto">
                    <option value=0>?util</option>
                    @foreach (var tob in LsVues)
                    {
                        <option value=@tob.Gp2>@tob.Liba</option>
                    }
                </InputSelect> *@
            </div>
            <div class="container-fluid-fixed-top">
                @if (curOrga == null)
                {
                    <p style="color:red;">Warning: curOrga is unexpectedly null.</p>
                }
                else
                {
                    <EditForm Context="invform" Model="@curOrga">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        <div class="row">
                            @if (!String.IsNullOrEmpty(Kmessage))
                            {
                                <span class="bg-info bg-opacity-10" style="font-style:italic;color:red">&nbsp;--> @Jmessage</span>
                            }
                        </div>
                        <div class="row">
                            @if (IMyGtie != 0 && IMyAtr != 0)
                            {
                                <Grid TItem="PlngenDto"
                                      Data="@MyDaPlans"
                                      @key="PlnRenderKey"
                                      AllowDetailView="true"
                                      AllowPaging="true"
                                      RowClass="@((item) => GetPlanRowClass(item))"
                                      Responsive="true">
                                    <GridColumns>
                                        <GridColumn TItem="PlngenDto" HeaderText="No" Class="xcol1">
                                            <ChildContent Context="item">
                                                @if (item.Xadd1 == -1)
                                                {
                                                    <span>@item?.Iui</span>
                                                }
                                                else
                                                {
                                                    <span>@(item.Xedt1 == -1 ? item?.Iui : (item?.Iui == 0 ? item?.Iele : item?.Iui))</span>
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="PlngenDto" HeaderText="Designation" Class="xcol3">
                                            <ChildContent Context="item">
                                                @if (IsPlanEditing(item))
                                                {

                                                    <InputText @bind-Value="draftPln.Liba" />
                                                }
                                                else
                                                {
                                                    @item.Liba
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="PlngenDto" HeaderText="abrege" Class="xcol2">
                                            <ChildContent Context="item">
                                                @if (IsPlanEditing(item))
                                                {

                                                    <InputText @bind-Value="draftPln.Abg" />
                                                }
                                                else
                                                {
                                                    @item.Abg
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="PlngenDto" HeaderText="Eta" Class="xcol1">
                                            <HeaderContent>
                                                @if (IMyDom != 0 && IMyGtie != 0 && IMyVue != 0)
                                                {
                                                    <button class="btn btn-primary btn-sm @(IsLevelBusy(EntityLevel.Plan) ? "disabled-action" : "")"
                                                        disabled="@IsLevelBusy(EntityLevel.Plan)"
                                                            @onclick="StartPlnNew">
                                                        <span style="display:inline-flex; align-items:center; gap:4px;">
                                                            <span>➕</span>
                                                            <span>Add</span>
                                                        </span>
                                                    </button>
                                                }
                                            </HeaderContent>
                                            <ChildContent Context="item">
                                                @if (IsPlanEditing(item))
                                                {
                                                    <InputSelect @bind-Value="draftPln.Eta">
                                                        <option class="jchx" value=0>?choisir</option>
                                                        @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                        {
                                                            <option value=@tob.Elea>@tob.Liba</option>
                                                        }
                                                    </InputSelect>
                                                }
                                                else
                                                {
                                                    <InputSelect @bind-Value="item.Eta" disabled="true">
                                                        <option class="jchx" value=0>?choisir</option>
                                                        @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                        {
                                                            <option value=@tob.Elea>@tob.Liba</option>
                                                        }
                                                    </InputSelect>
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="PlngenDto" HeaderText="Actions" Filterable="false" Class="xcol2 actions-col">
                                            <ChildContent Context="item">
                                                @switch (GetRowState(EntityLevel.Plan, item.Rowguid))
                                                {
                                                    case RowState.Locked:
                                                        <span class="text-muted">—</span>
                                                        break;

                                                    case RowState.DeletePending:
                                                        <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                @onclick="() => ConfirmDelete(EntityLevel.Plan, item, true)">
                                                            ⚠️ Confirm
                                                        </Button>
                                                        <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                @onclick="() => CancelDelete(EntityLevel.Plan, item)">
                                                            ❎ Cancel
                                                        </Button>
                                                        break;
                                                    case RowState.AddPending:
                                                        <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                @onclick="() => ConfirmAdd(EntityLevel.Plan, draftPln, true)">
                                                            ✅ Confirm
                                                        </Button>
                                                        <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                @onclick="() => CancelAdd(EntityLevel.Plan, draftPln)">
                                                            ❌ Cancel
                                                        </Button>
                                                        break;
                                                    case RowState.EditPending:
                                                        <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                @onclick="() => ConfirmEdit(EntityLevel.Plan, draftPln, true)">
                                                            ✅ Confirm
                                                        </Button>
                                                        <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                @onclick="() => CancelEdit(EntityLevel.Plan, false)">
                                                            ❌ Cancel
                                                        </Button>
                                                        break;
                                                    default:
                                                        <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                                                @onclick="() => StartPlnEdit(item)">
                                                            ✏️ Edit
                                                        </Button>
                                                        <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                @onclick="() => StartRowDelete(EntityLevel.Plan, item.Rowguid)">
                                                            🗑 Delete
                                                        </Button>
                                                        break;
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                    </GridColumns>
                                    <GridDetailView TItem="PlngenDto" Context="selectedPln">
                                        @if (selectedPln != null)
                                        {
                                            <div class="mt-2 border-start border-primary border-3 bg-light bg-opacity-25 rounded-end">
                                                <div class="row align-items-center mb-2">
                                                    <div class="col-auto">
                                                        <i class="bi bi-chevron-right text-primary"></i>
                                                    </div>
                                                    <div class="col">
                                                        <small class="text-muted fw-semibold">
                                                            Plan ← @selectedPln.Liba (No: @selectedPln.Iele)
                                                        </small>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-12">
                                                        <Grid TItem="RubvarDto"
                                                              Data="@MyDaRubs"
                                                              @key="RubRenderKey"
                                                              AllowDetailView="true"
                                                              RowClass="@((item) => GetRubRowClass(item))"
                                                              Responsive="true">
                                                            <GridColumns>
                                                                <GridColumn TItem="RubvarDto" HeaderText="No" Class="xcol1">
                                                                    <ChildContent Context="item">
                                                                        @if (item.Xadd1 == -1)
                                                                        {
                                                                            <span>?@item?.Iui</span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span>
                                                                                @(item.Xedt1 == -1 ? item?.Iui : (item?.Iui == 0 ? item?.Iele : item?.Iui))
                                                                            </span>
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="">
                                                                    <HeaderContent>
                                                                        Code
                                                                        @if (!String.IsNullOrEmpty(Jmessage))
                                                                        {
                                                                            <span class="bg-info bg-opacity-10" style="font-style:italic;color:red">&nbsp;--> @Jmessage</span>
                                                                        }
                                                                    </HeaderContent>
                                                                    <ChildContent Context="item">
                                                                        <div style="width:90px" class="rubpoint">
                                                                            @if (IsRubEditing(item))
                                                                            {
                                                                                <InputText @bind-Value="draftRub.Scdrub"
                                                                                           placeholder="code"
                                                                                           id="rucode"
                                                                                           class="w-100"
                                                                                           maxlength="@_lgcdu"
                                                                                           @onblur="@(() => OnChlBlurHandler(selectedPln, draftRub))"
                                                                                           @onfocus="@(() => OnChlFocusHandler(selectedPln, draftRub))"
                                                                                           pattern="@($"[0-9]{{{_lgcdu}}}")"
                                                                                           title="@($"{_lgcdu} chiffres obligatoires et unique")"
                                                                                           required />
                                                                            }
                                                                            else
                                                                            {
                                                                                @item.Scdrub
                                                                            }
                                                                        </div>
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Designation" Class="xcol3">
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item))
                                                                        {
                                                                            <InputText @bind-Value="draftRub.Liba" />
                                                                        }
                                                                        else
                                                                        {
                                                                            @item.Liba
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Abrege" Class="xcol2">
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item))
                                                                        {
                                                                            <InputText @bind-Value="draftRub.Abg" />
                                                                        }
                                                                        else
                                                                        {
                                                                            @item.Abg
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Ajustmt" Class="xcol1">
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item))
                                                                        {
                                                                            <InputSelect @bind-Value="draftRub.Ajstyp">
                                                                                @foreach (var typ in LsFixes.Where(f => f.Gvars == 33 && f.Itb == 2).ToList())
                                                                                {
                                                                                    <option value="@typ.Elea">@typ.Liba</option>
                                                                                }
                                                                            </InputSelect>
                                                                        }
                                                                        else
                                                                        {
                                                                            <InputSelect @bind-Value="item.Ajstyp" disabled>
                                                                                @foreach (var typ in LsFixes.Where(f => f.Gvars == 33 && f.Itb == 2).ToList())
                                                                                {
                                                                                    <option value="@typ.Elea">@typ.Liba</option>
                                                                                }
                                                                            </InputSelect>
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Type" Class="xcol1">
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item))
                                                                        {
                                                                            <InputSelect @bind-Value="draftRub.Ectype">
                                                                                @foreach (var typ in LsFixes.Where(f => f.Gvars == 33 && f.Itb == 1).ToList())
                                                                                {
                                                                                    <option value="@typ.Elea">@typ.Liba</option>
                                                                                }
                                                                            </InputSelect>
                                                                        }
                                                                        else
                                                                        {
                                                                            <InputSelect @bind-Value="item.Ectype" disabled>
                                                                                @foreach (var typ in LsFixes.Where(f => f.Gvars == 33 && f.Itb == 1).ToList())
                                                                                {
                                                                                    <option value="@typ.Elea">@typ.Liba</option>
                                                                                }
                                                                            </InputSelect>
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Mode" Class="xcol1">
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item))
                                                                        {
                                                                            <InputSelect @bind-Value="draftRub.Ecmode">
                                                                                @foreach (var typ in LsFixes.Where(f => f.Gvars == 33 && f.Itb == 4).ToList())
                                                                                {
                                                                                    <option value="@typ.Elea">@typ.Liba</option>
                                                                                }
                                                                            </InputSelect>
                                                                        }
                                                                        else
                                                                        {
                                                                            <InputSelect @bind-Value="item.Ecmode" disabled>
                                                                                @foreach (var typ in LsFixes.Where(f => f.Gvars == 33 && f.Itb == 4).ToList())
                                                                                {
                                                                                    <option value="@typ.Elea">@typ.Liba</option>
                                                                                }
                                                                            </InputSelect>
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>

                                                                <GridColumn TItem="RubvarDto" HeaderText="Max Amount" Class="xcol1">
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item))
                                                                        {
                                                                            <InputNumber @bind-Value="draftRub.Ecmount" TValue="Decimal?" />
                                                                        }
                                                                        else
                                                                        {
                                                                            @item.Ecmount
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>

                                                                <GridColumn TItem="RubvarDto" HeaderText="Montt/Nbre" IsVisible="@inModM" Class="xcol1">
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item))
                                                                        {
                                                                            <InputNumber @bind-Value="draftRub.Ecannu" TValue="Decimal?" />
                                                                        }
                                                                        else
                                                                        {
                                                                            @item.Ecannu
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Nb.Ech." IsVisible="@outModM" Class="xcol1">
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item))
                                                                        {
                                                                            <InputNumber @bind-Value="draftRub.Nbech" />
                                                                        }
                                                                        else
                                                                        {
                                                                            @item.Nbech
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Formule" Class="xcol1">
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item))
                                                                        { // show draftPln inputs
                                                                            <Button Color="ButtonColor.Secondary" Class="btn btn-default btn-sm d-inline-flex align-items-center gap-1"
                                                                                    @onclick="() => showFrRubModal(draftRub, 1)">
                                                                                <i class="bi bi-pencil-square"></i>
                                                                                <span class="text-truncate flex-grow-1">@draftRub?.Frsrc</span>
                                                                            </Button>
                                                                        }
                                                                        else
                                                                        { // show item as read-only
                                                                            <Button Color="ButtonColor.Secondary" Class="btn btn-default btn-sm d-inline-flex align-items-center gap-1"
                                                                                    @onclick="() => showFrRubModal(item, 2)">
                                                                                <i class="bi bi-pencil-square"></i>
                                                                                <span class="text-truncate flex-grow-1">@item.Frsrc</span>
                                                                            </Button>
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Eta">
                                                                    <HeaderContent>
                                                                        @if (selectedPln != null)
                                                                        {
                                                                            <button class="btn btn-primary btn-sm @(IsLevelBusy(EntityLevel.Rub) ? "disabled-action" : "")"
                                                                                disabled="@IsLevelBusy(EntityLevel.Rub)"
                                                                                    @onclick="() => StartRubNew(selectedPln)">
                                                                                <span style="display:inline-flex; align-items:center; gap:4px;">
                                                                                    <span>➕</span>
                                                                                    <span>Add</span>
                                                                                </span>
                                                                            </button>
                                                                        }
                                                                    </HeaderContent>
                                                                    <ChildContent Context="item">
                                                                        @if (IsRubEditing(item))
                                                                        { // show draftPln inputs
                                                                            <InputSelect @bind-Value="draftRub.Eta" class="col-md-1" style="width:auto">
                                                                                <option class="jchx" value=0>?etat</option>
                                                                                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                                                {
                                                                                    <option value=@tob.Elea>@tob.Liba</option>
                                                                                }
                                                                            </InputSelect>
                                                                        }
                                                                        else
                                                                        { // show item as read-only
                                                                            <InputSelect @bind-Value="item.Eta" class="col-md-1" style="width:auto" disabled>
                                                                                <option class="jchx" value=0>?etat</option>
                                                                                @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                                                {
                                                                                    <option value=@tob.Elea>@tob.Liba</option>
                                                                                }
                                                                            </InputSelect>
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                                <GridColumn TItem="RubvarDto" HeaderText="Actions" Filterable="false" Class="xcol2 actions-col">
                                                                    <HeaderContent>
                                                                        @if (!isFiltre)
                                                                        {
                                                                            <button class="btn btn-info btn-sm" @onclick="ToggleRubFiltering">
                                                                                @(isRubFilteringEnabled ? "🚫 Out Filter" : "🔍 In Filter")
                                                                            </button>
                                                                        }
                                                                    </HeaderContent>
                                                                    <ChildContent Context="item">
                                                                        @switch (GetRowState(EntityLevel.Rub, item.Rowguid))
                                                                        {
                                                                            case RowState.Locked:
                                                                                <span class="text-muted">—</span>
                                                                                break;

                                                                            case RowState.DeletePending:
                                                                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                                        @onclick="() => ConfirmDelete(EntityLevel.Rub, item, true)">
                                                                                    ⚠️ Confirm
                                                                                </Button>
                                                                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                                        @onclick="() => CancelDelete(EntityLevel.Rub, item)">
                                                                                    ❎ Cancel
                                                                                </Button>
                                                                                break;
                                                                            case RowState.AddPending:
                                                                                <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                                        @onclick="() => ConfirmAdd(EntityLevel.Rub, draftRub, true)">
                                                                                    ✅ Confirm
                                                                                </Button>
                                                                                <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                                        @onclick="() => CancelAdd(EntityLevel.Rub, draftRub)">
                                                                                    ❌ Cancel
                                                                                </Button>
                                                                                break;
                                                                            case RowState.EditPending:
                                                                                <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                                        @onclick="() => ConfirmEdit(EntityLevel.Rub, draftRub, true)">
                                                                                    ✅ Confirm
                                                                                </Button>
                                                                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                                        @onclick="() => CancelEdit(EntityLevel.Rub, draftRub)">
                                                                                    ❌ Cancel
                                                                                </Button>
                                                                                break;
                                                                            default:
                                                                                <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                                                                        @onclick="() => StartRubEdit(item)">
                                                                                    ✏️ Edit
                                                                                </Button>
                                                                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                                        @onclick="() => StartRowDelete(EntityLevel.Rub, item.Rowguid)">
                                                                                    🗑 Delete
                                                                                </Button>
                                                                                break;
                                                                        }
                                                                    </ChildContent>
                                                                </GridColumn>
                                                            </GridColumns>
                                                        </Grid>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </GridDetailView>
                                </Grid>
                            }
                        </div>
                    </EditForm>
                }
            </div>
            <!-- Modal for FORMULE PLAN -->
            <Modal @ref="pForuModal" Size="ModalSize.Large" Title="Edit Formula" ShowCloseButton="false">
                <BodyTemplate>
                    <div class="mb-3">
                        <label class="form-label">Formula</label>
                        <InputTextArea class="form-control"
                                       @bind-Value="curPlan.Fpsrc"
                                       rows="8"
                                       style="resize: vertical;" />
                    </div>
                </BodyTemplate>
                <FooterTemplate>
                    <Button Color="ButtonColor.Secondary" @onclick="() => pForuModal.HideAsync()">Cancel</Button>
                </FooterTemplate>
            </Modal>
        </Authorized>
    </AuthorizeView>
}
<style>
    .modal-wide .modal-dialog {
        max-width: 50vw;
        width: auto;
        margin: auto;
    }

    .rubModal-wide .modal-dialog {
        max-width: 65vw;
        width: auto;
        margin: auto;
    }

    .disabled-action {
        pointer-events: none;
        opacity: 0.5;
    }

    .formul.button {
        pointer-events: none;
        opacity: 0.5;
        height: 160px;
    }

    .plnpoint {
        font-weight: bold;
        background-color: blue;
        color: white;
    }

    .rubpoint {
        font-weight: bold;
        background-color: yellow;
        color: black;
    }

    .fmtpoint {
        font-weight: bold;
        background-color: darkolivegreen;
        color: black;
    }

    .xcolx {
        width: 40px !important;
    }

    .xcol1 {
        width: 60px;
    }

    .xcol2 {
        width: 120px;
    }

    .xcol3 {
        width: 180px;
    }

    .xcol4 {
        width: 240px;
    }
        /* Ensure inputs inside these columns fill the width */
        .xcol1 input,
        .xcol2 input,
        .xcol3 input,
        .xcol4 input {
            width: 100%;
            box-sizing: border-box; /* prevents overflow due to padding/border */
        }

    .editing-row {
        pointer-events: none; /* Blocks all clicks on row */
    }

        .editing-row * {
            pointer-events: auto; /* Re-enables clicks on buttons/inputs */
        }

    .new-add-indicator::after {
        content: "➕ NEW";
        float: right;
        margin-left: 8px;
        background: #ffc107;
        color: #000;
        font-size: 0.65em;
        padding: 1px 4px;
        border-radius: 8px;
        font-weight: bold;
    }

    .readonly input,
