    //CRUD
    private async Task LoadOrgaAsync(int key)
    {
        try
        {
            // Query directly into DTO (recommended for Blazor WASM)
            curOrga = await _MyODaClient
                .For<GxorgaDto>("Gxorgas")
                .Key(key)
                .Expand(o => o.Plngens.Select(p => p.Rubvars))
                .Expand(o => o.Plngens.Select(p => p.Rubhies))
                .FindEntryAsync();

            if (curOrga == null)
                return;

            Console.WriteLine($"curorga : {curOrga.Raison}");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
    }
    
