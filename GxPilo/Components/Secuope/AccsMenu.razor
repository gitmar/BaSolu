                      <AJetons @ref=mygses
                                 ChxMenu="@chxMenu"
                                 curOrga="@curOrga"
                                 toChild="@toChild"
                                 curODContext="@curODContext">
                          <ChildContent>
                              <h2 class="child-box">Hello SESSIONS</h2>
                          </ChildContent>
                      </AJetons>
                    } else *@
                    @if (_chxMenu == 2)
                    { //SESSIONS
                      <ASessions @ref=mygses
                        ChxMenu="@_chxMenu"
                        curOrga="@curOrga"
                        toChild="@toChild">
                            <ChildContent>
                                <h2 class="child-box">Hello SESSIONS</h2>
                            </ChildContent>
                        </ASessions>
                    } else
                    @if (_chxMenu == 3)
                    { //EXERCICES
                        @*<ZZSAsesios ChxMenu="@chxMenu"
                                    curOrga="@curOrga"
                                    toChild="@toChild"
                                    curODContext="@curODContext">
                              <ChildContent>
                                  <h2 class="child-box">Hello RECEPTION</h2>
                              </ChildContent>
                          </ZZSAsesios>*@
                    } else
                    @if (_chxMenu == 4)
                    { //EXERCICES
                      @* <ASessions ChxMenu="@chxMenu"
                                curOrga="@curOrga"
                                toChild="@toChild"
                                curODContext="@curODContext">
                          <ChildContent>
                              <h2 class="child-box">Hello RECEPTION</h2>
                          </ChildContent>
                      </ASessions> *@
                    }
                 }
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-12">
                @if (_guard.HasPendingChanges())
                {
                    <div class="alert alert-warning">
                        <strong>@pendingCount changes pending across all tabs</strong>
                    </div>
                }
                <div class="d-flex gap-2 justify-content-end">
                    <Button Color="ButtonColor.Primary"
                            @onclick="SaveAllChanges"
                            Enabled="@_guard.HasPendingChanges()">
                        Save All (@pendingCount changes)
                    </Button>
                    <Button Color="ButtonColor.Secondary"
                            @onclick="CancelAllChanges">
                        Cancel All Changes
                    </Button>
                </div>
            </div>
        </div>
    </div>
}
