@page "/secumenu"
@inherits LayoutComponentBase
@layout FreeLayout

@using System.Security.Claims
@using System.Linq.Expressions
@using BlazorBootstrap
@using Blazored.LocalStorage
@using GxPilo.Components.Secuope
@using GxPilo.Services
@using GxPilo.StaticHelpers
@using GxShared.Helpers
@using GxShared.Sess
@using GxShared.Others
@using Simple.OData.Client
@using GxShared.GxDtos
@using GxShared.Interfaces
@using Newtonsoft.Json
@using Gx.Components
@using Gx.Components.Navigation

@inject NavigationManager _navManager
@inject ILocalStorageService _localStorage
@inject HttpClientService _clieManager
@inject IODataClient _MyODaClient
@inject SessionContextService _sessionContext
@inject MyAuthStateProvider _authProvider
@inject RendAgres _rendAgres
@inject IJSRuntime _JsRUN
@inject IPendingChangesGuard _guard
@inject IMessageService _messageService

@if (isLoading)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" Size="SpinnerSize.Large" />
        <p>SECURITES/Autorisations Loading...</p>
    </div>
}
@if (!isLoading)
{
    <div class="gx-screen-layout">
        <div class="container gx-parent-container" style="height: 100vh;">
            <div class="d-flex flex-column" style="height: 100%;">
                <!-- Top Menu -->
                <GxNavMenu BrandText="A24soft Gx-Solutions"
                           MenuItems="@MenuItems"
                           YaGroup="false"
                           Groups="@Groupes"
                           MenuSelected="@_chxMenu"
                           MenuSelectedChanged="@SelMenu"
                           GroupSelected="@_chxGpe"
                           GroupSelectedChanged="@SelGpe"
                           OnBack="@NavigateBack" />

                <div class="row">
                    <div class="col-md-12 input-group align-middle">
                        <span class="text-uppercase text- text-success"><b>@strComp</b></span>
                        <span class="separator">|| </span>
                    </div>
                </div>

                <!-- Main Content -->
                @if (curOrga != null && toChild != null)
                {
                    @if (_chxMenu == 1)
                    {
                        <Sessions @ref="mygses"
                                 curOrga="@curOrga"
                                 @bind-NbChanges="_nbChanges"
                                 _guard="@_guard"
                                 toChild="@toChild"
                                 _InODaClient="@_MyODaClient">
                            <ChildContent>
                                <h2 class="child-box">Hello TABLES</h2>
                            </ChildContent>
                        </Sessions>
                    }
                    else if (_chxMenu == 2)
                    {
                        <Authoris @ref="mygaut"
                                curOrga="@curOrga"
                                @bind-NbChanges="_nbChanges"
                                _guard="_guard"
                                toChild="@toChild"
                                authDivs="@authDivs"
                                _InODaClient="@_MyODaClient">
                            <ChildContent>
                                @* <h2 class="child-box">Hello ATTRIBUTS</h2> *@
                            </ChildContent>
                        </Authoris>
                    }
                    else if (_chxMenu == 3)
                    { //Jetons
                        <Jetons @ref="mygjet"
                                  curOrga="@curOrga"
                                  @bind-NbChanges="_nbChanges"
                                  _guard="_guard"
                                  toChild="@toChild"
                                  authDivs="@authDivs"
                                  _InODaClient="@_MyODaClient">
                            <ChildContent>
                                @* <h2 class="child-box">Hello ATTRIBUTS</h2> *@
                            </ChildContent>
                        </Jetons>
                    }
                    else if (_chxMenu == 4)
                    { //Exos
                        <Gexos @ref="mygexo"
                                curOrga="@curOrga"
                                @bind-NbChanges="_nbChanges"
                                _guard="_guard"
                                toChild="@toChild"
                                _InODaClient="@_MyODaClient">
                            <ChildContent>
                                @* <h2 class="child-box">Hello ATTRIBUTS</h2> *@
                            </ChildContent>
                        </Gexos>
                    }
                }
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-12">
                @if (_guard.HasPendingChanges())
                {
                    <div class="alert alert-warning">
                        <strong>@pendingCount changes pending across all tabs</strong>
                    </div>
                }
                <div class="d-flex gap-2 justify-content-end">
                    <Button Color="ButtonColor.Primary"
                            @onclick="SaveAllChanges"
                            Enabled="@_guard.HasPendingChanges()">
                        Save All (@pendingCount changes)
                    </Button>
                    <Button Color="ButtonColor.Secondary"
                            @onclick="CancelAllChanges">
                        Cancel All Changes
                    </Button>
                </div>
            </div>
        </div>
    </div>
}
<ErrorBoundary>
    <ErrorContent>
        An unexpected error occured. Please try again later.
    </ErrorContent>
</ErrorBoundary>

@code {

    private int selectedMenu = 1;

    private bool isLoading = true;
    public GxorgaDto curOrga = new GxorgaDto();
    public ChildVars toChild = new ChildVars();
    public RenderFragment ChildContent { get; set; }
    private string Jmessage = "";

    private Sessions mygses = new();
    private Authoris mygaut = new();
    private Jetons mygjet = new();
    private Gexos mygexo = new();

    //[CascadingParameter]
    //private Task<AuthenticationState>? AuthState { get; set; }
    private ClaimsPrincipal authUser;
    private bool isAuthenticated = false;
    //in DATA
    public List<GsgfixDto> LsTables = new();

    private string _strOrga = "", _curSigle = "", strmeta = "", strmeta2 = "";
    //private int _lgcdu = 0;
    //entities load
    private IEnumerable<GxorgaDto> _lsOrgas = new List<GxorgaDto>();

    //GlobModels
    public Userbag _usrBag = new Userbag();
    public List<Gpfixe> LsFixes = new();
    //public List<Upara> Uafls = new();
    public List<Gpdivh> LsDivs = new();
    public List<Gpdivh> authDivs = new();
    public List<Gpvar> LsVars = new();
    public List<Gplan> LsPlans = new();
    public List<Gpvar> LtTabls = new();
    public List<Gpvar> LsTabls = new();
    //Navigation
    private int _chxGpe = 0, _chxMenu = 1;
    private string strComp = "Sessions";

    //Guard
    private int _nbChanges = 0;
    private IDisposable? _locationHandler;
    private int pendingCount => _guard.GetPendingChangesCount();
    private int insertCount => _guard.GetInsertCount();
    private int updateCount => _guard.GetUpdateCount();
    private int deleteCount => _guard.GetDeleteCount();
    //Global CRUD
    private async Task CancelAllChanges()
    {
        Console.WriteLine("🗑️ CancelAllChanges START");
        await _guard.CancelChanges();  // 🔥 AWAIT - blocks until done
        _messageService.Show("✅ CancelAllChanges successfully", ToastType.Success);
        StateHasChanged();
        Console.WriteLine($"✅ CancelAllChanges END - Pending: {_guard.GetPendingChangesCount()}");
    }
    private async Task SaveAllChanges()
    {
        await _guard.FlushAsync();  // 🔥 AWAIT - blocks until done
        _messageService.Show("✅ Saved successfully", ToastType.Success);
        StateHasChanged();
    }
    //menus
    public List<GxMenuItem> MenuItems = new()
    {
        new GxMenuItem { Id = 1, Text = "Sessions", Icon = "bi bi-box-arrow-in-down" },
        new GxMenuItem { Id = 2, Text = "Autorisations", Icon = "bi bi-house-door" },
        new GxMenuItem { Id = 3, Text = "Jetons", Icon = "bi bi-arrow-repeat" },
        new GxMenuItem { Id = 4, Text = "Exercices", Icon = "bi bi-arrow-repeat" },
    };
    public List<GxGroupe> Groupes = new();

    //modal management
    private string SidebarStyle = "width: 200px;";
    private bool IsOpen = true;
    private bool FirstLoadCompleted = false;
    private bool ContentLoaded { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;

            // 1. CRITICAL: AUTH FIRST
            var authState = await _authProvider.GetAuthenticationStateAsync();
            isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
            if (!isAuthenticated)
            {
                _messageService.Show("❌ Utilisateur non authentifié", ToastType.Danger);
                return;  // STOP EXECUTION
            }

            // 2. Load user context
            _usrBag = await _sessionContext.GetUserbagAsync();
            if (_usrBag == null)
            {
                _messageService.Show("❌ Session utilisateur invalide", ToastType.Danger);
                return;
            }

            //_gIdTie = _usrBag.Usorga.Gdtie;
            LsFixes = _usrBag.Ufixes.ToList();
            LsVars = _usrBag.Usorga.Uvars.ToList();
            LsPlans = _usrBag.Usorga.Uplns.ToList();
            LtTabls = _usrBag.Usorga.Uvars.Where(tb => tb.Gvars == 4).ToList();
            LsTabls = _usrBag.Usorga.Uvars.Where(tb => tb.Gvars == 5).ToList();

            // 3. Parallel loads for performance
            //var allDivsTask = _rendAgres.LoadOrgaPostes();
            authDivs = await _rendAgres.LoadOrgaPostes();
            //var allDivs = await allDivsTask;
            LsDivs = authDivs.Where(ud => ud.Rpdom == 6 && ud.Rpatr == 1).ToList();

            await LoadOrgaAsync(_usrBag.Idorg);
            // 4. NOW pass to child (all data ready)
            toChild.authUser = authUser;
            toChild.isAuthenticated = true;
            toChild.LsDivs = LsDivs;
            toChild.LsVars = LsVars;
            toChild.LsFixes = LsFixes;
            toChild.LsPlans = LsPlans;
            toChild.LsTabls = LsTabls;
            toChild.curOrga = curOrga;  // ADD THIS!
            //_guard.RegisterUnconfirmedPredicate<Gsgfix>(g => g.Xadd1 == -1 || g.Xedt1 == -1 || g.Xdel1 == -1);
            _nbChanges = _guard.GetPendingChangesCount();  // Initial value
        }
        catch (Exception ex)
        {
            _messageService.Show($"❌ Erreur chargement: {ex.Message}", ToastType.Danger);
            Console.WriteLine($"Load error: {ex}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
    private async Task LoadOrgaAsync(int key)
    {
        try
        {
            curOrga = await _MyODaClient
                .For<GxorgaDto>("Gxorgas")
                .Key(key)
                .Expand(o => o.Gsauths)
                .FindEntryAsync();
            Console.WriteLine($"loadOrgaAsync completed :{curOrga?.Raison}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Load error: {ex.Message}");
        }
    }
    // Register guards and handlers ONCE when the component is initialized
    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
        if (firstRender)
        {
            _locationHandler = _navManager.RegisterLocationChangingHandler(OnLocationChangingAsync);
            _guard.OnChanges += StateHasChanged;
        }
    }
    private async ValueTask OnLocationChangingAsync(LocationChangingContext context)
    {
        Console.WriteLine($"🌐 Intercepted: {context.TargetLocation}");

        if (!_guard.HasPendingChanges())
        {
            Console.WriteLine("✅ Clean - allowing navigation");
            return;
        }

        context.PreventNavigation();  // BLOCK navigation
        Console.WriteLine($"🚫 Showing confirm dialog {context.TargetLocation}");

        try
        {
            var save = await _JsRUN.InvokeAsync<bool>("confirm", "Save changes before leaving?");

            if (save)
            {
                // 🔥 YES: SaveAllChanges() → Navigate away
                await SaveAllChanges();
                Console.WriteLine("💾 Saved - navigating away");
                _navManager.NavigateTo(context.TargetLocation, forceLoad: false);
            }
            else
            {
                // 🔥 NO: STAY on page - NO CancelAllChanges()
                Console.WriteLine("❌ User chose NO - staying on page");
                // User stays - sees SaveAllChanges() / CancelAllChanges() buttons ENABLED
                // They can now manually: SaveAllChanges() OR CancelAllChanges()
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error: {ex.Message}");
            // Safety: stay on page
        }
    }
    private async Task SelMenu(int noM)
    {
        _chxMenu = noM;
        if (_chxMenu == 1) strComp = $"Sessions";
        if (_chxMenu == 2) strComp = $"Autorisations";
        if (_chxMenu == 3) strComp = $"Jetons";
        if (_chxMenu == 4) strComp = $"Exercices";

        StateHasChanged();
        await Task.Delay(1);
    }
    private async Task SelGpe(int noG)
    {
        _chxGpe = noG;
        StateHasChanged();
        Console.WriteLine("PAS 2");
        await Task.Delay(1);
    }
    private async Task Save()
    {
        await _guard.FlushAsync();  // ✅ Parallel batch saves
    }
    void NavigateBack()
    {
        _navManager.NavigateTo("/");
    }
}
