@using Gx.Components.Navigation

@inject NavigationManager _navManager
@inject ILocalStorageService _localStorage
@inject HttpClientService _clieManager
@inject IODataClient _MyODaClient
@inject SessionContextService _sessionContext
@inject MyAuthStateProvider _authProvider
@inject RendAgres _rendAgres
@inject IJSRuntime _JsRUN
@inject IPendingChangesGuard _guard
@inject IMessageService _messageService

@if (isLoading)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" Size="SpinnerSize.Large" />
        <p>PARAMS/ATTRIB Loading...</p>
    </div>
}
@if (!isLoading)
{
    <div class="gx-screen-layout">
        <div class="container gx-parent-container" style="height: 100vh;">
            <div class="d-flex flex-column" style="height: 100%;">
                <!-- Top Menu -->
                <GxNavMenu BrandText="A24soft Gx-Solutions"
                           MenuItems="@MenuItems"
                           YaGroup="false"
                           Groups="@Groupes"
                           MenuSelected="@_chxMenu"
                           MenuSelectedChanged="@SelMenu"
                           GroupSelected="@_chxGpe"
                           GroupSelectedChanged="@SelGpe"
                           OnBack="@NavigateBack" />

                <div class="row">
                    <div class="col-md-12 input-group align-middle">
                        <span class="text-uppercase text- text-success"><b>@strComp</b></span>
                        <span class="separator">|| </span>
                    </div>
                </div>

                <!-- Main Content -->
                @if (curOrga != null && toChild != null)
                {
                    @if (_chxMenu == 1)
                    {
                        //attributs tiers
                        <AttribTie @ref="mytatr"
                        curOrga="@curOrga"
                        @bind-NbChanges="_nbChanges"
                        _guard="_guard"
                        EnsTbls="@EnsTbls"
                        Orig="1"
                        toChild="@toChild"
                                   _InODaClient="@_MyODaClient">
                            <ChildContent>
                                <h2 class="child-box">Hello ATTRIBUTS</h2>
                            </ChildContent>
                        </AttribTie>
                    }
                    else if (_chxMenu == 2)
                    { //attributs stock
                        <AttribStk @ref="mykatr"
                        curOrga="@curOrga"
                        @bind-NbChanges="_nbChanges"
                        _guard="_guard"
                        EnsTbls="@EnsTbls"
                        Orig="2"
                        toChild="@toChild"
                                   _InODaClient="@_MyODaClient">
                            <ChildContent>
                                <h2 class="child-box">Hello ATTRIBUTS</h2>
                            </ChildContent>
                        </AttribStk>
                    }
                    else if (_chxMenu == 3)
                    { //categories tiers
                        <CategTie @ref="mytcat"
                        curOrga="@curOrga"
                        @bind-NbChanges="_nbChanges"
                        _guard="_guard"
                        EnsTbls="@EnsTbls"
                        Orig="1"
                        toChild="@toChild"
                            _InODaClient="@_MyODaClient">
                            <ChildContent>
                                <h2 class="child-box">Hello ATTRIBUTS</h2>
                            </ChildContent>
                        </CategTie>
                    }
                    else if (_chxMenu == 4)
                    { //categories stock
                        <CategStk @ref="mykcat"
                        curOrga="@curOrga"
                        @bind-NbChanges="_nbChanges"
                        _guard="_guard"
                        EnsTbls="@EnsTbls"
                        Orig="2"
                        toChild="@toChild"
                           _InODaClient="@_MyODaClient">
                            <ChildContent>
                                <h2 class="child-box">Hello ATTRIBUTS</h2>
                            </ChildContent>
                        </CategStk>
                    }
                    else if (_chxMenu == 4)
                    { //nomenclature
                        <ItemsEntry @ref="mykent"
                            curOrga="@curOrga"
                            LsDivs="@LsDivs"
                            toMenu="@_chxMenu"
                            @bind-NbChanges="_nbChanges"
                            _guard="_guard"
                            EnsTbls="@EnsTbls"
                            _InODaClient="@_MyODaClient">
                        </ItemsEntry>
                    }
                }
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-12">
                <div class="d-flex gap-2 justify-content-end">
                    <Button Color="ButtonColor.Primary"
                            @onclick="SaveAllChanges"
                            Enabled="@_guard.HasPendingChanges()">
                        Save All (@pendingCount changes)
                    </Button>
                    <Button Color="ButtonColor.Secondary"
                            @onclick="CancelAllChanges">
                        Cancel All Changes
                    </Button>
                </div>
                @* <Gatribs @ref="mygatr"
                         curOrga="@curOrga"
                         @bind-NbChanges="_nbChanges"
                         _guard="_guard"
                         Orig="2"
                         toChild="@toChild"
                         _InODaClient="@ODataClient">
                    <ChildContent>
                        <h2 class="child-box">Hello ATTRIBUTS</h2>
                    </ChildContent>
                </Gatribs> *@
            </div>
        </div>
    </div>
}
<ErrorBoundary>
    <ErrorContent>
        An unexpected error occured. Please try again later.
    </ErrorContent>
</ErrorBoundary>
