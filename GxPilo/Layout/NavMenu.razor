                        </NavLink>

                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center flex-nowrap gap-2" href="astrmenu">
                            <i class="bi bi-calendar-check nav-icon"></i>
                            <span class="nav-text">Astreintes</span>
                        </NavLink>

                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center flex-nowrap gap-2" href="atribmenu">
