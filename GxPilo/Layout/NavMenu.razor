                    </span>
                </NavLink>

                <div class="submenu @(isSubProgVisible ? "open" : "")">
                    <nav class="nav flex-column">

                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center flex-nowrap gap-2" href="prubmenu">
                            <i class="bi bi-diagram-3 nav-icon"></i>
                            <span class="nav-text">Plans</span>
                        </NavLink>

                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center flex-nowrap gap-2" href="edtmenu">
                            <i class="bi bi-pencil-square nav-icon"></i>
                            <span class="nav-text">Écriture</span>
                        </NavLink>

                    </nav>
                </div>

                <!-- SECURITES -->
                <NavLink class="nav-link nav-main text-light small d-flex align-items-center flex-nowrap gap-2"
                         @onclick="ToggleSubSecu">

                    <i class="bi bi-shield-lock nav-icon"></i>

                    <span class="nav-text d-flex align-items-center flex-nowrap gap-1" style="min-width:0;">
                        Sécurités
                        <i class="bi @(isSubSecuVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron flex-shrink-0"></i>
                    </span>
                </NavLink>

                <div class="submenu @(isSubSecuVisible ? "open" : "")">
                    <nav class="nav flex-column">

                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center flex-nowrap gap-2" href="accsmenu">
                            <i class="bi bi-key nav-icon"></i>
                            <span class="nav-text">Autorisations</span>
                        </NavLink>

                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center flex-nowrap gap-2" href="donamenu">
                            <i class="bi bi-database nav-icon"></i>
                            <span class="nav-text">Données</span>
                        </NavLink>

                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center flex-nowrap gap-2" href="subitem2">
                            <i class="bi bi-tools nav-icon"></i>
                            <span class="nav-text">Outils</span>
                        </NavLink>

                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center flex-nowrap gap-2" href="ownerpage">
                            <i class="bi bi-person-badge nav-icon"></i>
                            <span class="nav-text">Owner Page</span>
                        </NavLink>

                    </nav>
                </div>
                <!-- SUPPORT -->
                <NavLink class="nav-link nav-main text-light small d-flex align-items-center flex-nowrap gap-2" href="about">
                    <i class="bi bi-life-preserver nav-icon"></i>
                    <span class="nav-text">Support</span>
                </NavLink>
                <!-- AGENDAS -->
                <NavLink class="nav-link nav-main text-light small d-flex align-items-center flex-nowrap gap-2" href="about">
                    <i class="bi bi-calendar3 nav-icon"></i>
                    <span class="nav-text">Agendas</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <!-- ABOUT -->
        <NavLink class="nav-link nav-main text-light small d-flex align-items-center flex-nowrap gap-2" href="about">
            <i class="bi bi-info-circle nav-icon"></i>
            <span class="nav-text">About</span>
        </NavLink>
    </nav>
</div>

<style>
    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        line-height: 1.2;
        flex-wrap: nowrap;
    }

    /* ICON COLUMN */
    .nav-icon {
        width: 22px;
        min-width: 22px;
        text-align: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    /* TEXT */
    .nav-text {
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* CHEVRON */
    .nav-chevron {
        font-size: 0.7rem;
        opacity: 0.7;
        flex-shrink: 0;
    }

    /* SUBMENU */
    .submenu {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.25s ease;
        margin-left: 10px;
        padding-left: 1rem;
        border-left: 1px solid rgba(255,255,255,0.1);
    }

        .submenu.open {
            max-height: 500px;
        }

    /* SUB ITEMS */
    .nav-sub {
        font-size: 0.85rem;
        opacity: 0.9;
    }
</style>
