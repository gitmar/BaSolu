                </NavLink>

                <div class="submenu @(isSubParaVisible ? "open" : "")">
                    <nav class="nav flex-column">

                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center flex-nowrap gap-2" href="atblmenu">
