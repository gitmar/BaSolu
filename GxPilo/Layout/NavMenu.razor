
@using GxPilo.Services
@using GxShared.Sess
@using BlazorBootstrap
@using Blazored.LocalStorage
@using System.Security.Claims
@using GxPilo.Components.Identity

@inject NavigationManager _navManager
@inject ILocalStorageService _localStorage

<div class="top-row navbar navbar-dark navbar-slim d-flex gap-1 shadow-sm
    m-0 p-0 justify-content-start align-items-start" style="min-height:32px; background: linear-gradient(180deg, rgb(5, 39, 103) 0%, #3a0647 70%);">

    <a class="navbar-brand text-white fw-bold m-0 p-1" href="">
        <i class="bi bi-gear-fill"></i>
        <span>Gx-Solutions</span>
    </a>
    <button class="navbar-toggler btn btn-sm ms-auto p-1 m-0"
            type="button"
            @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>

</div>

<div class="@NavMenuCssClass vh-100" style="overflow-y: auto;">
    <nav class="nav flex-column">
        <div class="text-md-center text-warning fw-bold">(PILOTAGE)</div>
        <!-- HOME -->
        <NavLink class="nav-link nav-main text-light text-small d-flex align-items-center gap-2" href="" Match="NavLinkMatch.All">
            <i class="bi bi-house-door-fill nav-icon d-inline-flex align-items-center"></i>
            <span class="nav-text" title="Home">Home</span>
        </NavLink>

        <AuthorizeView>
            <Authorized>
                <!-- TEST -->
                @* <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2" href="pages/register">
                    <i class="bi bi-building nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text" title="Test">Test</span>
                </NavLink> *@
                <!-- INSTITUTION -->
                <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2" href="aorgas">
                    <i class="bi bi-building nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text" title="Institution">Institution</span>
                </NavLink>

                <!-- PARAMÉTRAGE -->
                <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2"
                         @onclick="ToggleSubPara">
                    <i class="bi bi-sliders nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text">Paramétrage</span>
                    <i class="bi @(isSubParaVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                </NavLink>
                <div class="submenu @(isSubParaVisible ? "open" : "")">
                    <nav class="nav flex-column">
                        <NavLink class="nav-link nav-sub text-light text-small d-flex align-items-center gap-2" href="atblmenu">
                            <i class="bi bi-table nav-icon"></i>
                            <span class="nav-text">Constantes</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light text-small d-flex align-items-center gap-2" href="astrmenu">
                            <i class="bi bi-calendar-check nav-icon"></i>
                            <span class="nav-text">Astreintes</span>
                        </NavLink>
                        @* <NavLink class="nav-link nav-sub text-light text-small d-flex align-items-center gap-2" href="mrubmenu">
                            <i class="bi bi-calendar-check nav-icon"></i>
                            <span class="nav-text">Test Modeles</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light text-small d-flex align-items-center gap-2" href="orgacrudpage">
                            <i class="bi bi-calendar-check nav-icon"></i>
                            <span class="nav-text">Test Pages</span>
                        </NavLink> *@
                        <NavLink class="nav-link nav-sub text-light text-small d-flex align-items-center gap-2" href="atribmenu">
                            <i class="bi bi-tags nav-icon"></i>
                            <span class="nav-text">Attributs++</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light text-small d-flex align-items-center gap-2" href="invoper">
                            <i class="bi bi-people nav-icon"></i>
                            <span class="nav-text">Opérateurs</span>
                        </NavLink>
                    </nav>
                </div>

                <!-- PROGRAMMES -->
                <NavLink class="nav-link nav-main text-light text-small d-flex gap-2"
                         @onclick="ToggleSubProg">
                    <i class="bi bi-journal-code nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text">Programmes</span>
                    <i class="bi @(isSubProgVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                </NavLink>
                <div class="submenu @(isSubProgVisible ? "open" : "")">
                    <nav class="nav flex-column">
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="prubmenu">
                            <i class="bi bi-diagram-3 nav-icon"></i>
                            <span class="nav-text">Plans</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="edtmenu">
                            <i class="bi bi-pencil-square nav-icon"></i>
                            <span class="nav-text">Écriture</span>
                        </NavLink>
                    </nav>
                </div>

                <!-- SÉCURITÉS -->
                <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2"
                         @onclick="ToggleSubSecu">
                    <i class="bi bi-shield-lock nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text">Sécurités</span>
                    <i class="bi @(isSubSecuVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                </NavLink>
                <div class="submenu @(isSubSecuVisible ? "open" : "")">
                    <nav class="nav flex-column">
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="secumenu">
                            <i class="bi bi-key nav-icon"></i>
