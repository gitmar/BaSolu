                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="donamenu">
                            <i class="bi bi-database nav-icon"></i>
                            <span class="nav-text">Données</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="subitem2">
                            <i class="bi bi-tools nav-icon"></i>
                            <span class="nav-text">Outils</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="ownerpage">
                            <i class="bi bi-person-badge nav-icon"></i>
                            <span class="nav-text">Owner Page</span>
                        </NavLink>
                    </nav>
                </div>

                <!-- AGENDA -->
                @* <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2" href="agenda">
                    <i class="bi bi-calendar3 nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text">Agenda</span>
                </NavLink> *@

                <!-- SUPPORT DOMAINE -->
                @if (authUser.IsInRole("Support") || authUser.IsInRole("Owner") || authUser.IsInRole("Admin"))
                {
                    <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2"
                             @onclick="ToggleSubSupp">
                        <i class="bi bi-life-preserver nav-icon d-inline-flex align-items-center"></i>
                        <span class="nav-text">Support</span>
                        <i class="bi @(isSubSuppVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                    </NavLink>
                    <div class="submenu @(isSubSuppVisible ? "open" : "")">
                        <nav class="nav flex-column">
                            @if (authUser.IsInRole("Support"))
                            {
                                <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="support">
                                    <i class="bi bi-question-circle nav-icon"></i>
                                    <span class="nav-text">Aide?</span>
                                </NavLink>
                            }
                            <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="resendconfmail">
                                <i class="bi bi-envelope-check nav-icon"></i>
                                <span class="nav-text">Re-Confirm Email</span>
                            </NavLink>
                        </nav>
                    </div>
                }
            </Authorized>
        </AuthorizeView>
        <!-- ABOUT -->
        <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2" href="about">
            <i class="bi bi-info-circle nav-icon d-inline-flex align-items-center"></i>
            <span class="nav-text">About</span>
        </NavLink>
    </nav>
</div>

<style>

    /* ICON COLUMN */
    .nav-icon {
        width: 22px;
        min-width: 22px;
        text-align: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        flex-wrap: nowrap;
    }

    .nav-text {
        flex: 0 1 auto;
        min-width: 0;
        white-space: nowrap;
    }

    .nav-chevron {
        font-size: 0.9rem;
        color: #ffea00; /* bright yellow */
        flex-shrink: 0;
    }
    
    /* SUBMENU */
    .submenu {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.25s ease;
        margin-left: 10px;
        padding-left: 1rem;
        border-left: 1px solid rgba(255,255,255,0.1);
    }

        .submenu.open {
            max-height: 500px;
        }

    /* SUB ITEMS */
    .nav-sub {
        font-size: 0.85rem;
        opacity: 0.9;
    }

    /* Slim navbar: remove Bootstrap’s default horizontal padding */
    
    /* Slim navbar: remove Bootstrap’s default horizontal padding */
    .top-row.navbar {
        padding-left: 0;
        padding-right: 0;
    }

    /* Ensure menu container is flush left */
    .bg-dark.vh-100 {
        padding-left: 0;
        margin-left: 0;
    }

    .navbar {
        padding-left: 0 !important;
        padding-right: 0 !important;
    }

    .navbar-brand {
        margin-left: 0 !important;
        margin-right: 0 !important;
    }

</style>
@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }
    private ClaimsPrincipal authUser;

    private bool success, errors, isSubmitting = false;
    private string[] errorList = [];
    private bool collapseNavMenu = false;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private Userbag _usrBag = new();

    private bool isSubManagVisible = false;
    private bool isSubSecuVisible = false;
    private bool isSubOperVisible = false;
    private bool isSubParaVisible = false;
    private bool isSubProgVisible = false;
    private bool isSubSuppVisible = false;
    //private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        authUser = authState.User;
    }

    public void Dispose()
    {
        //_appState.OnChange -= StateHasChanged;
    }
    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void ToggleSubManag()
    {
        isSubManagVisible = !isSubManagVisible;
    }
    private void ToggleSubSecu()
    {
        isSubSecuVisible = !isSubSecuVisible;
    }
    private void ToggleSubOper()
    {
        isSubOperVisible = !isSubOperVisible;
    }

    //Admin
    private void ToggleSubPara()
    {
        isSubParaVisible = !isSubParaVisible;
    }

    private void ToggleSubProg()
    {
        isSubProgVisible = !isSubProgVisible;
    }
    //support
    private void ToggleSubSupp()
    {
        isSubSuppVisible = !isSubSuppVisible;
    }
    private bool Entest = false;

    // protected override async Task OnAfterRenderAsync(bool firstRender)
