                <!-- TRAITEMENTS -->
                <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2"
                         @onclick="ToggleSubOper">
                    <i class="bi bi-gear nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text">Traitements</span>
                    <i class="bi @(isSubOperVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                </NavLink>
                <div class="submenu @(isSubOperVisible ? "open" : "")">
                    <nav class="nav flex-column">
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="ptraitmenu">
                            <i class="bi bi-calendar-check nav-icon"></i>
