                    <span class="nav-text">Carrières</span>
                    <i class="bi @(isSubCarriVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                </NavLink>
                <div class="submenu @(isSubCarriVisible ? "open" : "")">
                    <nav class="nav flex-column">
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="pcarimenu">
