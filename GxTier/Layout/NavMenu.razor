                            <span class="nav-text" title="Affectations">Affectations</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="saieactlnes">
                            <i class="bi bi-award nav-icon"></i>
                            <span class="nav-text" title="Promotions">Promotions</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="saieactlnes">
                            <i class="bi bi-exclamation-triangle nav-icon"></i>
                            <span class="nav-text" title="Sanctions">Sanctions</span>
                        </NavLink>
