                    <i class="bi bi-sliders nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text">Paramétrage</span>
                    <i class="bi @(isSubParaVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                </NavLink>
                <div class="submenu @(isSubParaVisible ? "open" : "")">
                    <nav class="nav flex-column">
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="accsmenu">
                            <i class="bi bi-clock-history nav-icon"></i>
                            <span class="nav-text" title="Sessions">Sessions</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="offlinemanager">
