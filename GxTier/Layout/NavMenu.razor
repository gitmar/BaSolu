@using GxTie.Services
@using GxShared.Sess
@using System.Security.Claims
@using BlazorBootstrap

@inject NavigationManager _navManager

<div class="top-row navbar navbar-dark navbar-slim d-flex gap-1 shadow-sm
    m-0 p-0 justify-content-start align-items-start" style="min-height:32px; background: linear-gradient(180deg, rgb(5, 39, 103) 0%, #3a0647 70%);">

    <a class="navbar-brand text-white fw-bold m-0 p-1" href="">
        <i class="bi bi-gear-fill"></i>
        <span>Gx-Solutions</span>
    </a>
    <button class="navbar-toggler btn btn-sm ms-auto p-1 m-0"
            type="button"
            @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>

</div>

<div class="@NavMenuCssClass vh-100" style="overflow-y: auto;">
    <nav class="nav flex-column">
        <div class="text-md-center text-warning fw-bold">(PERSONNE)</div>
