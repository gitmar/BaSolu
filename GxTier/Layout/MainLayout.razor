@inherits LayoutComponentBase

@using System.Security.Claims
@using System.Text.RegularExpressions
@using Blazored.LocalStorage
@using GxTie.Services
@using GxShared.Helpers;
@using GxShared.Identity;

@inject IConfiguration _iconfig
@inject NavigationManager _navManager
@inject ILocalStorageService _localStorage
@inject SessionContextService _sessionContext
@inject ClieAppState _appState
@inject MyAuthStateProvider _authProvider
@inject IJSRuntime _JsRun

@if (_layoutReady)
{
    <div class="page-wrapper" style="display: flex; height: 100vh;">

        <!-- SIDEBAR -->
        <div class="sidebar"
             style="width: 250px; background: linear-gradient(180deg, rgb(5, 39, 103) 0%, #3a0647 70%);">
            <NavMenu />
        </div>

        <!-- MAIN -->
        <div class="main-content-wrapper d-flex flex-column" style="flex: 1; min-width: 0;">

            <!-- ================= TOP BAR ================= -->
            <div class="bg-light border-bottom">

                <div class="d-flex align-items-center px-3 py-2 flex-nowrap" style="min-width: 0;">

                    <!-- LEFT GROUP -->
                    <div class="d-flex align-items-center flex-nowrap gap-2" style="min-width: 0;">

                        @* <span class="fw-bold text-muted flex-shrink-0">(Personne)</span> *@

                        <AuthorizeView>
                            <Authorized>

                                <button class="btn btn-sm fw-bold text-dark m-0 p-0 flex-shrink-0"
                                        @onclick="NavigateToIdentityPage">
                                    PrivateRoom
                                </button>

                                <!-- ORGANIZATION BLOCK -->
                                <div class="d-flex align-items-center gap-2 flex-nowrap" style="min-width: 0;">

                                    <div class="truncated-text">
                                        @_appState.ogRaison
                                    </div>

                                    <div class="truncated-text text-muted">
                                        @_appState.usFulnom
                                    </div>

                                </div>

                            </Authorized>
                        </AuthorizeView>

                    </div>

                    <!-- RIGHT SIDE -->
                    <div class="ms-auto d-flex align-items-center gap-3 flex-shrink-0">

                        <label class="mb-0">Help ?</label>

                        <AuthorizeView>
                            <Authorized>
                                <a href="logout">
                                    <span class="bi bi-door-closed-fill" style="vertical-align:middle"></span>
                                    Logout
                                </a>
                            </Authorized>
                            <NotAuthorized>
                                <a href="login">
                                    <span class="bi bi-door-open" style="vertical-align:middle"></span>
                                    Login
                                </a>
                            </NotAuthorized>
                        </AuthorizeView>

                    </div>

                </div>

                <!-- USER MENU BELOW BAR -->
                <AuthorizeView>
                    <Authorized>
                        @if (collapseUserMenu)
                        {
                            @* <div class="px-3 py-2 border-top bg-white">
                                <UsrMenu />
                            </div> *@
                        }
                    </Authorized>
                </AuthorizeView>

            </div>
            <!-- ================= END TOP BAR ================= -->
            <!-- ================= MAIN CONTENT ================= -->
            <main class="flex-fill overflow-auto">
                <article class="content px-4">
                    @Body
                </article>
            </main>

        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <span>Loading session...</span>
    </div>
}
<style>
    /* CRITICAL: flex-safe truncation */
    .truncated-text {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 180px; /* adjust if needed */
        min-width: 0; /* REQUIRED for flex truncation */
        display: block;
    }

    /* safety for top bar flex */
    .page-wrapper,
    .main-content-wrapper {
        min-width: 0;
    }

    /* prevent unexpected wrapping in top bar */
    .flex-nowrap {
        flex-wrap: nowrap;
    }
</style>
@code {
    private bool _layoutReady = false, isLoading = false;
    private bool collapseUserMenu = false, canTierLog = false;
    //[CascadingParameter]
    //private Task<AuthenticationState>? AuthState { get; set; }
    private ClaimsPrincipal authUser;
    private bool isAuthenticated = false;
    //[Inject] private MyAuthStateProvider _authProvider { get; set; }

    // private void ToggleUserMenu()
    // {
    //     collapseUserMenu = !collapseUserMenu;
    // }

    protected override async Task OnInitializedAsync()
    {
        canTierLog = false;
        isLoading = false;
        //_layoutReady = true;
        var token = await _localStorage.GetItemAsync<string>("blazToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            Console.WriteLine("No token found — skipping session sync.");
            _layoutReady = true;
            return;
        }
        await _sessionContext.InitializeAsync();

        // Wait for AuthenticationStateProvider to reflect the new token
        //await Task.Delay(100); // Give NotifyUserAuthentication time to propagate
        var authState = await _authProvider.GetAuthenticationStateAsync();
        isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        authUser = authState.User;
        //var authState = await AuthState;
        //isAuthenticated = authUser.Identity?.IsAuthenticated ?? false;

        if (!isAuthenticated)
        {
            Console.WriteLine("Authentication in Main Layout ECHEC");
            await _authProvider.NotifyUserLogout();
        }
        else
        {
            //if (authUser.IsInRole("Support") || authUser.IsInRole("Admin")) canTierLog = true;
            
            Console.WriteLine("Authentication in Main Layout SUCCESS");
        }

        _layoutReady = true;
        _authProvider.AuthenticationStateChanged += async task =>
        {
            var authState = await task;
            authUser = authState.User;
            isAuthenticated = authUser.Identity?.IsAuthenticated ?? false;
            StateHasChanged();
        };

        isLoading = true;
    }
    private async Task NavigateToIdentityPage()
    {
        // Get token from localStorage
        var token = await _localStorage.GetItemAsync<string>("blazToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            Console.WriteLine("No token found — skipping session sync.");
            return;
        }
        var backendUrl = _iconfig["backendUrl"];
        var targetUrl = $"{backendUrl}/Identity/Account/JwtLandingPage?access_token={token}";
        _navManager.NavigateTo(targetUrl, forceLoad: true);
    }
    public void Dispose()
    {
        _appState.OnChange -= StateHasChanged;
    }
}
