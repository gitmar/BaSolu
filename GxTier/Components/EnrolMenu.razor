@if (isLoading)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" Size="SpinnerSize.Large" />
        <p>RH/ENROLLEMENT Loading...</p>
    </div>
}
else
{
    <div class="gx-screen-layout">
        <div class="container gx-parent-container" style="height: 100vh;">
            <div class="d-flex flex-column" style="height: 100%;">
                <GxNavMenu BrandText="A24soft Gx-Solutions"
                           MenuItems="@MenuItems"
                           YaGroup="true"
                           Groups="@Groupes"
                           MenuSelected="@_chxMenu"
                           MenuSelectedChanged="@SelMenu"
                           OnBack="@NavigateBack" />
                <div class="row">
                    <div class="col-md-12 input-group align-middle">
                        <span class="text-uppercase text- text-success"><b>@strComp</b></span>
                        @if (!String.IsNullOrEmpty(Jmessage))
                        {
                            <span class="bg-info bg-opacity-10" style="font-style:italic;color:red">&nbsp;--> @Jmessage</span>
                        }
                    </div>
                </div>
                <!-- Main Content -->
                <div class="row">
                    @if (_chxMenu != 0 && toChild.LsFixes.Any() && curOrga != null)
                    {
                        @if (_chxMenu == 1 && Ugpe != 0 && Tgpe != 0)
                        {
                            <ValdTie @ref="mygvld"
                                     Ugpe="@Ugpe"
                                     Tgpe="@Tgpe"
                                     curOrga="@curOrga"
                                     @bind-NbChanges="_nbChanges"
                                     _guard="_guard"
                                     EnsTbls ="@EnsTbls"
                                     toChild="@toChild"
                                     _InODaClient="@_MyODaClient">
                                <ChildContent>
                                    @* <h2 class="child-box">Hello INTEGRATION</h2> *@
                                </ChildContent>
                            </ValdTie>
                        }
                        else if (_chxMenu == 2 && Ugpe != 0) // && Tgpe != 0 && ParentOK)
                        {
                            <InscTiw @ref="myetiw"
                                     Ugpe="@Ugpe"
                                     Tgpe="@Tgpe"
                                     curOrga="@curOrga"
                                     @bind-NbChanges="_nbChanges"
                                     _guard="_guard"
                                     EnsTbls="@EnsTbls"
                                     toChild="@toChild"
                                     _InODaClient="@_MyODaClient">
                                <ChildContent>
                                    @* <h2 class="child-box">Hello ACCUEIL</h2> *@
                                </ChildContent>
                            </InscTiw>
                        }
                        else if (_chxMenu == 3)
                        {
                            @* <InvOper @ref="myginv"
                                     curOrga="@curOrga"
                                     allEnable="@allEnable"
                                     _InODaClient="@ODataClient">
                                <ChildContent>
                                    <h2 class="child-box">Hello ACCUEIL</h2>
                                </ChildContent>
                            </InvOper> *@
                        }
                    }
                 }
            </div>
        </div>
    </div>
</div>
    <div class="row mt-3">
        <div class="alert alert-warning d-flex justify-content-between align-items-center py-1 px-2 position-fixed bottom-0 end-0"
             style="background-color: transparent; z-index: 1050; max-width: 400px;">
            <div class="d-flex gap-2 align-items-center">
                <Button class="w-auto flex-grow-0 flex-shrink-0" Color="ButtonColor.Info" @onclick="SaveAllChanges"
                        Enabled="@_guard.HasPendingChanges()">
                    Save All (@_guard.GetPendingChangesCount() changes)
                </Button>
                <Button class="w-auto flex-grow-0 flex-shrink-0" Color="ButtonColor.Secondary" @onclick="CancelAllChanges"
                        Enabled="@_guard.HasPendingChanges()">
                    Cancel All
                </Button>
            </div>
        </div>

