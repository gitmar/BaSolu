    private async Task CancelAllChanges()
    {
        Console.WriteLine("🗑️ CancelAllChanges START");
        await _guard.CancelChanges();  // 🔥 AWAIT - blocks until done
        _messageService.Show("✅ CancelAllChanges successfully", ToastType.Success);
        StateHasChanged();
        Console.WriteLine($"✅ CancelAllChanges END - Pending: {_guard.GetPendingChangesCount()}");
    }
    private async Task SaveAllChanges()
    {
        await _guard.FlushAsync();  // 🔥 AWAIT - blocks until done
        _messageService.Show("✅ Saved successfully", ToastType.Success);
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            var authState = await AuthState;
            if (!authState.User.Identity.IsAuthenticated) return;
            // Load lightweight user data FIRST
            _usrBag = await _sessionContext.GetUserbagAsync();
            LsDivs = await _rendAgres.LoadOrgaPostes();
            EnsTbls = await _rendAgres.LoadOrgaTables();
            LsPlans = _usrBag.Usorga.Uplns.Where(pl => pl.Ptyp == 4).ToList();
            // Create shared OData context
            //curODContext = await _contextFactory.CreateAsync();
            //_guard.AttachContext(curODContext);

            _usrBag = await _sessionContext.GetUserbagAsync();

            // Groupe tiers
            LsGties = _usrBag.Ufixes
                .Where(ut => ut.Gvars == 36 && ut.Elea != 0 && ut.Elea != 9)
                .ToList();
            Groupes.Clear();
