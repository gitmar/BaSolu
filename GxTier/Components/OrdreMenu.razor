<!-- 🔽 STOCK SERVICES -->
@* @inject ItemClientService ItemService
@inject StockClientService StockService *@

@if (isLoading)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" Size="SpinnerSize.Large" />
        <p>Loading...</p>
    </div>
}
else
{
    <div class="gx-screen-layout">
        <div class="container gx-parent-container" style="height: 100vh;">
            <div class="d-flex flex-column" style="height: 100%;">

                <!-- Top Menu -->
                <GxNavMenu BrandText="A24soft Gx-Solutions"
                           MenuItems="@MenuItems"
                           YaGroup="false"
                           Groups="@Groupes"
                           MenuSelected="@_chxMenu"
                           MenuSelectedChanged="@SelMenu"
                           GroupSelected="@_chxGpe"
                           GroupSelectedChanged="@SelGpe"
                           OnBack="@NavigateBack" />

                <!-- Main Content -->
                @if (_chxMenu != 0 && curOrga != null)
                {
                    @* 🔽 STOCK PAGES *@
                    if (_chxMenu == 1)
                    {
                        <Ordres @ref="mygmut"
                                     curOrga="@curOrga"
                                     LsDivs="@LsDivs"
                                     LsPlans="@LsPlans"
                                     EnsTbls="@EnsTbls"
                                     toMenu="@_chxMenu"
                                     @bind-NbChanges="_nbChanges"
                                     _guard="_guard"
                                     _InODaClient="@_MyODaClient">
                        </Ordres>
                    }
                    else if (_chxMenu == 2)
                    {
                        @* <Ordreref @ref="myaref"
                                  curOrga="@curOrga"
                                  LsDivs="@LsDivs"
                                  LsPlans="@LsPlans"
                                  toMenu="@_chxMenu"
                                  @bind-NbChanges="_nbChanges"
                                  _guard="_guard"
                                  _InODaClient="@_MyODaClient">
                        </Ordreref> *@
                    }
                }
            </div>
            <div class="row mt-3">
                <div class="col-12">
                    @* @if (_guard.HasPendingChanges())
                    {
                        <div class="alert alert-warning">
                            <strong>@pendingCount changes pending across all tabs</strong>
                        </div>
                    } *@
                    <div class="d-flex gap-2 justify-content-end">
                        <Button Color="ButtonColor.Primary"
                                @onclick="SaveAllChanges"
                                Enabled="@_guard.HasPendingChanges()">
                            Save All (@pendingCount changes)
                        </Button>
                        <Button Color="ButtonColor.Secondary"
                                @onclick="CancelAllChanges">
                            Cancel All Changes
                        </Button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

