            Ugpe = 1; //initial Cible
            Console.WriteLine("Authentication ENTREE");
            await LoadCarriOrgaAsync(_usrBag.Idorg);

            _nbChanges = _guard.GetPendingChangesCount();  // Initial value
            Console.WriteLine($"Expanded results : {curOrga.Tiersps?.Count} and stkent {curOrga.Tiewels?.Count ?? 0}");
        }
        catch (Exception ex)
        {
