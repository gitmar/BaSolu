    // Column management (keep as-is)
    private Dictionary<int, List<Gptbl>> _cachedOptions = new();
    private List<Gptbl> GetOptions(int pxcod)
    {
        _cachedOptions ??= SelectOptions.ToDictionary(
            kvp => kvp.Key,
            kvp => kvp.Value.ToList()
        );

        return _cachedOptions.TryGetValue(pxcod, out var cached)
            ? cached
            : [];
    }
    protected override void OnParametersSet()
    {
        foreach (var item in TbItems.OfType<Gptbl>())
        {
            if (!_cachedOptions.ContainsKey(item.Pxcod))
                _cachedOptions[item.Pxcod] = new List<Gptbl>();
            _cachedOptions[item.Pxcod].Add(item);
        }
    }
