@using GxTie.ClieModels
@using GxShared.Others
@using GxWapi.DaModels

@if (draftAfl != null)
{
    <div class="card">
        <div class="card-body p-3">
            <!-- FIELD 3: Nom -->
            <FormField Label="Nom" IsVisible="@AflVisibility.GetValueOrDefault("Nom", true)">
                @if (isEditing)
                {
                    <InputText @bind-Value="draftAfl.Nom" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftAfl.Nom</span>
                }
            </FormField>
            <!-- FIELD 4: Pnom -->
            <FormField Label="Pnom" IsVisible="@AflVisibility.GetValueOrDefault("Pnom", true)">
                @if (isEditing)
                {
                    <InputText @bind-Value="draftAfl.Pnom" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftAfl.Pnom</span>
                }
            </FormField>
            <!-- FIELD 5: Nom de Jeune fille -->
            <FormField Label="Bnom" IsVisible="@AflVisibility.GetValueOrDefault("Bnom", true)">
                @if (isEditing)
                {
                    <InputText @bind-Value="draftAfl.Bnom" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftAfl.Bnom</span>
                }
            </FormField>
            <!-- FIELD 6: Statut (int) -->
            <FormField Label="Statut" IsVisible="@AflVisibility.GetValueOrDefault("Statut", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftAfl!.Statut"
                    isEditing="@isEditing"
                    Options="@GetOptions(11)"
                    GetOptionValue="@(t => t.Elea ?? 0)"
                    GetOptionLabel="@(t => t.Liba ?? "")" />
            </FormField>

            <!-- FIELD 7: Relat (int) -->
            <FormField Label="Relation" IsVisible="@AflVisibility.GetValueOrDefault("Relat", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftAfl!.Relat"
                    isEditing="@isEditing"
                    Options="@GetOptions(18)"
                    GetOptionValue="@(t => t.Elea ?? 0)"
                    GetOptionLabel="@(t => t.Liba ?? "")" />
            </FormField>
            <!-- FIELD 8: Sexe (int) -->
            <FormField Label="Sexe" IsVisible="@AflVisibility.GetValueOrDefault("Sexe", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftAfl!.Sexe"
                    isEditing="@isEditing"
                    Options="@GetOptions(12)"
                    GetOptionValue="@(t => t.Elea ?? 0)"
                    GetOptionLabel="@(t => t.Liba ?? "")" />
            </FormField>

            <!-- FIELD 9: Sitmat (int) -->
            
            <FormField Label="Sit.Mat." IsVisible="@AflVisibility.GetValueOrDefault("Sitmat", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftAfl!.Sitmat"
                    isEditing="@isEditing"
                    Options="@GetOptions(13)"
                    GetOptionValue="@(t => t.Elea ?? 0)"
                    GetOptionLabel="@(t => t.Liba ?? "")" />
            </FormField>

            <!-- FIELD 10: Fonction -->
            <FormField Label="Fonct." IsVisible="@AflVisibility.GetValueOrDefault("Ifonc", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftAfl!.Ifonc"
                    isEditing="@isEditing"
                    Options="@GetOptions(14)"
                    GetOptionValue="@(t => t.Elea ?? 0)"
                    GetOptionLabel="@(t => t.Liba ?? "")" />
            </FormField>

            <!-- FIELD 11: Grade -->
            <FormField Label="Grade" IsVisible="@AflVisibility.GetValueOrDefault("Igrad", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftAfl!.Igrad"
                    isEditing="@isEditing"
                    Options="@GetOptions(15)"
                    GetOptionValue="@(t => t.Elea ?? 0)"
                    GetOptionLabel="@(t => t.Liba ?? "")" />
            </FormField>
   
            <!-- FIELD 12: Email -->
            <FormField Label="Email" IsVisible="@AflVisibility.GetValueOrDefault("Email", true)">
                @if (isEditing)
                {
                    <InputText @bind-Value="draftAfl.Email" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftAfl.Email</span>
                }
            </FormField>

            <!-- FIELD 13: Phone -->
            <FormField Label="Phone" IsVisible="@AflVisibility.GetValueOrDefault("Phone", true)">
                @if (isEditing)
                {
                    <InputText @bind-Value="draftAfl.Phone" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftAfl.Phone</span>
                }
            </FormField>

            <!-- FIELD 14: Date de naissance -->
            <FormField Label="Date Naiss." IsVisible="@AflVisibility.GetValueOrDefault("Dnais", true)">
                @if (isEditing)
                {
                    <InputDate @bind-Value="draftAfl.Dnais" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftAfl.Dnais</span>
                }
            </FormField>
            
            
            <!-- FIELD 15: Date d’embauche -->
            <FormField Label="Date Emb." IsVisible="@AflVisibility.GetValueOrDefault("Demb", true)">
                @if (isEditing)
                {
                    <InputDate @bind-Value="draftAfl.Demb" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftAfl.Demb</span>
                }
            </FormField>

            <!-- FIELD 16: Nombre d’enfants -->
            <FormField Label="Nb.Enf" IsVisible="@AflVisibility.GetValueOrDefault("Nenf", true)">
                @if (isEditing)
                {
                    <InputNumber @bind-Value="draftAfl.Nenf" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftAfl.Nenf</span>
                }
            </FormField>

            <!-- FIELD 17: Responsabilité -->
            <FormField Label="Responsable" IsVisible="@AflVisibility.GetValueOrDefault("Respon", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftAfl!.Respon"
                    isEditing="@isEditing"
                    Options="@GetOptions(17)" 
                    GetOptionValue="@(t => t.Elea ?? 0)"
                    GetOptionLabel="@(t => t.Liba ?? "")" />
            </FormField>

            <!-- FIELD 18: Pays de résidence -->
            <FormField Label="Residence" IsVisible="@AflVisibility.GetValueOrDefault("Rpays", true)">
                <SelectedDisplay TValue="string"
                    @bind-Value="draftAfl!.Rpays"
                    isEditing="@isEditing"
                    Options="@GetOptions(31)"
                    GetOptionValue="@(t => t.Abg ?? "")"
                    GetOptionLabel="@(t => t.Liba ?? "")" />
            </FormField>
           
            <!-- FIELD 19: Nationalité -->
            <FormField Label="Natio" IsVisible="@AflVisibility.GetValueOrDefault("Natio", true)">
                <SelectedDisplay TValue="string"
                    @bind-Value="draftAfl!.Natio"
                    isEditing="@isEditing"
                    Options="@GetOptions(31)"
                    GetOptionValue="@(t => t.Abg ?? "")"
                    GetOptionLabel="@(t => t.Liba ?? "")" />
            </FormField>
  
            <!-- FIELD 20: Méthode de paiement -->
            <FormField Label="P.Meth" IsVisible="@AflVisibility.GetValueOrDefault("Ipaid", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftAfl!.Ipaid"
                    isEditing="@isEditing"
                    Options="@GetOptions(17)"
                    GetOptionValue="@(t => t.Elea ?? 0)"
                    GetOptionLabel="@(t => t.Liba ?? "")" />
            </FormField>
        </div>
    </div>
}
