    private List<Gptbl> GetOptions(int pxcod)
    {
        var result = new List<Gptbl>();
    
        try
        {
            if (TbItems is IEnumerable enumerable)
            {
                // ✅ FOREACH - bulletproof vs circular refs
                foreach (var item in enumerable)
                {
                    if (item is Gptbl gptbl && gptbl.Pxcod == pxcod)
                    {
                        result.Add(gptbl);
                    }
                }
            }
        }
        catch
        {
            // Silent fail - empty list
        }
    
        return result;
    }



    protected override void OnParametersSet()
    {
        // Compare references (fast)
        _tbItemsChanged = !ReferenceEquals(TbItems, _prevTbItems);
        
        _prevTbItems = TbItems;
        _prevDraftTiw = DraftTiw;
        _prevCurrentMainRecord = CurrentMainRecord;
    }
    
    protected override bool ShouldRender()
    {
        // Only render if data actually changed
        return _tbItemsChanged || 
               !ReferenceEquals(DraftTiw, _prevDraftTiw) ||
               !ReferenceEquals(CurrentMainRecord, _prevCurrentMainRecord);
    }

 
    // INT fields
    private int GetBindIntValue(Func<int> editValue, Func<int> displayValue) => 
        isEditing ? editValue() : displayValue();

    private async Task SetIntField(string fieldName, int value)
    {
        switch (fieldName)
        {
            case "Statut": if (isEditing) DraftTiw.Statut = value; else draftTiwStatut = value; break;
            case "Relat":  if (isEditing) DraftTiw.Relat = value; else draftTiwRelat = value; break;
            case "Sexe":   if (isEditing) DraftTiw.Sexe = value; else draftTiwSexe = value; break;
            case "Sitmat": if (isEditing) DraftTiw.Sitmat = value; else draftTiwSitmat = value; break;
            case "Ifonc":  if (isEditing) DraftTiw.Ifonc = value; else draftTiwIfonc = value; break;
            case "Igrad":  if (isEditing) DraftTiw.Igrad = value; else draftTiwIgrad = value; break;
            case "Respon":  if (isEditing) DraftTiw.Respon = value; else draftTiwRespon = value; break;
        }
        StateHasChanged();
    }

    // STRING fields
    private string GetBindStringValue(Func<string> editValue, Func<string> displayValue) => 
        isEditing ? editValue() : displayValue();

    private async Task SetStringField(string fieldName, string value)
    {
        switch (fieldName)
        {
            case "Rpays":
                if (isEditing) DraftTiw.Rpays = value; 
                else draftTiwRpays = value; 
                break;
            case "Natio":
                if (isEditing) DraftTiw.Rpays = value; 
                else draftTiwRpays = value; 
                break;
        }
        StateHasChanged();
    }

