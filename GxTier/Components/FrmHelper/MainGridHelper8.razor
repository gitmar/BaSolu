@using GxWapi.DaModels
@using GxTie.Components.FrmHelper
@using GxTie.StaticHelpers
@using GxShared.Others
@using System.Collections

@if (draftTiw != null)
{
    <div class="card">
        <div class="card-body p-3">
            <!-- FIELD 1: ID -->
            <div class="row mb-2">
                <label class="fw-bold col-1 col-form-label text-nowrap">ID:</label>
                <div class="col-11">
                    <div class="form-control-plaintext">@draftTiw.Id</div>
                </div>
            </div>
             
            <!-- FIELD 2: Dossier -->
            <FormField Label="Dossier" IsVisible="@Visibility.GetValueOrDefault("Dossier", true)">
                @if (isEditing)
                {
                    <InputText @bind-Value="draftTiw.Xmatri" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftTiw.Xmatri</span>
                }
            </FormField>

            <!-- FIELD 3: Nom -->
            <FormField Label="Nom" IsVisible="@Visibility.GetValueOrDefault("Nom", true)">
                @if (isEditing)
                {
                    <InputText @bind-Value="draftTiw.Nom" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftTiw.Nom</span>
                }
            </FormField>
            <!-- FIELD 4: Pnom -->
            <FormField Label="Pnom" IsVisible="@Visibility.GetValueOrDefault("Pnom", true)">
                @if (isEditing)
                {
                    <InputText @bind-Value="draftTiw.Pnom" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftTiw.Pnom</span>
                }
            </FormField>
            <!-- FIELD 5: Nom de Jeune fille -->
            <FormField Label="Bnom" IsVisible="@Visibility.GetValueOrDefault("Bnom", true)">
                @if (isEditing)
                {
                    <InputText @bind-Value="draftTiw.Bnom" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftTiw.Bnom</span>
                }
            </FormField>

            <!-- FIELD 6: Statut (int) -->
            <FormField Label="Statut" IsVisible="@Visibility.GetValueOrDefault("Statut", true)">
                <SelectedDisplay TValue="int?"
                                 @bind-Value="draftTiw!.Statut"
                                 isEditing="@isEditing"
                                 Options="@GetOptions(11)"
                                 GetOptionValue="StatutValue"
                                 GetOptionLabel="StatutLabel" />
            </FormField>


            @* <p>Options count: @GetOptions(11).Count</p>
            <FormField Label="Statut" IsVisible="@Visibility.GetValueOrDefault("Statut", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftTiw!.Statut"
                    isEditing="@isEditing"
                   Options="@GetOptions(11)"
                   GetOptionValue="@(t => t.Elea ?? 0)"
                   GetOptionLabel="@(t => t.Liba ?? "")" />
            </FormField> *@
            <!-- FIELD 7: Relat (int) -->
            <FormField Label="Relation" IsVisible="@Visibility.GetValueOrDefault("Relat", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftTiw!.Relat"
                    isEditing="@isEditing"
                   Options="@GetOptions(18)"
                   GetOptionValue="@(t => t.Elea ?? 0)"
                   GetOptionLabel="@(t => t.Liba ?? "")" />
            </FormField>
            <!-- FIELD 8: Sexe (int) -->
            <FormField Label="Sexe" IsVisible="@Visibility.GetValueOrDefault("Sexe", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftTiw!.Sexe"
                    isEditing="@isEditing"
                    Options="@GetOptions(12)"
                                 GetOptionValue="SexeValue"
                                 GetOptionLabel="SexeLabel" />
            </FormField>

            <!-- FIELD 9: Sitmat (int) -->
            
            <FormField Label="Sit.Mat." IsVisible="@Visibility.GetValueOrDefault("Sitmat", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftTiw!.Sitmat"
                    isEditing="@isEditing"
                    Options="@GetOptions(13)"
                                 GetOptionValue="SitmatValue"
                                 GetOptionLabel="SitmatLabel" />
            </FormField>

            <!-- FIELD 10: Fonction -->
            <FormField Label="Fonct." IsVisible="@Visibility.GetValueOrDefault("Ifonc", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftTiw!.Ifonc"
                    isEditing="@isEditing"
                    Options="@GetOptions(14)"
                                 GetOptionValue="IfoncValue"
                                 GetOptionLabel="IfoncLabel" />
            </FormField>

            <!-- FIELD 11: Grade -->
            <FormField Label="Grade" IsVisible="@Visibility.GetValueOrDefault("Igrad", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftTiw!.Igrad"
                    isEditing="@isEditing"
                    Options="@GetOptions(15)" 
                                 GetOptionValue="IgradValue"
                                 GetOptionLabel="IgradLabel" />
            </FormField>
   
            <!-- FIELD 12: Email -->
            <FormField Label="Email" IsVisible="@Visibility.GetValueOrDefault("Email", true)">
                @if (isEditing)
                {
                    <InputText @bind-Value="draftTiw.Email" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftTiw.Email</span>
                }
            </FormField>

            <!-- FIELD 13: Phone -->
            <FormField Label="Phone" IsVisible="@Visibility.GetValueOrDefault("Phone", true)">
                @if (isEditing)
                {
                    <InputText @bind-Value="draftTiw.Phone" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftTiw.Phone</span>
                }
            </FormField>

            <!-- FIELD 14: Date de naissance -->
            <FormField Label="Date Naiss." IsVisible="@Visibility.GetValueOrDefault("Dnais", true)">
                @if (isEditing)
                {
                    <InputDate @bind-Value="draftTiw.Dnais" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftTiw.Dnais</span>
                }
            </FormField>
            
            
            <!-- FIELD 15: Date d’embauche -->
            <FormField Label="Date Emb." IsVisible="@Visibility.GetValueOrDefault("Demb", true)">
                @if (isEditing)
                {
                    <InputDate @bind-Value="draftTiw.Demb" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftTiw.Demb</span>
                }
            </FormField>

            <!-- FIELD 16: Nombre d’enfants -->
            <FormField Label="Nb.Enf" IsVisible="@Visibility.GetValueOrDefault("Nenf", true)">
                @if (isEditing)
                {
                    <InputNumber @bind-Value="draftTiw.Nenf" class="form-control" />
                }
                else
                {
                    <span class="form-control-plaintext">@draftTiw.Nenf</span>
                }
            </FormField>

            <!-- FIELD 17: Responsabilité -->
            <FormField Label="Responsable" IsVisible="@Visibility.GetValueOrDefault("Respon", true)">
                <SelectedDisplay TValue="int?" 
                    @bind-Value="draftTiw!.Respon"
                    isEditing="@isEditing"
                    Options="@GetOptions(17)"
                                 GetOptionValue="ResponValue"
                                 GetOptionLabel="ResponLabel" />
            </FormField>

            <!-- FIELD 18: Pays de résidence -->
            <FormField Label="Residence" IsVisible="@Visibility.GetValueOrDefault("Rpays", true)">
                <SelectedDisplay TValue="string"
                    @bind-Value="draftTiw!.Rpays"
                    isEditing="@isEditing"
                    Options="@GetOptions(31)"
                                 GetOptionValue="RpaysValue"
                                 GetOptionLabel="RpaysLabel" />
            </FormField>
           
            <!-- FIELD 19: Nationalité (string) -->
            <FormField Label="Natio" IsVisible="@Visibility.GetValueOrDefault("Natio", true)">
                <SelectedDisplay TValue="string"
                    @bind-Value="draftTiw!.Natio"
                    isEditing="@isEditing"
                    Options="@GetOptions(31)"
                                 GetOptionValue="NatioValue"
                                 GetOptionLabel="NatioLabel" />
            </FormField>
  
            <!-- FIELD 20: Méthode de paiement -->
            <FormField Label="P.Meth" IsVisible="@Visibility.GetValueOrDefault("Ipaid", true)">
                <SelectedDisplay TValue="int?"
                    @bind-Value="draftTiw!.Ipaid"
                    isEditing="@isEditing"
                    Options="@GetOptions(17)"
                                 GetOptionValue="IpaidValue"
                                 GetOptionLabel="IpaidLabel" />
            </FormField>
        </div>
    </div>
}
