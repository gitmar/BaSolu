@code {
    // Workflow flags
    [Parameter] public List<TiwaflDto> SubAfls { get; set; }
    [Parameter] public GridMode GMode { get; set; } = GridMode.None;
    [Parameter] public bool isEditing { get; set; } = false;
    [Parameter] public Dictionary<string, bool> AflVisibility { get; set; } = new();

    [Parameter] public List<Gtabl> EnsTbls { get; set; }
    [Parameter] public int? SelectedGroup { get; set; }
    
    // Identifiers
    [Parameter] public string RenderKey { get; set; }
    [Parameter] public Guid? EdRowguid { get; set; }
    // Actions passed in from parent
    [Parameter] public EventCallback<TiwaflDto> ConfirmEdit { get; set; }
    [Parameter] public EventCallback<TiwaflDto> CancelEdit { get; set; }

    [Parameter] public EventCallback<TiwaflDto> ConfirmDelete { get; set; }
    [Parameter] public EventCallback<TiwaflDto> CancelDelete { get; set; }
    [Parameter] public EventCallback<TiwaflDto> StartRubEdit { get; set; }
    [Parameter] public EventCallback<Guid> StartRowDelete { get; set; }

    private List<Gtabl> GetOptions(int pxcod)
    {
        return EnsTbls
            .Where(t => t.Pid == pxcod)
            .ToList();
    }
}