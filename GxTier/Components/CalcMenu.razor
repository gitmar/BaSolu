@inject SessionContextService _sessionContext
@inject RendAgres _rendAgres
@inject IPendingChangesGuard _guard
@inject IMessageService _messageService

@if (isLoading)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" Size="SpinnerSize.Large" />
        <p>OPERA/CALCULS Loading...</p>
    </div>
}
<div>
    @* test : @froMenu.Usite *@
</div>
@if (!isLoading)
{
    <div class="gx-screen-layout">
        <div class="container gx-parent-container" style="height: 100vh;">
            <div class="d-flex flex-column" style="height: 100%;">
                <GxNavMenu BrandText="A24soft Gx-Solutions"
                           MenuItems="@MenuItems"
                           YaGroup="true"
                           Groups="@Groupes"
                           MenuSelected="@_chxMenu"
                           MenuSelectedChanged="@SelMenu"
                           GroupSelected="@_chxGpe"
                           GroupSelectedChanged="@SelGpe"
                           OnBack="@NavigateBack" />
               
                <!-- Top Menu Info -->
                <div class="row mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <label>Exercice:</label>
                        <InputSelect id="exoId" @bind-Value="froMenu.Uexo">
                            <option value="0">exo?</option>
                            @foreach (var exo in EnsExos)
                            {
                                <option value="@exo.Id">@exo.Sref</option>
                            }
                        </InputSelect>

                        <label>Session:</label>
                        <InputSelect id="sesId" @bind-Value="froMenu.Usesio">
                            <option value="0">session?</option>
                            @foreach (var ses in EnsSess)
                            {
                                <option value="@ses.Id">@ses.Sref</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="row mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <label>Programme :</label>
                        <div class="text-center">
                            <InputSelect id="pgrId" @bind-Value="ImyProg">
                                <option value="0">progr?</option>
                                @foreach (var pgr in LsProgs)
                                {
                                    <option value="@pgr.Id">@pgr.Liba</option>
                                }
                            </InputSelect>
                        </div>

                        <label for="TypDiv">Service :</label>
                        <div>
                            <InputSelect id="TypDiv" @bind-Value="ImyDiv">
                                <option value="0">Aucun</option>
                                @foreach (var divo in LsDivs)
                                {
                                    <option value="@divo.Ihie">@divo.Abg-@divo.Liba</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                </div>

                    @if (!string.IsNullOrEmpty(Imessage))
                    {
                        <span class="bg-info bg-opacity-10 text-danger px-2" style="font-style: italic;">
                            &nbsp;--> @Imessage
                        </span>
                    }
                <!-- Main Content //a integer froMenu -->
                @if (_chxMenu != 0 && curOrga != null && toChild != null)
                {
                    @if (_chxMenu == 1)
                    {
                        <CalcResLnes @ref="mygcalc"
                               curOrga="@curOrga"
                               @bind-NbChanges="_nbChanges"
                               _guard="@_guard"
                               toChild="@toChild"
                               allEnable="@allEnable"
                               _InODaClient="@_MyODaClient">
                                    <ChildContent>
                                        @* <h2 class="child-box">Hello TABLES</h2> *@
                                    </ChildContent>
                        </CalcResLnes>

                        @* <CalcResLnes @ref="mygcalc"
                                     curOrga="@curOrga"
                                     toChild="@toChild"
                                     allEnable="@allEnable"
                                     InODaClient="@_MyODaClient">
                            <ChildContent>
                                <h2 class="child-box">Hello GRILLES</h2>
                            </ChildContent>
                        </CalcResLnes> *@
                    }
                    else if (_chxMenu == 2)
                    {
                        @* <OrdaLoad>
                                    <ChildContent>
                                        <h2 class="child-box">Hello VALIDATIONS</h2>
                                    </ChildContent>
                                </OrdaLoad> *@
                    }
                }
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-12">
            @if (_guard.HasPendingChanges())
            {
                <div class="alert alert-warning">
                    <strong>@pendingCount changes pending across all tabs</strong>
                </div>
            }
            <div class="d-flex gap-2 justify-content-end">
                <Button Color="ButtonColor.Primary"
                        @onclick="SaveAllChanges"
                        Enabled="@_guard.HasPendingChanges()">
                    Save All (@pendingCount changes)
                </Button>
                <Button Color="ButtonColor.Secondary"
                        @onclick="CancelAllChanges">
                    Cancel All Changes
                </Button>
            </div>
        </div>
    </div>
}
<ErrorBoundary>
    <ErrorContent>
        An unexpected error occured. Please try again later.
    </ErrorContent>
</ErrorBoundary>
}
