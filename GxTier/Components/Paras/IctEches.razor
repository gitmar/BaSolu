    // ADD process
    private async Task ProcessAdding<TDto>(
    TDto? entity,
    bool isConfirm,
    string entitySet,
    Action<TDto> addToCollection,
    Action<TDto> removeFromCollection)
    where TDto : class
    {
        if (entity is null)
            return;

        var rowguid = GetRowguid(entity);
        _rowPendingOpTypeByRow.TryGetValue(rowguid, out var pendingType);
        var isNew = pendingType == PendingOpType.Insert;

        if (!isConfirm)
        {
            if (isNew)
                removeFromCollection(entity);

            RollbackPendingState(entity, isNew);
            await InvokeAsync(StateHasChanged);
            return;
        }

        CopyDraftToGridItem(entity);
        ResetEntityUIState<TDto>();

        var opId = await CommitAddOrUpdateAsync(entity, isNew, entitySet);
        _rowPendingOpTypeByRow[rowguid] = isNew ? PendingOpType.Insert : PendingOpType.Update;
        _pendingOpIdsByRow[rowguid] = opId;

        if (isNew)
        {
            removeFromCollection(entity);
            addToCollection(entity);
        }

        FinalizeConfirmedState(entity, $"✅ {typeof(TDto).Name} confirmed");
        await InvokeAsync(StateHasChanged);
    }
    // EDIT process
    private async Task ProcessEditing<TDto>(
    TDto? entity,
    bool isConfirm,
    string entitySet,
    Func<TDto, bool> validate,
    Action<TDto> replaceInCollection)
    where TDto : class
    {
        if (entity is null)
        {
            Imessage = "Entity is null";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var rowguid = GetRowguid(entity);
        _rowPendingOpTypeByRow.TryGetValue(rowguid, out var pendingType);
        var isNew = pendingType == PendingOpType.Insert;

        if (!isConfirm)
        {
            RollbackPendingState(entity, isNew);
            await InvokeAsync(StateHasChanged);
            return;
        }

        CopyDraftToGridItem(entity);
        ResetEntityUIState<TDto>();

        if (!validate(entity))
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        var opId = await CommitAddOrUpdateAsync(entity, isNew, entitySet);
        _rowPendingOpTypeByRow[rowguid] = isNew ? PendingOpType.Insert : PendingOpType.Update;
        _pendingOpIdsByRow[rowguid] = opId;

        replaceInCollection(entity);

        FinalizeConfirmedState(entity, $"✅ {typeof(TDto).Name} confirmed");
        await InvokeAsync(StateHasChanged);
    }
    // DELETE process
    private async Task ProcessDeleting<TDto>(
    TDto? item,
    bool isConfirm,
    string entitySet,
    Action<TDto> removeFromCollection)
    where TDto : class
    {
        if (item is null)
            return;

        var rowguid = GetRowguid(item);

        if (!isConfirm)
        {
            ResetRowState(rowguid);
            await InvokeAsync(StateHasChanged);
            return;
        }

        removeFromCollection(item);

        var key = GetEntityKey(item);
        var opId = await _guard.TrackDelete(entitySet, key, rowguid);
        _pendingOpIdsByRow[rowguid] = opId;

        SetDeleteFlags(item);
        ResetRowState(rowguid);
        _rowPendingOpTypeByRow.Remove(rowguid);

        await InvokeAsync(StateHasChanged);
    }
    // CANCEL process
    private async Task ProcessCancel<TDto>(TDto? entity, PendingOpType opType) where TDto : class
    {
        if (entity is null)
            return;

        var rowguid = GetRowguid(entity);

        if (_pendingOpIdsByRow.TryGetValue(rowguid, out var opId))
        {
            await _guard.CancelTrackAsync(opId, opType);
            _pendingOpIdsByRow.Remove(rowguid);
        }

        _rowPendingOpTypeByRow.Remove(rowguid);

        if (opType == PendingOpType.Insert)
            RemoveFromParentCollection(entity);
        else
            ClearDraft<TDto>();

        ResetRowState(rowguid);
        ResetEntityUIState<TDto>();
        Imessage = string.Empty;
        StateHasChanged();
    }

    // Pending and others UI Helpers
    private Guid? GetPendingOpId<TDto>(TDto entity) where TDto : class
    {
        var rowguid = GetRowguid(entity);
        return _pendingOpIdsByRow.TryGetValue(rowguid, out var opId) ? opId : null;
    }
    private void RollbackPendingState<TDto>(TDto entity, bool isNew)
    where TDto : class
    {
        var rowguid = GetRowguid(entity);

        if (isNew)
            RemoveFromParentCollection(entity);
        else
            ClearDraft<TDto>();

        _rowPendingOpTypeByRow.Remove(rowguid);
        _pendingOpIdsByRow.Remove(rowguid);
        ResetRowState(rowguid);
        ResetEntityUIState<TDto>();
        Imessage = string.Empty;
    }
    private async Task<Guid> CommitAddOrUpdateAsync<TDto>(
    TDto entity,
    bool isNew,
    string entitySet)
    where TDto : class
    {
        if (isNew)
            return await _guard.TrackInsert(entitySet, entity);

        var key = GetEntityKey(entity);
        return await _guard.TrackUpdate(entitySet, key, entity);
    }
    private void FinalizeConfirmedState<TDto>(TDto entity, string confirmMessage)
        where TDto : class
    {
        var rowguid = GetRowguid(entity);

        SetFlags(entity, 0, -1, 0);
        ResetRowState(rowguid);
        SetLightBackground(rowguid, false);
        ResetEntityUIState<TDto>();
        Imessage = confirmMessage;
    }
