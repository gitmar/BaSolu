    private string GetEntitySetName<T>() where T : class
    {
        return typeof(T) switch
        {
            Type t when t == typeof(PlngenDto) => "Plngens",
            Type t when t == typeof(ActsaieDto) => "Actsaies",
            Type t when t == typeof(ActdetDto) => "Actdets",
            _ => throw new ArgumentException($"Unknown entity type: {typeof(T).Name}")
        };
    }
    private string GetEntitySet(object entity)
    {
        return entity switch
        {
            PlngenDto _ => "Plngens",
            ActsaieDto _ => "Actsaies",
            ActdetDto _ => "Actdets",
            _ => throw new ArgumentException("Unknown entity type")
        };
    }
    private object GetEntityKey<TDto>(TDto entity)
    {
        switch (entity)
        {
            case PlngenDto pln:
                return pln.Id;
            case ActsaieDto rub:
                return rub.Id;
            case ActdetDto fmt:
                return fmt.Id;
            default:
                throw new InvalidOperationException($"Unknown entity type {typeof(TDto).Name}");
        }
    }
    // 🔥 Generic Rowguid (no reflection)
    private static Guid GetRowguid<T>(T entity) where T : class
        => ((dynamic)entity).Rowguid;  // Or property expression
    // Generic Xadd1 getter
    private int GetXadd1<T>(T entity)
    {
        return (int)typeof(T).GetProperty("Xadd1")?.GetValue(entity)!;
    }
    // Remove from parent collection
    private void RemoveFromParentCollection<T>(T entity)
    {
        // Plngen: top-level
        if (entity is TierspDto tie && MyDaTiers.Any(p => p.Rowguid == tie.Rowguid))
            MyDaTiers.Remove(tie);
        // Rubvar: parent Plngen.Actsaies
        else if (entity is ActsaieDto rub)
        {
            var parent = MyDaTiers.FirstOrDefault(p => p.Id == rub.Itie);
            parent?.Actsaies?.Remove(rub);
        }
        // Rubfmt: parent Rubvar.Actdets
        else if (entity is ActdetDto fmt)
        {
            var parentRub = MyDaTiers.SelectMany(p => p.Actsaies).FirstOrDefault(r => r.Id == fmt.Iact);
            parentRub?.Actdets?.Remove(fmt);
        }
    }
    // Generic flag setter
    private void SetFlags<T>(T entity, int xadd1, int xedt1, int xdel1)
    {
        typeof(T).GetProperty("Xadd1")?.SetValue(entity, xadd1);
        typeof(T).GetProperty("Xedt1")?.SetValue(entity, xedt1);
        typeof(T).GetProperty("Xdel1")?.SetValue(entity, xdel1);
    }
    private ActsaieDto? FindParentRub(ActdetDto fmt)
    {
        // Using foreign key Irub, but Rubvar exists only inside plans
        return MyDaTiers
            .SelectMany(p => p.Actsaies ?? Enumerable.Empty<ActsaieDto>())
            .FirstOrDefault(r => r.Id == fmt.Iact);
    }
    private async Task MarkAsModified<TDto>(TDto item, string entitySet) where TDto : class
    {
        // Reset flags (your convention)
        SetFlags(item, 0, 0, 0);  // Xadd1=Xedt1=Xdel1=0

        // Extract PK using your helper
        var key = GetEntityKey(item);

        // Queue update in guard
        await _guard.TrackUpdate(entitySet, key, item);

        Console.WriteLine($"modified liba {((dynamic)item).Liba} et abg {((dynamic)item).Abg}");
        Console.WriteLine($"✅ {entitySet} marked Modified (queued for update)");
    }
    private void CopyDraftToGridItem<T>(T gridItem) where T : class
    {
