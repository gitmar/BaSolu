                    var atr = (ActdetDto?)item;
                    await ProcessAdding(
                        atr,
                        isConfirm,
                        "Actdets",
                        x => Uihelper.AddItem(curAct.Actdets, x),
                        x => Uihelper.RemoveItem(curAct.Actdets, y => y.Rowguid == x.Rowguid));
                    break;
                }
        }
    }
