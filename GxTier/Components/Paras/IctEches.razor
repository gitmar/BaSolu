                    var atr = (ActsaieDto?)item;
                    await ProcessAdding(
                        atr,
                        isConfirm,
                        "Actsaies",
                        x => Uihelper.AddItem(curTier.Actsaies, x),
                        x => Uihelper.RemoveItem(curTier.Actsaies, y => y.Rowguid == x.Rowguid));
                    break;
