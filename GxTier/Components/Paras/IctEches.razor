    public void GenerateSchedulesForSelection()
    {
        foreach (var tiers in SelDaTiers)
        {
            // Create ActsaieDto linked to this Tiersp
            var actsaie = new ActsaieDto
            {
                Id = Guid.NewGuid().GetHashCode(), // or your DB identity
                Idorg = curOrga.Idorg,
                Ityp = 3, //1durable2session3echeancier
                Itie = tiers.Id, // link to Tiersp
                Irub = curRubr.Id,
                Isess = "",
                Tovalid = 1, //a valider
                Fullname = tiers.Nom + ' ' + tiers.Pnom,// optional for UI
                Liba = curRubr.Liba,
                Abg = curRubr.Abg
            };

            // Generate schedule with balances
            GenerateScheduleWithBalance(curRubr, actsaie);

            // Attach Actsaie back to Tiersp or persist to DB
            tiers.Actsaies.Add(actsaie);
        }
    }
    public void GenerSave()
    {
        foreach (var tiers in MyDaTiers)
        {
            foreach(var act in tiers.Actsaies.Where(ia => ia.Tovalid == 1).ToList())
            {
                //save actsaie
                _guard.TrackInsert("Actsaies", act);
                foreach(var adet in act.Actdets)
                {
                    //save actdet
                    _guard.TrackInsert("Actdets", adet);
                }
                act.Tovalid = 0;
            }
        }
    }
    public void GenerCancel()
    {
        foreach (var tiers in MyDaTiers)
        {
            foreach (var act in tiers.Actsaies.Where(ia => ia.Tovalid == 1).ToList())
            {
                foreach (var adet in act.Actdets)
                {
                    act.Actdets.Remove(adet);
                }
                tiers.Actsaies.Remove(act);
            }
        }
    }
    public static void GenerateScheduleWithBalance(RubvarDto rubvar, ActsaieDto actsaie)
    {
        actsaie.Actdets = new List<ActdetDto>();

        if (rubvar.Ecmount == null || (rubvar.Ecannu == null && rubvar.Nbech == 0))
            throw new InvalidOperationException("Rubvar must define either Ecmount or Ecannu or Nbech.");

        decimal total = rubvar.Ecmount ?? 0m;
        decimal monthly = rubvar.Ecannu ?? 0m;
        int months = rubvar.Nbech ?? int.MaxValue;

        // Decide number of installments
        int installmentCount;
        if (rubvar.Ecmode == 1) // ByMonth
        {
            installmentCount = months;
            monthly = total / months;
        }
        else // ByAmount
        {
            installmentCount = (int)Math.Ceiling(total / monthly);
        }

        // Calculate base amount and remainder
        decimal baseAmount = monthly;
        decimal remainder = total - (baseAmount * installmentCount);

        decimal runningBalance = total;

        for (int i = 0; i < installmentCount; i++)
        {
            decimal amount = baseAmount;

            // Apply adjustment strategy
            if (remainder != 0)
            {
                var adjustmentMode = (AdjustmentMode)rubvar.Ajstyp;

                if (adjustmentMode == AdjustmentMode.FirstLine && i == 0)
                    amount += remainder;
                else if (adjustmentMode == AdjustmentMode.LastLine && i == installmentCount - 1)
                    amount += remainder;
                else if (adjustmentMode == AdjustmentMode.EvenSpread)
                    amount += remainder / installmentCount;
            }

            // Update balance depending on operation type
            var operType = (OperationType)rubvar.Ectype;
            if (operType == OperationType.Repayment || operType == OperationType.Subscription)
                runningBalance -= amount; // repayment/subscription reduces balance
            else if (operType == OperationType.Disbursement)
                runningBalance += amount; // disbursement increases balance

            actsaie.Actdets.Add(new ActdetDto
        {
            Iact = actsaie.Id, //0a corriger trigger
            Prowguid = actsaie.Rowguid, //pour Iact
            Liba = rubvar.Abg + $"{i}", //UI
            Eddate = rubvar.Ddate?.AddMonths(i),
            Edmount = amount,
            Edsolde = runningBalance
        });
        }

        // Update ActsaieDto summary
        actsaie.Ecmount = total;
        actsaie.Ecannu = monthly;
        actsaie.Nbech = rubvar.Nbech;
        actsaie.Ecsolde = runningBalance;
    }

