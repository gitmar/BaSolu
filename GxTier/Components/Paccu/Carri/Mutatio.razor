                                                                    ✏️ Edit
                                                                </Button>
                                                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                        @onclick="() => StartRowDelete(item.Rowguid, EntityLevel.Plan)">
                                                                    🗑 Delete
                                                                </Button>
                                                                break;
                                                        }
                                                    </ChildContent>
                                                </GridColumn>
                                                </GridColumns>
