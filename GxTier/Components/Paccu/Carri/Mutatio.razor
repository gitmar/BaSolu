    private async Task ProcessEntity<T>(T entity, bool isConfirm, string entitySet, Func<T, bool> validate)
    where T : class
    {
        Console.WriteLine($"🔄 Process{typeof(T).Name}: {(isConfirm ? "CONFIRM" : "CANCEL")}");

        if (entity == null)
        {
            Imessage = "entity nulle";
            StateHasChanged();
            return;
        }

        if (isConfirm)
        {
            // 🔥 1. Copy draft → entity (for validation)
            CopyDraftToGridItem(entity);

            // 🔥 2. VALIDATE (now has updated values)
            if (!validate(entity))
            {
                Console.WriteLine($"❌ Validation failed: {Imessage}");
                StateHasChanged();
                return;
            }

            // 🔥 3. NEW vs EXISTING (SINGLE operation)
            bool isNew = GetXadd1(entity) == -1;  // Assumes GetXadd1<T>
            if (isNew)
            {
                curODContext.AddObject(entitySet, entity);  // Tracks + prepares INSERT
                Console.WriteLine($"➕ NEW {typeof(T).Name} → AddObject");
            }
            else
            {
                curODContext.SafeAttachOrUpdate(entity, entitySet, false);  // Your method!
                Console.WriteLine($"✏️ EXISTING → SafeAttachOrUpdate");
            }

            // 🔥 4. Confirm flags ONCE
            SetFlags(entity, 0, -1, 0);  // Xadd1=0 confirmed

            // 🔥 5. SINGLE UpdateObject (applies flags + changes)
            curODContext.UpdateObject(entity);
            Console.WriteLine($"✅ {typeof(T).Name} confirmed → tracked");

            // 🔥 6. UI + notify
            var rowguid = GetRowguid(entity);  // Generic helper
            ResetRowState(rowguid);
            SetLightBackground(rowguid, false);
            ResetEntityUIState<T>();
            await NotifyPendingChanges();
            Imessage = $"✅ {typeof(T).Name} confirmed";
        }
        else  // CANCEL (unchanged - perfect)
        {
            if (GetXadd1(entity) == -1)  // New only
            {
                if (curODContext.IsEntityTracked(entity))
                    curODContext.Detach(entity);
                RemoveFromParentCollection(entity);
            }
            else
            {
                ClearDraft<T>();
            }
            var rowguid = GetRowguid(entity);
            ResetRowState(rowguid);
            ResetEntityUIState<T>();
            Imessage = "";
        }
        StateHasChanged();
    }
    private async Task NotifyPendingChanges()
    {
        await OnPendingStateChanged.InvokeAsync(new PendingState(
            _guard.HasPendingChanges(),
            _guard.GetPendingChangesCount()
        ));

        NbChanges = _guard.GetPendingChangesCount();
        Console.WriteLine($"🔔 Pending changes: {NbChanges}");
        await NbChangesChanged.InvokeAsync(NbChanges);
        StateHasChanged();
    }
    
