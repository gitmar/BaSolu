                curODContext.AddRelatedObject(tie, "Tiemvts", nwMvt);
            } catch(Exception ex)
            {
                Console.WriteLine($"erreur mutation {ex.Message}");
            }
        }
        editingTiwRowGuid = Guid.Empty;
        // EditingRubRowGuid = Guid.Empty;
        // EditingFmtRowGuid = Guid.Empty;
        StateHasChanged();
    }

