                                     curODContext="@curODContext">
                                <ChildContent>
                                    <h2 class="child-box">Hello ACCUEIL</h2>
                                </ChildContent>
                            </InvOper> *@
                        }
                        else if (_chxMenu == 4 && Ugpe != 0 && Tgpe != 0)
                        {
                            @* <EnrolTiw @ref="myertiw"
                                     ParentEDT="@ParentEDT"
                                     ParentOK="@ParentOK"
                                     Ugpe="@Ugpe"
                                     Tgpe="@Tgpe"
                                     OnSaved="ManSaveAll"
                                     allEnable="@allEnable"
                                     curOrga="@curOrga"
                                     toChild="@toChild"
                                     curODContext="@curODContext">
                                <ChildContent>
                                    <h2 class="child-box">Hello ACCUEIL</h2>
                                </ChildContent>
                            </EnrolTiw> *@
