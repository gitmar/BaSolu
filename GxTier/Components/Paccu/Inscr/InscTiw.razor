@page "/insctiw"
@layout EnrolMenu

@using System
@using System.Collections.ObjectModel
@using System.ComponentModel.DataAnnotations
@using System.Dynamic
@using System.Net.Http.Headers
@using System.Security.Claims
@using System.Reflection
@using System.Text
@using System.Text.Json
@using System.Web
@using BlazorBootstrap
@using GxShared.Sess
@using GxShared.Others
@using GxShared.Helpers
@using GxTie.ClieModels
@using GxTie.Services
@using GxTie.Components.Paccu.RtPer
@using GxTie.Components.FrmHelper
@using GxWapi.DaModels
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.OData.Client
@using Newtonsoft.Json

@inject NavigationManager _navmanager
@inject HttpClientService _clieManager
@inject RendAgres _rendAgres
@inject IMessageService _messageService

<PageTitle>Saisie.Enrollement</PageTitle>
<div>
    @Imessage
</div>
@if (isLoading)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" Size="SpinnerSize.Medium" />
        <p>Saisie.Enrollement Loading...</p>
    </div>
}
<!--downmodal-->
@if (curTiw != null && isModalVisible == true)
{
    <GlobModal IsVisible="@isModalVisible"
               IsVisibleChanged="@OnModalVisibilityChanged"
               Title="Chargement des documents"
               EntyTiw="@curTiw"
               EntyTie="null"
               LsmVars="@LsVars"
               LsmFixes="@LsFixes"
               OnTiwSave="@HandleTiwSave"
               Oparent="2">
    </GlobModal>
}
<div class="my-container">
    @if (toChild != null)
    {
        @ChildContent
    }
</div>
@if (!isLoading)
{
    <AuthorizeView>
        <Authorized Context="authtiwcontext">
            <div class="d-flex align-items-center gap-2">
                <Button Color="ButtonColor.Primary"
                        Size="ButtonSize.Small"
                        Class="px-2 py-1 small-btn"
                        Disabled="@(!AllowMultipleEdits && isAddTiw)"
                        @onclick="StartTiwNew">
                    ➕ Add
                </Button>

                @if (isAddTiw)
                {
                    <Button Color="ButtonColor.Info"
                            Size="ButtonSize.Small"
                            Class="px-2 py-1 small-btn"
                            @onclick="ShowModal">
                        piece(s)
                    </Button>

                    <Button Color="ButtonColor.Success"
                            Size="ButtonSize.Small"
                            Class="px-2 py-1 small-btn"
                            @onclick="() => ConfirmEdit(curTiw, EntityLevel.Plan)">
                        ✅ Confirm
                    </Button>

                    <Button Color="ButtonColor.Secondary"
                            Size="ButtonSize.Small"
                            Class="px-2 py-1 small-btn"
                            @onclick="() => CancelEdit(curTiw, EntityLevel.Plan)">
                        ❌ Cancel
                    </Button>
                }
            </div>

            @if (isAddTiw || isEdtTiw)
            {
                <div class="container">
                    <Tabs>
                        <Tab Title="Membres">
                            <Content>
                                <!-- ✅ EditForm per tab - no nesting issues -->
                                <EditForm Model="curTiw">
                                    <DataAnnotationsValidator />
                                    <ValidationSummary />
                                    <div>
                                        @if (draftTiw != null)
                                        {
                                            <PTiwGdHelper Draft="@draftTiw"
                                                          RenderKey="parent-grid"
                                                          GMode="@GtieMode"
                                                          IsEditing="@isTieEditing"
                                                          Visibility="@Visibility"
                                                          TbItems="@TbItems"
                                                          EdRowguid="@EdTiwRowguid" />
                                        }
                                    </div>

                                    <!-- Additional dynamic attributes -->
                                    <div class="card">
                                        <div class="card-body p-3">
                                            @foreach (var ua in LsVars.Where(a => a.Gvars == 6 && a.Itb == Ugpe))
                                            {
                                                Tiwatr icatr = curTiw.Tiwatrs.FirstOrDefault(tat => tat.Igsg == ua.Xseq)
                                                                ?? new Tiwatr
                                                                {
                                                                    Xadd1 = -1,
                                                                    Igsg = ua.Xseq,
                                                                    Itie = curTiw.Id,
                                                                    Atyp = ua.Atyp,
                                                                    Aztyp = ua.Ztyp,
                                                                    Svala = "",
                                                                    AtState = AEntState.NewAdded
                                                                };
                                                <FormField Label="@ua.Liba" IsVisible=true>
                                                    @if ((isEdtTiw || isAddTiw) && ua.Eta == 1)
                                                    {
                                                        if (ua.Zfro == 2)
                                                        {
                                                            <InputSelect @bind-Value="icatr.Svala" class="form-select">
                                                                <option value="0">?choisir</option>
                                                                @foreach (var tob in TbItems.Where(ut => ut.Pxcod == ua.Xdpd))
                                                                {
                                                                    <option value="@tob.Elea">@tob.Liba</option>
                                                                }
                                                            </InputSelect>
                                                        }
                                                        else
                                                        {
                                                            <InputText @bind-Value="icatr.Svala" class="form-control" />
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <div class="form-control-plaintext">@icatr.Svala</div>
                                                    }
                                                </FormField>
                                            }
                                        </div>
                                    </div>
                                </EditForm>
                            </Content>
                        </Tab>
                        <Tab title="Affilies">
                            <Content>
                                @if (CanEditChildren)
                                {
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <label>Group:</label>
                                        <InputSelect id="gpId" @bind-Value="@IMyGAfl">
                                            <option value="0">Select group...</option>
                                            @foreach (var afl in LsGAfls.Where(af => af.Atyp == Ugpe))
                                            {
                                                <option value="@afl.Elea">@afl.Liba</option>
                                            }
                                        </InputSelect>
                                        <Button Color="ButtonColor.Primary"
                                                Size="ButtonSize.Small"
                                                Disabled="@(IMyGAfl < 1)"
                                                @onclick="() => StartRubNew(curTiw, IMyGAfl)">
                                            ➕ Add Child
                                        </Button>
                                        @if (curTiw.Tiwafls.Any())
                                        {
                                            <Button Color="ButtonColor.Success"
                                                    Size="ButtonSize.Small"
                                                    Class="px-2 py-1 small-btn"
                                                    @onclick="() => ConfirmRubEdit(curAfl)">
                                                ✅ Confirm
                                            </Button>
                                            <Button Color="ButtonColor.Secondary"
                                                    Size="ButtonSize.Small"
                                                    Disabled="@(IMyGAfl < 1)"
                                                    @onclick="() => CancelRubNew(curTiw)">
                                                ✖ Cancel
                                            </Button>
                                        }
                                    </div>
                                    <div>
                                        @if (draftAfl != null)
                                        {
                                            <!-- Cascade stable reference -->
                                            <CTiwGdHelper SubAfls="@curTiw.Tiwafls.ToList()"
                                                          RenderKey="child-grid"
                                                          GMode="@GaflMode"
                                                          IsEditing="@isAflEditing"
                                                          AflVisibility="@AflVisibility"
                                                          TbItems="@TbItems"
                                                          EdRowguid="@EdAflRowguid"
                                                          SelectedGroup="@IMyGAfl"
                                                          ConfirmEdit="@(p => ConfirmEdit(p, EntityLevel.Rub))"
                                                          CancelEdit="@(p => CancelEdit(p, EntityLevel.Rub))"
                                                          ConfirmDelete="@(p => ConfirmDelete(p, EntityLevel.Rub))"
                                                          CancelDelete="@(p => CancelDelete(p, EntityLevel.Rub))"
                                                          StartRubEdit="@(p => StartRubEdit(p, p.Rowguid))"
                                                          StartRowDelete="@(id => StartRowDelete(id, EntityLevel.Rub))" />
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-warning">
                                        🚫 Save the main record before adding children.
                                    </div>
                                }
                            </Content>
                        </Tab>
                        <Tab Title="Verification">
                            <Content>
                                @if (canbeVerified)
                                {
                                    <div class="container row">
                                        @* SelectedItemsChanged="OnSelectedItemsChanged" *@
                                        <Grid TItem="Tiewel"
                                              Data="@WaitingTiewels"
                                              AllowSelection="true"
                                              SelectionMode="GridSelectionMode.Multiple"
                                              Responsive="true">
                                            <GridColumns>
                                                <GridColumn TItem="Tiewel" HeaderText="No">
                                                    <ChildContent Context="item">
                                                        <span>@(item.Xedt1 == -1 ? item?.Iui : (item?.Iui == 0 ? item?.Iele : item?.Iui))</span>
                                                    </ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="Tiewel" HeaderText="Dossier">
                                                    <ChildContent Context="item">
                                                        @item.Xmatri
                                                    </ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="Tiewel" HeaderText="Nom">
                                                    <ChildContent Context="item">
                                                        @item.Nom
                                                    </ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="Tiewel" HeaderText="Pnom">
                                                    <ChildContent Context="item">
                                                        @item.Pnom
                                                    </ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="Tiewel" HeaderText="etat" IsVisible="true">
                                                    <HeaderContent>
                                                        @* @if (siyaItem)
                                                                    {
                                                                        <button class="btn btn-primary btn-sm"
                                                                                @onclick="() => ValiderSelection()">
                                                                            ➕ Valider?
                                                                        </button>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span>Eta</span>
                                                                    } *@
                                                    </HeaderContent>
                                                    <ChildContent Context="item">
                                                        <InputSelect @bind-Value="item.Eta" disabled="true">
                                                            <option class="jchx" value="0">?choisir</option>
                                                            @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                            {
                                                                <option value="@tob.Elea">@tob.Liba</option>
                                                            }
                                                        </InputSelect>
                                                    </ChildContent>
                                                </GridColumn>
                                            </GridColumns>
                                        </Grid>
                                    </div>
                                }
                            </Content>
                        </Tab>
                    </Tabs>
                </div>
            }
            <!--En bas ordinaire-->
            <div class="container row">
                <Grid TItem="Tiewel"
                      Data="@WaitingTiewels"
                      @key="TiwRenderKey"
                      AllowDetailView="true"
                      AllowPaging="true"
                      Responsive="true">
                    <GridColumns>
                        <GridColumn TItem="Tiewel" HeaderText="No">
                            <ChildContent Context="item">
                                <span>@(item.Xedt1 == -1 ? item?.Iui : (item?.Iui == 0 ? item?.Iele : item?.Iui))</span>
                            </ChildContent>
                        </GridColumn>
                        <GridColumn TItem="Tiewel" HeaderText="Dossier">
                            <ChildContent Context="item">
                                @item.Xmatri
                            </ChildContent>
                        </GridColumn>
                        <GridColumn TItem="Tiewel" HeaderText="Nom">
                            <ChildContent Context="item">
                                @item.Nom
                            </ChildContent>
                        </GridColumn>
                        <GridColumn TItem="Tiewel" HeaderText="Pnom">
                            <ChildContent Context="item">
                                @item.Pnom
                            </ChildContent>
                        </GridColumn>
                        <GridColumn TItem="Tiewel" HeaderText="etat" IsVisible="true">
                            <ChildContent Context="item">
                                <InputSelect @bind-Value="item.Eta" disabled="true">
                                    <option class="jchx" value="0">?choisir</option>
                                    @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                    {
                                        <option value="@tob.Elea">@tob.Liba</option>
                                    }
                                </InputSelect>
                            </ChildContent>
                        </GridColumn>
                        <GridColumn TItem="Tiewel" HeaderText="Actions" Filterable="false" Class="xcol2 actions-col">
                            <ChildContent Context="item">
                                @switch (GetRowState(item.Rowguid))
                                {
                                    case RowState.Locked:
                                        <span class="text-muted">—</span>
                                        break;

                                    case RowState.DeletePending:
                                        <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                @onclick="() => ConfirmDelete(item, EntityLevel.Plan)">
                                            ⚠️ Confirm
                                        </Button>
                                        <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                @onclick="() => CancelDelete(item, EntityLevel.Plan)">
                                            ❎ Cancel
                                        </Button>
                                        break;
                                    case RowState.EditPending:
                                        <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                Disabled="@(item.Xadd1 == -1)"
                                                @onclick="() => ConfirmEdit(item, EntityLevel.Plan)">
                                            ✅ Confirm
                                        </Button>
                                        <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                Disabled="@(item.Xadd1 == -1)"
                                                @onclick="() => CancelEdit(item, EntityLevel.Plan)">
                                            ❌ Cancel
                                        </Button>
                                        break;
                                    default:
                                        <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                                @onclick="() => StartManTiwEdit(item, 1)">
                                            ✏️ Edit
                                        </Button>
                                        <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                @onclick="() => StartRowDelete(item.Rowguid, EntityLevel.Plan)">
                                            🗑 Delete
                                        </Button>
                                        break;
                                }
                            </ChildContent>
                        </GridColumn>
                    </GridColumns>
                    <GridDetailView TItem="Tiewel" Context="selectedPln">
                        <Grid TItem="Tiwafl"
                              Data="@selectedPln.Tiwafls"
                              @key="RubRenderKey"
                              Responsive="true">
                            <GridColumns>
                                <GridColumn TItem="Tiwafl" HeaderText="No">
                                    <ChildContent Context="item">
                                        <span>@(item.Xedt1 == -1 ? item?.Iui : (item?.Iui == 0 ? item?.Iele : item?.Iui))</span>
                                    </ChildContent>
                                </GridColumn>
                                <GridColumn TItem="Tiwafl" HeaderText="Dossier">
                                    <ChildContent Context="item">
                                        @item.Xmatri
                                    </ChildContent>
                                </GridColumn>
                                <GridColumn TItem="Tiwafl" HeaderText="Nom">
                                    <ChildContent Context="item">
                                        @item.Nom
                                    </ChildContent>
                                </GridColumn>
                                <GridColumn TItem="Tiwafl" HeaderText="Pnom">
                                    <ChildContent Context="item">
                                        @item.Pnom
                                    </ChildContent>
                                </GridColumn>
                                <GridColumn TItem="Tiwafl" HeaderText="etat" IsVisible="true">
                                    <ChildContent Context="item">
                                        <InputSelect @bind-Value="item.Eta" disabled="true">
                                            <option class="jchx" value="0">?choisir</option>
                                            @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                            {
                                                <option value="@tob.Elea">@tob.Liba</option>
                                            }
                                        </InputSelect>
                                    </ChildContent>
                                </GridColumn>
                                <GridColumn TItem="Tiwafl" HeaderText="Actions" Filterable="false" Class="xcol2 actions-col">
                                    <ChildContent Context="item">
                                        @switch (GetRowState(item.Rowguid))
                                        {
                                            case RowState.Locked:
                                                <span class="text-muted">—</span>
                                                break;

                                            case RowState.DeletePending:
                                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                        @onclick="() => ConfirmDelete(item, EntityLevel.Rub)">
                                                    ⚠️ Confirm
                                                </Button>
                                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                        @onclick="() => CancelDelete(item, EntityLevel.Rub)">
                                                    ❎ Cancel
                                                </Button>
                                                break;
                                            case RowState.EditPending:
                                                <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                        Disabled="@(item.Xadd1 == -1)"
                                                        @onclick="() => ConfirmRubEdit(item)">
                                                    ✅ Confirm
                                                </Button>
                                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                        Disabled="@(item.Xadd1 == -1)"
                                                        @onclick="() => CancelRubEdit(item)">
                                                    ❌ Cancel
                                                </Button>
                                                break;
                                            default:
                                                <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                                        @onclick="() => StartRubEdit(item, item.Rowguid)">
                                                    ✏️ Edit
                                                </Button>
                                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                        @onclick="() => StartRowDelete(item.Rowguid, EntityLevel.Rub)">
                                                    🗑 Delete
                                                </Button>
                                                break;
                                        }
                                    </ChildContent>
                                </GridColumn>
                            </GridColumns>
                        </Grid>
                    </GridDetailView>
                </Grid>
            </div>
        </Authorized>
    </AuthorizeView>
}
<style>
    .inputfl {
        opacity: 0;
        width: 0.1;
        height: 0.1;
        position: absolute;
    }

    .disabled {
        pointer-events: none; /* Prevents clicking */
        opacity: 0.5; /*visual cue for disabled state */
    }

    .gpe-select {
        font-size: 24px;
        font-weight: bold;
    }

        .gpe-select option {
            font-size: 18px;
            font-weight: bold;
        }

    .my-container {
        background-color: yellow;
    }

    .maxh-400 {
        max-height: 400px;
        overflow-y: auto;
    }

    .disabled-action {
        pointer-events: none;
        opacity: 0.5;
    }

    .grid-container {
        display: grid;
        grid-template-columns: max-content minmax(max-content, auto);
        gap: 8px 16px;
    }

    .grid-row {
        display: contents; /* makes children participate directly in the grid */
    }

    .grid-container label {
        grid-column: 1;
        font-weight: bold;
        white-space: nowrap; /* prevent label wrap */
    }

    .grid-container > div {
        grid-column: 2;
    }

    .standard-width {
        width: 200px; /* or any fixed width like 150px, 100%, etc */
        max-width: 100%;
    }

    .fs-xs {
        font-size: 0.65rem;
    }

    .small-btn {
        font-size: 0.75rem; /* smaller text */
        line-height: 1.2;
    }
</style>

@code {
