@page "/valdtie"
@layout EnrolMenu

@using System
@using System.Collections.ObjectModel
@using System.ComponentModel.DataAnnotations
@using System.Dynamic
@using System.Net.Http.Headers
@using System.Security.Claims
@using System.Reflection
@using System.Text
@using System.Text.Json
@using System.Web
@using BlazorBootstrap
@using GxShared.Sess
@using GxShared.Others
@using GxShared.Helpers
@using GxTie.ClieModels
@using GxTie.Services
@using GxTie.Components.Paccu.RtPer
@using GxWapi.DaModels
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.OData.Client
@using Newtonsoft.Json

@inject NavigationManager _navmanager
@inject HttpClientService _cliemanager
@inject RendAgres _rendAgres
@inject IMessageService _messageService

<PageTitle>Saisie.Enrollement</PageTitle>
<div>
    @Imessage
</div>
@if (isLoading)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" Size="SpinnerSize.Medium" />
        <p>Saisie.Enrollement Loading...</p>
    </div>
}
<!--downmodal-->
@if (curTie != null && isModalVisible == true)
{
    <GlobModal IsVisible="@isModalVisible"
               IsVisibleChanged="@OnModalVisibilityChanged"
               Title="Chargement des documents"
               EntyTiw="null"
               EntyTie="@curTie"
               LsmVars="@LsVars"
               LsmFixes="@LsFixes"
               OnTieSave="@HandleTieSave"
               Oparent="2">
    </GlobModal>
}
<div class="my-container">
    @if (toChild != null)
    {
        @ChildContent
    }
</div>
@if (!isLoading)
{
    @if (curTie != null && edTiwContext != null)
    {
        <AuthorizeView>
            <Authorized Context="authtiwcontext">
                <EditForm EditContext="edTiwContext" @key="curTie">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="container">
                        <Tabs>
                            <div class="container">
                                <Tabs>
                                    <Tab Title="Membres">
                                        <Content>
                                            <div class="d-flex align-items-center gap-2">
                                                <Button Color="ButtonColor.Primary"
                                                        Size="ButtonSize.Small"
                                                        Class="px-2 py-1 small-btn"
                                                        Disabled="@(!AllowMultipleEdits && isAddTiw)"
                                                        @onclick="StartTiwNew">
                                                    ➕ Add
                                                </Button>
                                                @if (isAddTiw)
                                                {
                                                    <Button Color="ButtonColor.Info"
                                                            Size="ButtonSize.Small"
                                                            Class="px-2 py-1 small-btn"
                                                            @onclick="ShowModal">
                                                        piece(s)
                                                    </Button>

                                                    <Button Color="ButtonColor.Success"
                                                            Size="ButtonSize.Small"
                                                            Class="px-2 py-1 small-btn"
                                                            @onclick="() => ConfirmEdit(curTie, EntityLevel.Plan)">
                                                        ✅ Confirm
                                                    </Button>

                                                    <Button Color="ButtonColor.Secondary"
                                                            Size="ButtonSize.Small"
                                                            Class="px-2 py-1 small-btn"
                                                            @onclick="() => CancelEdit(curTie, EntityLevel.Plan)">
                                                        ❌ Cancel
                                                    </Button>
                                                }
                                            </div>
                                            @if(curTie?.Xadd1 == -1 || curTie?.Xedt1 == -1)
                                            {
                                            <div>
                                                <MainGridHelper FilteredData="@PersonsForGrid"
                                                                EdRowguid="@EdTiwRowguid"
                                                                Visibility="@TiwVisibility"
                                                                RenderKey="persons-grid"
                                                                DraftEntity="@draftPers"
                                                                SelectedEntity="@curPerson"
                                                                TbItems="@TbItems" />
                                            </div>
                                            <!--Attributs plus-->
                                            <div>
                                                    @foreach (var ua in LsVars.Where(a => a.Gvars == 6 && a.Itb == Ugpe))
                                                    {
                                                        Tieatr icatr = curTie.Tieatrs.FirstOrDefault(tat => tat.Igsg == ua.Xseq);
                                                        if (icatr == null)
                                                        {
                                                            icatr = new();
                                                            icatr.Xadd1 = -1;
                                                            icatr.Igsg = ua.Xseq;
                                                            icatr.Itie = curTie.Id;
                                                            icatr.Atyp = ua.Atyp;
                                                            icatr.Aztyp = ua.Ztyp;
                                                            icatr.Svala = "";
                                                            icatr.AtState = AEntState.NewAdded;
                                                        }

                                                        <div class="mb-2">
                                                            <!-- Label on top -->
                                                            <label class="form-label fw-bold ms-3 text-capitalize">@ua.Liba:</label>
                                                            @if (isEdtTiw || isAddTiw)
                                                            {
                                                                if (ua.Zfro == 2)
                                                                {
                                                                    <InputSelect @bind-Value="icatr.Svala" class="form-select">
                                                                        <option value="0">?choisir</option>
                                                                        @foreach (var tob in TbItems.Where(ut => ut.Pxcod == ua.Xdpd))
                                                                        {
                                                                            <option value="@tob.Elea">@tob.Liba</option>
                                                                        }
                                                                    </InputSelect>
                                                                }
                                                                else
                                                                {
                                                                    <InputText @bind-Value="icatr.Svala" class="form-control" />
                                                                }
                                                            }
                                                            else
                                                            {
                                                                if (ua.Zfro == 2)
                                                                {
                                                                    <InputSelect @bind-Value="icatr.Svala" disabled class="form-select">
                                                                        <option value="0">?choisir</option>
                                                                        @foreach (var tob in TbItems.Where(ut => ut.Pxcod == ua.Xdpd))
                                                                        {
                                                                            <option value="@tob.Elea">@tob.Liba</option>
                                                                        }
                                                                    </InputSelect>
                                                                }
                                                                else
                                                                {
                                                                    <div class="form-control-plaintext">@icatr.Svala</div>
                                                                }
                                                            }
                                                        </div>
                                                    }
                                            </div>
                                            }
                                        </Content>
                                    </Tab>
                                    <Tab title="Affilies">
                                        <Content>
                                            @if (CanEditChildren)
                                            {
                                                <div class="d-flex align-items-center gap-2 mb-2">
                                                    <label>Group:</label>
                                                    <InputSelect id="gpId" @bind-Value="IMyGAfl">
                                                        <option value="0">Select group...</option>
                                                        @foreach (var afl in LsGAfls)
                                                        {
                                                            <option value="@afl.Elea">@afl.Liba</option>
                                                        }
                                                    </InputSelect>
                                                    <Button Color="ButtonColor.Primary"
                                                            Size="ButtonSize.Small"
                                                            Disabled="@(IMyGAfl < 1)"
                                                            @onclick="() => StartRubNew(curTie, IMyGAfl)">
                                                        ➕ Add Child
                                                    </Button>
                                                    @if (draftAfls is not null)
                                                    {
                                                        <Button Color="ButtonColor.Secondary"
                                                                Size="ButtonSize.Small"
                                                                Disabled="@(IMyGAfl < 1)"
                                                                @onclick="() => CancelRubNew(curTie)">
                                                            ✖ Cancel
                                                        </Button>
                                                    }
                                                </div>
                                                <div>
                                                    <ChildGridHelper FilteredData="@AfilsForGrid"
                                                                     EdRowguid="@EdRubRowguid"
                                                                     Visibility="@AflVisibility"
                                                                     RenderKey="afils-grid"
                                                                     DraftEntity="@draftAfls"
                                                                     SelectedEntity="@curAfil"
                                                                     SelectedGroup="@IMyGAfl"
                                                                     TbItems="@TbItems"
                                                                     RowStates="@_rowStates"
                                                                     ConfirmEdit="@(p => ConfirmEdit(p, EntityLevel.Rub))"
                                                                     CancelEdit="@(p => CancelEdit(p, EntityLevel.Rub))"
                                                                     ConfirmDelete="@(p => ConfirmDelete(p, EntityLevel.Rub))"
                                                                     CancelDelete="@(p => CancelDelete(p, EntityLevel.Rub))"
                                                                     StartRubEdit="@(p => StartRubEdit(p, p.Rowguid))"
                                                                     StartRowDelete="@(id => StartRowDelete(id, EntityLevel.Rub))" />
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="alert alert-warning">
                                                    🚫 Save the main record before adding children.
                                                </div>
                                            }
                                        </Content>
                                    </Tab>
                                    <Tab Title="Validation">
                                        <Content>
                                            @if (canbeVerified)
                                            {
                                            <div class="container row">
                                <Grid TItem="Tiersp"
                                      Data="@WaitingTiersps"
                                      @key="TiwRenderKey"
                                      AllowSelection="true"
                                      SelectionMode="GridSelectionMode.Multiple"
                                      SelectedItemsChanged="OnSelectedItemsChanged"
                                      Responsive="true">
                                    <GridColumns>
                                        <GridColumn TItem="Tiersp" HeaderText="No">
                                            <ChildContent Context="item">
                                                <span>@(item.Xedt1 == -1 ? item?.Iui : (item?.Iui == 0 ? item?.Iele : item?.Iui))</span>
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="Tiersp" HeaderText="Dossier">
                                            <ChildContent Context="item">
                                                @item.Xmatri
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="Tiersp" HeaderText="Nom">
                                            <ChildContent Context="item">
                                                @item.Nom
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="Tiersp" HeaderText="Pnom">
                                            <ChildContent Context="item">
                                                @item.Pnom
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="Tiersp" HeaderText="etat" IsVisible="true">
                                                                <HeaderContent>
                                                                    @if (siyaItem)
                                                                    {
                                                                        <button class="btn btn-primary btn-sm"
                                                                                @onclick="() => ValiderSelection()">
                                                                            ➕ Valider?
                                                                        </button>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span>Eta</span>
                                                                    }
                                                                </HeaderContent>
                                            <ChildContent Context="item">
                                                <InputSelect @bind-Value="item.Eta" disabled="true">
                                                    <option class="jchx" value="0">?choisir</option>
                                                    @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                    {
                                                        <option value="@tob.Elea">@tob.Liba</option>
                                                    }
                                                </InputSelect>
                                            </ChildContent>
                                        </GridColumn>
                                    </GridColumns>
                                    </Grid>
                                    </div>
                                            }
                                        </Content>
                                    </Tab>
                                </Tabs>
                            </div>
                            <!--En bas ordinaire-->
                            <div class="container row">
                                <Grid TItem="Tiersp"
                                      Data="@WaitingTiersps"
                                      @key="TiwRenderKey"
                                      AllowDetailView="true"
                                      AllowPaging="true"
                                      Responsive="true">
                                    <GridColumns>
                                        <GridColumn TItem="Tiersp" HeaderText="No">
                                            <ChildContent Context="item">
                                                <span>@(item.Xedt1 == -1 ? item?.Iui : (item?.Iui == 0 ? item?.Iele : item?.Iui))</span>
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="Tiersp" HeaderText="Dossier">
                                            <ChildContent Context="item">
                                                @item.Xmatri
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="Tiersp" HeaderText="Nom">
                                            <ChildContent Context="item">
                                                @item.Nom
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="Tiersp" HeaderText="Pnom">
                                            <ChildContent Context="item">
                                                @item.Pnom
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="Tiersp" HeaderText="etat" IsVisible="true">
                                            <ChildContent Context="item">
                                                <InputSelect @bind-Value="item.Eta" disabled="true">
                                                    <option class="jchx" value="0">?choisir</option>
                                                    @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                    {
                                                        <option value="@tob.Elea">@tob.Liba</option>
                                                    }
                                                </InputSelect>
                                            </ChildContent>
                                        </GridColumn>
                                        <GridColumn TItem="Tiersp" HeaderText="Actions" Filterable="false" Class="xcol2 actions-col">
                                            <ChildContent Context="item">
                                                @switch (GetRowState(item.Rowguid))
                                                {
                                                    case RowState.Locked:
                                                        <span class="text-muted">—</span>
                                                        break;

                                                    case RowState.DeletePending:
                                                        <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                @onclick="() => ConfirmDelete(item, EntityLevel.Plan)">
                                                            ⚠️ Confirm
                                                        </Button>
                                                        <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                @onclick="() => CancelDelete(item, EntityLevel.Plan)">
                                                            ❎ Cancel
                                                        </Button>
                                                        break;
                                                    case RowState.EditPending:
                                                        <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                Disabled="@(item.Xadd1 == -1)"
                                                                @onclick="() => ConfirmEdit(item, EntityLevel.Plan)">
                                                            ✅ Confirm
                                                        </Button>
                                                        <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                Disabled="@(item.Xadd1 == -1)"
                                                                @onclick="() => CancelEdit(item, EntityLevel.Plan)">
                                                            ❌ Cancel
                                                        </Button>
                                                        break;
                                                    default:
                                                        <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                                                @onclick="() => StartManTiwEdit(item, 1)">
                                                            ✏️ Edit
                                                        </Button>
                                                        <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                @onclick="() => StartRowDelete(item.Rowguid, EntityLevel.Plan)">
                                                            🗑 Delete
                                                        </Button>
                                                        break;
                                                }
                                            </ChildContent>
                                        </GridColumn>
                                    </GridColumns>
                                    <GridDetailView TItem="Tiersp" Context="selectedPln">
                                        <Grid TItem="Tieafl"
                                              Data="@selectedPln.Tieafls"
                                              @key="RubRenderKey"
                                              Responsive="true">
                                            <GridColumns>
                                                <GridColumn TItem="Tieafl" HeaderText="No">
                                                    <ChildContent Context="item">
                                                        <span>@(item.Xedt1 == -1 ? item?.Iui : (item?.Iui == 0 ? item?.Iele : item?.Iui))</span>
                                                    </ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="Tieafl" HeaderText="Dossier">
                                                    <ChildContent Context="item">
                                                        @item.Xmatri
                                                    </ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="Tieafl" HeaderText="Nom">
                                                    <ChildContent Context="item">
                                                        @item.Nom
                                                    </ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="Tieafl" HeaderText="Pnom">
                                                    <ChildContent Context="item">
                                                        @item.Pnom
                                                    </ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="Tieafl" HeaderText="etat" IsVisible="true">
                                                    <ChildContent Context="item">
                                                        <InputSelect @bind-Value="item.Eta" disabled="true">
                                                            <option class="jchx" value="0">?choisir</option>
                                                            @foreach (var tob in LsFixes.Where(ut => ut.Gvars == 32 && ut.Itb == 1 && ut.Elea != 0))
                                                            {
                                                                <option value="@tob.Elea">@tob.Liba</option>
                                                            }
                                                        </InputSelect>
                                                    </ChildContent>
                                                </GridColumn>
                                                <GridColumn TItem="Tieafl" HeaderText="Actions" Filterable="false" Class="xcol2 actions-col">
                                                    <ChildContent Context="item">
                                                        @switch (GetRowState(item.Rowguid))
                                                        {
                                                            case RowState.Locked:
                                                                <span class="text-muted">—</span>
                                                                break;

                                                            case RowState.DeletePending:
                                                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                        @onclick="() => ConfirmDelete(item, EntityLevel.Rub)">
                                                                    ⚠️ Confirm
                                                                </Button>
                                                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                        @onclick="() => CancelDelete(item, EntityLevel.Rub)">
                                                                    ❎ Cancel
                                                                </Button>
                                                                break;
                                                            case RowState.EditPending:
                                                                <Button Color="ButtonColor.Success" Size="ButtonSize.Small"
                                                                        Disabled="@(item.Xadd1 == -1)"
                                                                        @onclick="() => ConfirmEdit(item, EntityLevel.Rub)">
                                                                    ✅ Confirm
                                                                </Button>
                                                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                                                        Disabled="@(item.Xadd1 == -1)"
                                                                        @onclick="() => CancelEdit(item, EntityLevel.Rub)">
                                                                    ❌ Cancel
                                                                </Button>
                                                                break;
                                                            default:
                                                                <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                                                        @onclick="() => StartRubEdit(item, item.Rowguid)">
                                                                    ✏️ Edit
                                                                </Button>
                                                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                                                        @onclick="() => StartRowDelete(item.Rowguid, EntityLevel.Rub)">
                                                                    🗑 Delete
                                                                </Button>
                                                                break;
                                                        }
                                                    </ChildContent>
                                                </GridColumn>
                                            </GridColumns>
                                        </Grid>
                                    </GridDetailView>
                                </Grid>
                            </div>
                        </Tabs>
                    </div>
                </EditForm>
            </Authorized>
        </AuthorizeView>
    }
    else
    {
        <div class="text-center p-3">
            <p>No records available.</p>
            @* <button class="btn btn-primary" @onclick="() => InitializeData()">
                    Initialize Data
                </button> *@
        </div>
    }
}
<style>
    .inputfl {
        opacity: 0;
        width: 0.1;
        height: 0.1;
        position: absolute;
    }

    .disabled {
        pointer-events: none; /* Prevents clicking */
        opacity: 0.5; /*visual cue for disabled state */
    }

    .gpe-select {
        font-size: 24px;
        font-weight: bold;
    }

        .gpe-select option {
            font-size: 18px;
            font-weight: bold;
        }

    .my-container {
        background-color: yellow;
    }

    .maxh-400 {
        max-height: 400px;
        overflow-y: auto;
    }

    .disabled-action {
        pointer-events: none;
        opacity: 0.5;
    }

    .grid-container {
        display: grid;
        grid-template-columns: max-content minmax(max-content, auto);
        gap: 8px 16px;
    }

    .grid-row {
        display: contents; /* makes children participate directly in the grid */
    }

    .grid-container label {
        grid-column: 1;
        font-weight: bold;
        white-space: nowrap; /* prevent label wrap */
    }

    .grid-container > div {
        grid-column: 2;
    }

    .standard-width {
        width: 200px; /* or any fixed width like 150px, 100%, etc */
        max-width: 100%;
    }

    .fs-xs {
        font-size: 0.65rem;
    }

    .small-btn {
        font-size: 0.75rem; /* smaller text */
        line-height: 1.2;
    }
</style>

@code {
