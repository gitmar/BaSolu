    // Generic Xadd1 getter
    private int GetXadd1<T>(T entity)
    {
        return (int)typeof(T).GetProperty("Xadd1")?.GetValue(entity)!;
    }
    // Remove from parent collection
    private void RemoveFromParentCollection<T>(T entity)
    {
        // Plngen: top-level
        if (entity is Tiersp pln && MyDaTies.Any(p => p.Rowguid == pln.Rowguid))
            MyDaTies.Remove(pln);
        // Rubvar: parent Plngen.Rubvars
        else if (entity is Tieafl rub)
        {
            var parent = MyDaTies.FirstOrDefault(p => p.Id == rub.Itie);
            parent?.Tieafls?.Remove(rub);
        }
    }
    private void CopyDraftToGridItem<T>(T gridItem) where T : class
    {
        switch (typeof(T).Name)
        { // ONLY editable UI fields - 5-10x faster than reflection!
            case nameof(Tiersp):
                if (draftTiw == null) return;
                var pln = (Tiersp)(object)gridItem;
                pln.Smatri = draftTiw.Smatri; //designation
                pln.Xmatri = draftTiw.Xmatri; //abrege
                pln.Nom = draftTiw.Nom; //formule-non valider
                pln.Pnom = draftTiw.Pnom;
                pln.Raison = draftTiw.Raison;
                pln.Eta = draftTiw.Eta; //etat
                break;
            case nameof(Tieafl):
                if (draftRub == null) return;
                var rub = (Tieafl)(object)gridItem;
                rub.Irang = draftRub.Irang;
                rub.Smatri = draftRub.Smatri; //designation
                rub.Xmatri = draftRub.Xmatri; //abrege
                rub.Nom = draftRub.Nom; //formule-non valider
                rub.Pnom = draftRub.Pnom;
                rub.Raison = draftRub.Raison;
                rub.Eta = draftRub.Eta; //etat
                break;
                // case nameof(Rubfmt):
                //     if (draftFmt == null) return;
                //     var fmt = (Rubfmt)(object)gridItem;
                //     fmt.Liba = draftFmt.Liba; //designation
                //     fmt.Abg = draftFmt.Abg; //abrege
                //     fmt.Zcdrub = draftFmt.Zcdrub; //code
