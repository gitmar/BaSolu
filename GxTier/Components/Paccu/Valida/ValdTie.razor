    private async Task StartRubEdit<T>(T item, Guid rowguid) where T : class
    {
        switch (item)
        {
            case Tieafl tieafl:
                await StartRubEdit(tieafl, rowguid); // your existing method
                break;

            // case Tieafl tieafl:
            //     await StartRubEdit(tieafl, rowguid); // defined in another parent component
