    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            if (toChild == null || curOrga == null)
            {
                Console.WriteLine("Missing parent data");
                return;
            }
            isAuthenticated = toChild.isAuthenticated;
            authUser = toChild.authUser;
            if (!isAuthenticated)
            {
                Imessage = "CONNEXION, Utilisateur non authentifie";
                return;
            }
            LsVars = toChild.LsVars;
            LsFixes = toChild.LsFixes;
            LsGAfls = toChild.LsFixes.Where(ua => ua.Gvars == 53 && ua.Itb == 6 && ua.Elea != 0).ToList();
            _lgcdu = 3;
            var noslims = LsVars.Where(uv => uv.Idhie == 0 && uv.Gvars == 21 && uv.Itb == 1 && uv.Elea == 1);
            if (noslims.Any()) _lgcdu = noslims.FirstOrDefault().Ivala;
            LsVues = LsFixes.Where(ut => ut.Gvars == 36 && ut.Itb == 4 && ut.Gp1 == 5 && ut.Elea != 0).ToList();
            //chargement des tables;
            TbItems = await _rendAgres.LoadOrgaTables();
            //TbGpes = datbls?.Hdtbls ?? new List<Gtabl>();
            LsPlans = toChild.LsPlans;
            //LsSites = toChild.LsSites;

            //ChargeParentData;
            Console.WriteLine($"Child init: Tiersps={curOrga.Tiersps?.Count ?? 0}");
            // 🔥 SAFE - Only initialize if Tiersps EXISTS
            //editcontext Model initialising
            curTie ??= new();  // Or load data here
            // Load Tiersp list into EntPerson list for the grid
            if (curOrga.Tiersps != null && curOrga.Tiersps.Any())
            {
                Console.WriteLine($"Tiersps loaded: {curOrga.Tiersps.Count}");

                MyDaTies = new ObservableCollection<Tiersp>(curOrga.Tiersps.ToList());

                // Convert to EntPerson list for the grid
                Persons = ModelHelper.MapListTo<Tiersp, EntPerson>(MyDaTies);

                if (Persons.Any())
                {
                    curPerson = Persons.FirstOrDefault();
                }
            }
            else
            {
                Console.WriteLine("Tiersps null/empty - initializing empty collections");
                MyDaTies = new ObservableCollection<Tiersp>();
                Persons = new List<EntPerson>();
            }
            if (LsPcols.Any())
            {
                string StrStore = LsPcols.FirstOrDefault().Fgsrc; //ColName;IsVisible;
                List<LSelCol> Pcolumns = ColsPreferences.DeserializePreferences(StrStore);
                Console.WriteLine($"nb cols {Pcolumns.Count} et {StrStore}");
                TiwVisibility = Pcolumns.ToDictionary(tc => tc.ColName, tc => tc.IsVisible);
            }
            Console.WriteLine($"totyp {Ugpe} et cols Tiw in : {LsPcols?.Count} et visibles : {TiwVisibility?.Values?.Count}");
            foreach (var uco in TiwVisibility)
            {
                Console.WriteLine($"col: {uco.Key} visible: {uco.Value}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Child crash: {ex.Message}");
            Console.WriteLine($"Stack: {ex.StackTrace}");  // 🔥 More debug info
            Imessage = $"Erreur chargement: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
