        curPerson = ModelHelper.MapTo<Tieafl, EntPerson>(item);

        StartRowEdit(rowguid, EntityLevel.Rub);
    }
    private async Task TieatSaveAsync()
    {
        foreach (var atr in curTie.Tieatrs)
        {
            if (atr.AtState == AEntState.NewAdded)
            {
                curODContext.AddObject("tieatrs", atr);  // Tracks + prepares INSERT
                Console.WriteLine($"➕ NEW {typeof(Tieatr).Name} → AddObject");
            }
            else
            {
                curODContext.SafeAttachOrUpdate(atr, "tieatrs", false);  // Your method!
                Console.WriteLine($"✏️ EXISTING → SafeAttachOrUpdate");
            }
            curODContext.UpdateObject(atr);
            Console.WriteLine($"✅ {typeof(Tieatr).Name} confirmed → tracked");
        }
    }
