    private void CancelRubNew(Tiersp parentTiw)
    {
        if (draftRub == null) return;

        // Remove the draft from the domain collection if it was inserted
        var existing = parentTiw.Tieafls?.FirstOrDefault(r => r.Rowguid == draftRub.Rowguid);
        if (existing != null)
        {
            parentTiw.Tieafls.Remove(existing);
        }

        // Clear row state and UI hints
        // ClearRowState(draftRub.Rowguid);
        // Reset row state
        SetRowState(draftRub.Rowguid, RowState.Normal);
        SetLightBackground(draftRub.Rowguid, false);

        // Reset draft variables
        draftRub = null;
        draftAfls = null;
        EdRubRowguid = null;
        isAddRub = false;
        isEdtRub = false;

        // Refresh grid data source
        Affiles = ModelHelper.MapListTo<Tieafl, EntPerson>(parentTiw.Tieafls);

        RubRenderKey = Guid.NewGuid(); // force re-render
        StateHasChanged();

        Console.WriteLine("✖ Cancelled new child record.");
    }

    private async Task StartRubNew(Tiersp parentTiw, int rubType)
    {
        //Ensure parent is persisted before adding children
        if (parentTiw.Id <= 0)
        {
            Imessage = "🚫 Cannot add Affilie: Candidat must be saved first.";
            return;
        }

        Console.WriteLine("🚨 StartRubNew");

        // Compute next sequence
        var nextSeq = NextSeq(parentTiw.Tieafls, p => p.Iui);

        // Create new Rubrique
        var newRub = new Tieafl
        {
            Rowguid = Guid.NewGuid(),
            Itie = parentTiw.Id,
            Ttyp = Ugpe,
            Tyafl = rubType,
            Irang = nextSeq,
            Nom = "Fils Martin",
            Pnom = "Ilboudo",
            Datc = DateTime.Now,
            Liba = "",
            Abg = "",
            Eta = 1,
            Xadd1 = -1, // newly added
            Xedt1 = 0,
            Xdel1 = 0
        };
        // Row state + UI hints
        SetRowState(newRub.Rowguid, RowState.AddPending);
        SetLightBackground(newRub.Rowguid, true);

        // Ensure child collection exists
        if (parentTiw.Tieafls == null)
            parentTiw.Tieafls = new DataServiceCollection<Tieafl>();

        // Insert into domain collection
        parentTiw.Tieafls.Insert(0, newRub);



        // Refresh grid data source
        Affiles = ModelHelper.MapListTo<Tieafl, EntPerson>(parentTiw.Tieafls);
        GMode = GridMode.AflsAdding;

        draftRub = (Tieafl)DeepClone(newRub);
        draftAfls = ModelHelper.MapTo<Tieafl, EntPerson>(draftRub);
        draftAfls.Rowguid = draftRub.Rowguid; // ensure Rowguid is copied

        EdRubRowguid = draftRub.Rowguid;
        isAddRub = true;
        isEdtRub = true;

        SetRowState(draftRub.Rowguid, RowState.EditPending);
        RubRenderKey = draftRub.Rowguid;

        Console.WriteLine($"✅ New row added to curOrga.Tiersps - Count: {parentTiw.Tieafls.Count}");
        curRubr = newRub;

        StartRowEdit(draftRub.Rowguid, EntityLevel.Rub);
        StateHasChanged();
    }
    private async Task StartTiwEdit(Tiersp item, Guid rowguid)
    {
        var isNew = StaticMethods.IsNew(curODContext, item, e => e.Id);
        if (isNew)
        { //not saved yet
            Imessage = "🚫 Cannot edit new Plan: Please save it first.";
            return;
        }
        if (rowguid == Guid.Empty) return;
        item.Xedt1 = -1;
        if (item.Iele != 0) item.Iui = (int)item.Iele;
        SetRowState(rowguid, RowState.EditPending);  // Shows Confirm/Cancel buttons
        _edPlnOriginals[rowguid] = (Tiersp)DeepClone(item);
        EdTiwRowguid = AllowMultipleEdits ? null : rowguid;
        draftTiw = (Tiersp)DeepClone(item);
        isEdtTiw = true;
        StartRowEdit(rowguid, EntityLevel.Plan);
        //StateHasChanged();
    }
