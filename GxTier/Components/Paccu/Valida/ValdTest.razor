@page "/valdtest"

@layout EnrolMenu

@using System
@using System.Collections.ObjectModel
@using System.ComponentModel.DataAnnotations
@using System.Dynamic
@using System.Net.Http.Headers
@using System.Security.Claims
@using System.Reflection
@using System.Text
@using System.Text.Json
@using System.Web
@using BlazorBootstrap
@using GxShared.Sess
@using GxShared.Others
@using GxShared.Helpers
@using GxTie.ClieModels
@using GxTie.Services
@using GxTie.Components.Paccu
@using GxTie.Components.Paccu.RtPer
@using GxTie.Components.FrmHelper

@using GxWapi.DaModels
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.OData.Client
@using Newtonsoft.Json

@inject NavigationManager _navmanager
@inject HttpClientService _clieManager
@inject RendAgres _rendAgres
@inject IMessageService _messageService

<PageTitle>Saisie.Enrollement</PageTitle>
<h3>Validation Workflow</h3>

<MainGridHelper TEntity="Tiersp"
                Draft="@draftTiersp"
                TbItems="@optionItems"
                Visibility="@fieldVisibility"
                Mode="@mode" />

<div class="mt-3">
    <button class="btn btn-primary" @onclick="SaveDraft">Save</button>
    <button class="btn btn-secondary" @onclick="CancelDraft">Cancel</button>
</div>

@code {
    private Tiersp draftTiersp = new();
    private List<Gptbl> optionItems = new();
    private Dictionary<string, bool> fieldVisibility = new();
    private string mode = "Add"; // or "Edit", "View"

    protected override async Task OnInitializedAsync()
    {
        // Load options from service
        optionItems = await LoadOptionsAsync();

        // Configure visibility
        fieldVisibility["Dossier"] = true;
        fieldVisibility["Statut"] = true;
        fieldVisibility["Rpays"] = true;
    }

    private async Task<List<Gptbl>> LoadOptionsAsync()
    {
        // Example: call API or service
        return new List<Gptbl>
        {
            new Gptbl { Pxcod = 11, Elea = 1, Liba = "France" },
            new Gptbl { Pxcod = 11, Elea = 2, Liba = "Burkina Faso" },
            new Gptbl { Pxcod = 31, Abg = "FR", Liba = "France" },
            new Gptbl { Pxcod = 31, Abg = "BF", Liba = "Burkina Faso" }
        };
    }

    private void SaveDraft()
    {
        // Persist draftTiersp to backend
        Console.WriteLine($"Saving entity with Statut={draftTiersp.Statut}, Rpays={draftTiersp.Rpays}");
        mode = "View"; // switch to view mode after save
    }

    private void CancelDraft()
    {
        // Reset or discard changes
        draftTiersp = new Tiersp();
        mode = "View";
    }
}