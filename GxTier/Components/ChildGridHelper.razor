@code {
    [Parameter] public IEnumerable<EntPerson> FilteredData { get; set; } = Enumerable.Empty<EntPerson>();
    [Parameter] public Dictionary<string, bool> Visibility { get; set; } = new();
    [Parameter] public string RenderKey { get; set; } = "";

    [Parameter] public Guid? EdRowguid { get; set; }
    [Parameter] public EntPerson? DraftEntity { get; set; }
    [Parameter] public EntPerson? SelectedEntity { get; set; }

    [Parameter] public int? SelectedGroup { get; set; }

    [Parameter] public IEnumerable<dynamic> TbItems { get; set; } = Enumerable.Empty<dynamic>();

    // Actions passed in from parent
    [Parameter] public EventCallback<EntPerson> ConfirmEdit { get; set; }
    [Parameter] public EventCallback<EntPerson> CancelEdit { get; set; }
    [Parameter] public EventCallback<EntPerson> ConfirmDelete { get; set; }
    [Parameter] public EventCallback<EntPerson> CancelDelete { get; set; }
    [Parameter] public EventCallback<EntPerson> StartRubEdit { get; set; }
    [Parameter] public EventCallback<Guid> StartRowDelete { get; set; }

    private bool IsEditingRow(EntPerson entity, Guid? edRowguid, EntPerson? draftEntity)
        => entity.Rowguid == edRowguid && draftEntity != null;

    [Parameter] public Dictionary<Guid, RowState> RowStates { get; set; } = new();

    private RowState ResolveRowState(Guid rowguid)
        => RowStates.TryGetValue(rowguid, out var state) ? state : RowState.Normal;

}

