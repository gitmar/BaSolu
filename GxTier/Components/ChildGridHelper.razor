            if (EdRowguid == null || DraftEntity == null)
            {
                continue;
            }
            var isGridEditing = IsEditingRow(entity, EdRowguid, DraftEntity);
            <!-- Row‑dependent actions -->
           @*  <div class="d-flex align-items-center gap-2">
                @switch (ResolveRowState(entity.Rowguid))
                {
                    case RowState.EditPending:
                        <Button @onclick="() => ConfirmEdit.InvokeAsync(entity)">✅ Confirm</Button>
                        <Button @onclick="() => CancelEdit.InvokeAsync(entity)">❌ Cancel</Button>
                        break;
                    case RowState.DeletePending:
                        <Button @onclick="() => ConfirmDelete.InvokeAsync(entity)">⚠️ Confirm</Button>
                        <Button @onclick="() => CancelDelete.InvokeAsync(entity)">❎ Cancel</Button>
                        break;
                    case RowState.Locked:
                        <span class="text-muted">🔒 Locked</span>
                        break;
                    default:
                        <Button @onclick="() => StartRubEdit.InvokeAsync(entity)">✏️ Edit</Button>
                        <Button @onclick="() => StartRowDelete.InvokeAsync(entity.Rowguid)">🗑 Delete</Button>
                        break;
                }
            </div> *@
            <!-- FIELD 3: Nom -->
            @if (Visibility.GetValueOrDefault("Nom", true))
            {
                <div class="row mb-2">
                    <label class="fw-bold col-md-3 col-form-label text-nowrap">Nom:</label>
                    @if (isGridEditing)
                    {
                        <InputText @bind-Value="entity.Nom" class="form-control col-md-9" />
