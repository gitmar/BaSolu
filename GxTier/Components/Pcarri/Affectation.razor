    private void PrepListAffecs(int? hie)
    {
        var LsTies = curOrga.Tiersps?.ToList();//.Where(t => t.Ihie == hie).ToList();
        //prepalignes
        DaTiemvlnes = new();
        foreach(var tie in LsTies)
