<Grid TItem="TiemvlneDto" 
    Data="@DaTiemvlnes" 
    AllowPaging="true" 
    AllowSelection="true"
    SelectionMode="GridSelectionMode.Multiple"
    @bind-SelectedItems="@SelDaTiemvs"
    Responsive="true">
    <GridColumns>
        <GridColumn TItem="TiemvlneDto" HeaderText="Matricule" Class="xcol1">
            <ChildContent Context="line">
                @line.Smatri
            </ChildContent>
        </GridColumn>
        <GridColumn TItem="TiemvlneDto" HeaderText="Nom - Prenom(s)" Class="xcol4">
            <ChildContent Context="line">
                @line.Nom - @line.Pnom
            </ChildContent>
        </GridColumn>
        <GridColumn TItem="TiemvlneDto" HeaderText="Ancien Poste" Class="xcol1">
            <ChildContent Context="line">
                <InputSelect @bind-Value="line.Froloc" disabled>
                    @foreach (var loc in OriginLocations.ToList())
                    {
                        <option value="@loc.Ipst">@loc.Liba</option>
                    }
                    </InputSelect>
            </ChildContent>
        </GridColumn>
        <GridColumn TItem="TiemvlneDto" HeaderText="Nouv. Division" Class="xcol2">
            <ChildContent Context="line">
                <InputSelect @bind-Value="line.Nwhie">
                    @foreach (var dep in LsDivs.Where(d => d.Pdom == 1)) //adm
                    {
                        <option value="@dep.Ihie">@dep.Liba</option>
                    }
                </InputSelect>
            </ChildContent>
        </GridColumn>
        <GridColumn TItem="TiemvlneDto" HeaderText="Nouv. Poste" Class="xcol1">
            <ChildContent Context="line">
                <InputSelect @bind-Value="line.Toloc">  
                    @foreach (var loc in DestinationLocations.ToList())
                    {
                       <option value="@loc.Ipst">@loc.Liba</option>
                    }
                </InputSelect>
            </ChildContent>
        </GridColumn>
    </GridColumns>
</Grid>
<div class="mt-3">
    Nb. Selected Persons : @SelDaTiemvs.Count
    @if (SelDaTiemvs.Count > 0)
    {
        <Button Color="ButtonColor.Success" @onclick="() => ConfirmMuta()">Confirmer</Button>
    }
</div>
<style>
    .xcolx {
        width: 40px !important;
    }

    .xcol1 {
        width: 60px;
    }

    .xcol2 {
        width: 120px;
    }

    .xcol3 {
        width: 180px;
    }

    .xcol4 {
        width: 240px;
    }
        /* Ensure inputs inside these columns fill the width */
        .xcol1 input,
        .xcol2 input,
        .xcol3 input,
        .xcol4 input {
            width: 100%;
            box-sizing: border-box; /* prevents overflow due to padding/border */
        }

    .editing-row {
        pointer-events: none; /* Blocks all clicks on row */
    }

        .editing-row * {
            pointer-events: auto; /* Re-enables clicks on buttons/inputs */
        }
</style>

