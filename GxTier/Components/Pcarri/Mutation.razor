@page "/items-transfer"

@using System.Security.Claims
@using BlazorBootstrap
@using Blazored.LocalStorage
@using GxTie.ClieModels
@using GxTie.Components.Pcarri
@using GxTie.Services
@using GxTie.StaticHelpers
@using GxShared.Sess
@using Microsoft.EntityFrameworkCore;
@using Simple.OData.Client
@using GxShared.GxDtos
@using GxShared.Interfaces
@using Newtonsoft.Json

@* @implements IDisposable *@

@inject NavigationManager _navManager
@inject ILocalStorageService _localStorage
@inject HttpClientService _clieManager
@inject SessionContextService _sessionContext
@inject RendAgres _rendAgres
@inject IJSRuntime _JsRUN
@inject IMessageService _messageService

<h3>External Transfer</h3>

<!-- Transfer header -->
<div class="mb-3">
    <label>Origin Department</label>
    <InputSelect @bind-Value="curTransfer.Fromhie">
        @foreach (var dep in Departments)
        {
            <option value="@dep.Ihie">@dep.Liba</option>
        }
    </InputSelect>

    <label>Destination Department</label>
    <InputSelect @bind-Value="curTransfer.Tohie">
        @foreach (var dep in Departments)
        {
            <option value="@dep.Ihie">@dep.Liba</option>
        }
    </InputSelect>

    <label>Date</label>
    <InputDate @bind-Value="curTransfer.Tdate" />
    <label>Type</label>
    <InputSelect @bind-Value="curTransfer.Ttype">
        <option value="1">Exter</option>
    </InputSelect>
</div>

<Button Color="ButtonColor.Success" @onclick="() => StartAdd()">Add New Line</Button>

<Grid TItem="StktflneDto" Data="@curTransfer.Stktflnes" AllowPaging="true" Responsive="true">
    <GridColumns>
        <GridColumn TItem="StktflneDto" HeaderText="Item">
            <ChildContent Context="line">
                @if (editRowguid == line.Rowguid)
                {
                    <InputSelect @bind-Value="draftLine.Iitu">
                        @foreach (var item in DaItems)
                        {
                            <option value="@item.Id">@item.Liba</option>
                        }
                    </InputSelect>
                }
                else
                {

                    @DaItems.FirstOrDefault(i => i.Id == line.Iitu)?.Liba
                }
            </ChildContent>
        </GridColumn>

        <GridColumn TItem="StktflneDto" HeaderText="From Location">
            <ChildContent Context="line">
                @if (editRowguid == line.Rowguid)
                {
                    <InputSelect @bind-Value="draftLine.Froloc">
                        @foreach (var loc in OriginLocations.Where(od => od.Ihie == curTransfer.Fromhie).ToList())
                        {
                            <option value="@loc.Ipst">@loc.Liba</option>
                        }
                    </InputSelect>
                }
                else
                {

                    @OriginLocations.FirstOrDefault(l => l.Ipst == line.Froloc)?.Liba
                }
            </ChildContent>
        </GridColumn>

        <GridColumn TItem="StktflneDto" HeaderText="To Location">
            <ChildContent Context="line">
                @if (editRowguid == line.Rowguid)
                {
                    <InputSelect @bind-Value="draftLine.Toloc">
                        @foreach (var loc in DestinationLocations.Where(od => od.Ihie == curTransfer.Tohie).ToList())
                        {
                            <option value="@loc.Ipst">@loc.Liba</option>
                        }
                    </InputSelect>
                }
                else
                {
                    @DestinationLocations.FirstOrDefault(l => l.Ipst == line.Toloc)?.Liba
                }
            </ChildContent>
        </GridColumn>

        <GridColumn TItem="StktflneDto" HeaderText="Quantity">
            <ChildContent Context="line">
                @if (editRowguid == line.Rowguid)
                {
                    <InputNumber @bind-Value="draftLine.Qty" />
                }
                else
                {

                    @line.Qty
                }
            </ChildContent>
        </GridColumn>

        <GridColumn TItem="StktflneDto" HeaderText="Batch">
            <ChildContent Context="line">
                @if (editRowguid == line.Rowguid)
                {
                    <InputNumber @bind-Value="draftLine.Ibtch" />
                }
                else
                {

                    @line.Ibtch
                }
            </ChildContent>
        </GridColumn>

        <GridColumn TItem="StktflneDto" HeaderText="Actions">
            <ChildContent Context="line">
                @if (editRowguid == line.Rowguid)
                {
                    <Button Color="ButtonColor.Primary" @onclick="() => SaveEdit(line)">Save</Button>
                    <Button Color="ButtonColor.Secondary" @onclick="() => CancelEdit()">Cancel</Button>
                }
                else
                {
                    <Button Color="ButtonColor.Warning" @onclick="() => StartEdit(line)">Edit</Button>
                    <Button Color="ButtonColor.Danger" @onclick="() => DeleteLine(line)">Delete</Button>
                }
            </ChildContent>
        </GridColumn>
    </GridColumns>
</Grid>
@if (isAdding)
{
    <div class="mt-3">
        <h5>New Transfer Line</h5>
        <InputSelect @bind-Value="draftLine.Iitu">
            @foreach (var item in DaItems)
            {
                <option value="@item.Id">@item.Liba</option>
            }
        </InputSelect>
        <InputSelect @bind-Value="draftLine.Froloc">
            @foreach (var loc in OriginLocations)
            {
                <option value="@loc.Ipst">@loc.Liba</option>
            }
        </InputSelect>
        <InputSelect @bind-Value="draftLine.Toloc">
            @foreach (var loc in DestinationLocations)
            {
                <option value="@loc.Ipst">@loc.Liba</option>
            }
        </InputSelect>
        <InputNumber @bind-Value="draftLine.Qty" placeholder="Quantity" />
        <InputNumber @bind-Value="draftLine.Ibtch" placeholder="Batch" />
        <Button Color="ButtonColor.Success" @onclick="() => SaveAdd()">Add</Button>
        <Button Color="ButtonColor.Secondary" @onclick="() => CancelAdd()">Cancel</Button>
    </div>
}


@code {
    [Parameter] public IODataClient _InODaClient { get; set; }
    [Parameter] public GxorgaDto curOrga { get; set; }
    [Parameter]
    public List<Gpdivh> LsDivs { get; set; }
    [Parameter] public MyShareVars toChild { get; set; }
    [Parameter] public int toMenu { get; set; }
    //[Parameter] public StockClientService stockService { get; set; }
    //[Parameter] public ItemClientService itemService { get; set; }
    [Parameter] public IPendingChangesGuard _guard { get; set; }
    [Parameter] public EventCallback<PendingState> OnPendingStateChanged { get; set; }
    [Parameter] public int NbChanges { get; set; }
    [Parameter] public EventCallback<int> NbChangesChanged { get; set; }

    private StktrsfDto curTransfer = new();
    private StktflneDto draftLine = new();
    private Guid? editRowguid;
    private bool isAdding = false;

    private List<StkituDto> DaItems = new();
    private List<Gpdivh> Departments = new();
    //private List<Gpdivh> OriginLocations = new();
    //private List<Gpdivh> DestinationLocations = new();

    private List<Divpst> OriginLocations =>
    LsDivs.Where(d => d.Ihie == curTransfer.Fromhie)
          .FirstOrDefault()?
          .Divpsts?.ToList() ?? new List<Divpst>();

    private List<Divpst> DestinationLocations =>
        LsDivs.Where(d => d.Ihie == curTransfer.Tohie)
              .FirstOrDefault()?
              .Divpsts?.ToList() ?? new List<Divpst>();
    protected override async Task OnInitializedAsync()
    {
        DaItems = curOrga.Stkitus?.ToList() ?? new();
        Departments = LsDivs; //await stockService.GetDepartmentsAsync();
        //Warehouses = await stockService.GetWarehousesAsync();

        curTransfer.Rowguid = Guid.NewGuid();
        curTransfer.Tdate = DateTime.Now;
        curTransfer.Ttype = 1; // Exter
        curTransfer.Stktflnes = new();
    }

    private void StartAdd() { isAdding = true; draftLine = new StktflneDto(); }

    private async Task SaveAdd()
    {
        draftLine.Rowguid = Guid.NewGuid();
        draftLine.Itrsf = curTransfer.Id;
        // Register add with OData
        _guard.TrackInsert("Stktflnes", draftLine);
        curTransfer.Stktflnes.Add(draftLine);
        isAdding = false;
        await NotifyPendingChanges();
    }

    private void CancelAdd() => isAdding = false;

    private void StartEdit(StktflneDto line)
    {
        editRowguid = line.Rowguid;
        draftLine = new StktflneDto { Rowguid = line.Rowguid, Iitu = line.Iitu, Qty = line.Qty, Ibtch = line.Ibtch, Froloc = line.Froloc, Toloc = line.Toloc };
    }

    private async Task SaveEdit(StktflneDto line)
    {
        line.Iitu = draftLine.Iitu;
        line.Qty = draftLine.Qty;
        line.Ibtch = draftLine.Ibtch;
        line.Froloc = draftLine.Froloc;
        line.Toloc = draftLine.Toloc;
        // Register update with OData context
        var key = GetEntityKey(line); // helper to extract PK
        _guard.TrackUpdate("Stktflnes", key, line);
        editRowguid = null;
        await NotifyPendingChanges();
    }
    private object GetEntityKey<TDto>(TDto entity)
    {
        switch (entity)
        {
            case StktflneDto pln:
                return pln.Id;
            //case TiwaflDto rub:
            //    return rub.Id;
            //case RubfmtDto fmt:
            //    return fmt.Id;
            default:
                throw new InvalidOperationException($"Unknown entity type {typeof(TDto).Name}");
        }
    }
    private void CancelEdit() => editRowguid = null;

    private async Task DeleteLine(StktflneDto line)
    {
        curTransfer.Stktflnes.Remove(line);
        // Register delete with OData context
        var key = GetEntityKey(line);
        _guard.TrackDelete("Stktflnes", key);

        await NotifyPendingChanges();
    }

    private async Task NotifyPendingChanges()
    {
        await OnPendingStateChanged.InvokeAsync(new PendingState(_guard.HasPendingChanges(), _guard.GetPendingChangesCount()));
        NbChanges = _guard.GetPendingChangesCount();
        await NbChangesChanged.InvokeAsync(NbChanges);
        StateHasChanged();
    }

    // public async Task SaveAllChanges() { await curODContext.SaveChangesAsync(); await NotifyPendingChanges(); }
    // public void CancelAllChanges() { _guard.RejectAllChanges(); NotifyPendingChanges(); }
}
