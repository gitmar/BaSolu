@using GxStk.Services
@using GxShared.Sess
@using System.Security.Claims
@using BlazorBootstrap

@inject NavigationManager _navManager

<div class="top-row mb-0 navbar navbar-dark bg-success shadow-sm bg-opacity-25 mt-0 navbar-slim">
    <a class="navbar-brand text-white fw-bold d-flex align-items-center gap-1" href="">
        <i class="bi bi-gear-fill"></i>
        <span>Gx-Solutions</span>
    </a>
    <button class="navbar-toggler btn btn-sm" type="button" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>

<div class="@NavMenuCssClass bg-dark text-light vh-100" style="overflow-y: auto;">
    <nav class="nav flex-column">

        <!-- HOME -->
        <NavLink class="nav-link nav-main text-light small" href="" Match="NavLinkMatch.All">
            <i class="bi bi-house-door-fill nav-icon"></i>
            <span class="nav-text" title="Home">Home</span>
        </NavLink>

        <AuthorizeView>
            <Authorized>

                <!-- Parametrage -->
                <NavLink class="nav-link nav-main text-light small" @onclick="ToggleSubPara">
                    <i class="bi bi-sliders nav-icon"></i>

                    <span class="nav-text d-flex align-items-center gap-1">
                        Parametrage
                        <i class="bi @(isSubParaVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                    </span>
                </NavLink>

                <div class="submenu @(isSubParaVisible ? "open" : "")">
                    <nav class="nav flex-column">
                        <NavLink class="nav-link nav-sub text-light small" href="parasmenu">
                            <i class="bi bi-calendar-check nav-icon"></i>
                            <span class="nav-text" title="Astreintes">Astreintes</span>
                        </NavLink>
                    </nav>
                </div>

                <!-- Mouvements -->
                <NavLink class="nav-link nav-main text-light small" @onclick="ToggleSubMove">
                    <i class="bi bi-arrow-left-right nav-icon"></i>

                    <span class="nav-text d-flex align-items-center gap-1">
                        Mouvement
                        <i class="bi @(isSubMoveVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                    </span>
                </NavLink>

                <div class="submenu @(isSubMoveVisible ? "open" : "")">
                    <nav class="nav flex-column">
                        <NavLink class="nav-link nav-sub text-light small" href="entrymenu">
                            <i class="bi bi-shuffle nav-icon"></i>
                            <span class="nav-text" title="Entrees">Entrees</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small" href="transfmenu">
                            <i class="bi bi-shuffle nav-icon"></i>
                            <span class="nav-text" title="Affectation">Affectation</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small" href="corrigmenu">
                            <i class="bi bi-pencil-square nav-icon"></i>
                            <span class="nav-text" title="Correction">Correction</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small" href="offlinemanager">
                            <i class="bi bi-pencil-square nav-icon"></i>
                            <span class="nav-text" title="Offline">Offline</span>
                        </NavLink>
                    </nav>
                </div>

                <!-- Transactions -->
                <NavLink class="nav-link nav-main text-light small" @onclick="ToggleSubTrans">
                    <i class="bi bi-cash-stack nav-icon"></i>

                    <span class="nav-text d-flex align-items-center gap-1">
                        Transactions
                        <i class="bi @(isSubTransVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                    </span>
                </NavLink>

                <div class="submenu @(isSubTransVisible ? "open" : "")">
                    <nav class="nav flex-column">
                        <NavLink class="nav-link nav-sub text-light small" href="appromenu">
                            <i class="bi bi-box-arrow-in-down nav-icon"></i>
                            <span class="nav-text" title="Approv">Approv</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small" href="ventemenu">
                            <i class="bi bi-cart-check nav-icon"></i>
                            <span class="nav-text" title="Ventes">Ventes</span>
                        </NavLink>
                    </nav>
                </div>

                <!-- Editions -->
                <NavLink class="nav-link nav-sub text-light small" href="subitem3">
                    <i class="bi bi-printer nav-icon"></i>
                    <span class="nav-text" title="Editions">Editions</span>
                </NavLink>

                <!-- Analyses -->
                <NavLink class="nav-link nav-main text-light small" href="about">
                    <i class="bi bi-bar-chart-line nav-icon"></i>
                    <span class="nav-text" title="Analyses">Analyses</span>
                </NavLink>

                <!-- Support -->
                <NavLink class="nav-link nav-main text-light small" href="about">
                    <i class="bi bi-life-preserver nav-icon"></i>
                    <span class="nav-text" title="Support">Support</span>
                </NavLink>

            </Authorized>
        </AuthorizeView>

        <!-- Agendas -->
        <NavLink class="nav-link nav-main text-light small" href="about">
            <i class="bi bi-calendar3 nav-icon"></i>
            <span class="nav-text" title="Agendas">Agendas</span>
        </NavLink>

        <!-- About -->
        <NavLink class="nav-link nav-main text-light small" href="about">
            <i class="bi bi-info-circle nav-icon"></i>
            <span class="nav-text" title="About">About</span>
        </NavLink>

    </nav>
</div>

<style>
    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        line-height: 1.2;
        flex-wrap: nowrap;
    }

    /* ICON COLUMN */
    .nav-icon {
        width: 22px;
        min-width: 22px;
        text-align: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    /* TEXT */
    .nav-text {
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* CHEVRON */
    .nav-chevron {
        font-size: 0.7rem;
        opacity: 0.7;
        flex-shrink: 0;
    }

    /* SUBMENU */
    .submenu {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.25s ease;
        margin-left: 10px;
        padding-left: 1rem;
        border-left: 1px solid rgba(255,255,255,0.1);
    }

        .submenu.open {
            max-height: 500px;
        }

    /* SUB ITEMS */
    .nav-sub {
        font-size: 0.85rem;
        opacity: 0.9;
    }
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }
    private ClaimsPrincipal authUser;
    private bool isAuthenticated = false;
    private bool success, errors, isSubmitting = false;
    private string[] errorList = [];
    private bool collapseNavMenu = false;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private bool siOpera=false, siAdmin = false, siStock = true;
    private int IMyAcc = 2;
    private bool isSubParaVisible = false;
    private bool isSubRecepVisible = false;
    private bool isSubMoveVisible = false;
    private bool isSubTransVisible = false;
    
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        authUser = authState.User;
        isAuthenticated = authUser.Identity.IsAuthenticated;
        if (!isAuthenticated)
        {
            Console.WriteLine("Authentication Utilisateur ECHEC");
            return;
        }
        else
        {
            Console.WriteLine("Authentication MainMenu SUCCESS");
        }
        //_appState.OnChange += StateHasChanged;
    }
    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
    private void ToggleSubPara()
    {
        isSubParaVisible = !isSubParaVisible;
    }
    private void ToggleSubRecep()
    {
        isSubRecepVisible = !isSubRecepVisible;
    }
    private void ToggleSubMove()
    {
        isSubMoveVisible = !isSubMoveVisible;
    }
    private void ToggleSubTrans()
    {
        isSubTransVisible = !isSubTransVisible;
    }
    
    private bool Entest = false;
    public void Dispose()
    {
        //_appState.OnChange -= StateHasChanged;
    }
}
