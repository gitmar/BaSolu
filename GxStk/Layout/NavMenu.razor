@using GxStk.Services
@using GxShared.Sess
@using System.Security.Claims
@using BlazorBootstrap

@inject NavigationManager _navManager

<div class="top-row navbar navbar-dark navbar-slim d-flex gap-1 shadow-sm
    m-0 p-0 justify-content-start align-items-start" style="min-height:32px; background: linear-gradient(180deg, rgb(5, 39, 103) 0%, #3a0647 70%);">

    <a class="navbar-brand text-white fw-bold m-0 p-1" href="">
        <i class="bi bi-gear-fill"></i>
        <span>Gx-Solutions</span>
    </a>
    <button class="navbar-toggler btn btn-sm ms-auto p-1 m-0"
            type="button"
            @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>

</div>

<div class="@NavMenuCssClass vh-100" style="overflow-y: auto;">
    <nav class="nav flex-column">

        <!-- HOME -->
        <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2" href="" Match="NavLinkMatch.All">
            <i class="bi bi-house-door-fill nav-icon d-inline-flex align-items-center"></i>
            <span class="nav-text" title="Home">Home</span>
        </NavLink>

        <AuthorizeView>
            <Authorized>

                <!-- PARAMÉTRAGE -->
                <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2"
                         @onclick="ToggleSubPara">
                    <i class="bi bi-sliders nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text">Paramétrage</span>
                    <i class="bi @(isSubParaVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                </NavLink>
                <div class="submenu @(isSubParaVisible ? "open" : "")">
                    <nav class="nav flex-column">
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="accsmenu">
                            <i class="bi bi-clock-history nav-icon"></i>
                            <span class="nav-text" title="Sessions">Sessions</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="parasmenu">
                            <i class="bi bi-calendar-check nav-icon"></i>
                            <span class="nav-text" title="Astreintes">Astreintes</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="offlinemanager">
                            <i class="bi bi-pencil-square nav-icon"></i>
                            <span class="nav-text" title="Offline">Offline</span>
                        </NavLink>
                    </nav>
                </div>

                <!-- MOUVEMENTS -->
                <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2"
                         @onclick="ToggleSubMove">
                    <i class="bi bi-arrow-left-right nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text">Mouvement</span>
                    <i class="bi @(isSubMoveVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                </NavLink>
                <div class="submenu @(isSubMoveVisible ? "open" : "")">
                    <nav class="nav flex-column">
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="entrymenu">
                            <i class="bi bi-box-arrow-in-down nav-icon"></i>
                            <span class="nav-text" title="Entrées">Entrées</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="transfmenu">
                            <i class="bi bi-arrow-left-right nav-icon"></i>
                            <span class="nav-text" title="Affectation">Affectation</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="corrigmenu">
                            <i class="bi bi-pencil-square nav-icon"></i>
                            <span class="nav-text" title="Correction">Correction</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="subitem3">
                            <i class="bi bi-file-earmark-text nav-icon"></i>
                            <span class="nav-text" title="Editions">Editions</span>
                        </NavLink>
                    </nav>
                </div>

                <!-- TRANSACTIONS -->
                <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2"
                         @onclick="ToggleSubTrans">
                    <i class="bi bi-cash-stack nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text">Transactions</span>
                    <i class="bi @(isSubTransVisible ? "bi-chevron-up" : "bi-chevron-down") nav-chevron"></i>
                </NavLink>
                <div class="submenu @(isSubTransVisible ? "open" : "")">
                    <nav class="nav flex-column">
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="appromenu">
                            <i class="bi bi-box-seam nav-icon"></i>
                            <span class="nav-text" title="Approv">Approv</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="ventemenu">
                            <i class="bi bi-cart-check nav-icon"></i>
                            <span class="nav-text" title="Ventes">Ventes</span>
                        </NavLink>
                        <NavLink class="nav-link nav-sub text-light small d-flex align-items-center gap-2" href="subitem3">
                            <i class="bi bi-file-earmark-text nav-icon"></i>
                            <span class="nav-text" title="Editions">Editions</span>
                        </NavLink>
                    </nav>
                </div>

                <!-- ANALYSES -->
                <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2" href="about">
                    <i class="bi bi-bar-chart-line nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text" title="Analyses">Analyses</span>
                </NavLink>

                <!-- SUPPORT -->
                <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2" href="about">
                    <i class="bi bi-life-preserver nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text" title="Support">Support</span>
                </NavLink>

                <!-- AGENDA -->
                @* <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2" href="about">
                    <i class="bi bi-calendar3 nav-icon d-inline-flex align-items-center"></i>
                    <span class="nav-text" title="Agenda">Agenda</span>
                </NavLink> *@
            </Authorized>
        </AuthorizeView>

        <!-- ABOUT -->
        <NavLink class="nav-link nav-main text-light small d-flex align-items-center gap-2" href="about">
            <i class="bi bi-info-circle nav-icon d-inline-flex align-items-center"></i>
            <span class="nav-text" title="About">About</span>
        </NavLink>

    </nav>
</div>

<style>

    /* ICON COLUMN */
    .nav-icon {
        width: 22px;
        min-width: 22px;
        text-align: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        flex-wrap: nowrap;
    }

    .nav-text {
        flex: 0 1 auto;
        min-width: 0;
        white-space: nowrap;
    }

    .nav-chevron {
        font-size: 0.9rem;
        color: #ffea00; /* bright yellow */
        flex-shrink: 0;
    }

    /* SUBMENU */
    .submenu {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.25s ease;
        margin-left: 10px;
        padding-left: 1rem;
        border-left: 1px solid rgba(255,255,255,0.1);
    }

        .submenu.open {
            max-height: 500px;
        }

    /* SUB ITEMS */
    .nav-sub {
        font-size: 0.85rem;
        opacity: 0.9;
    }

    /* Slim navbar: remove Bootstrap’s default horizontal padding */

    /* Slim navbar: remove Bootstrap’s default horizontal padding */
    .top-row.navbar {
        padding-left: 0;
        padding-right: 0;
    }

    /* Ensure menu container is flush left */
    .bg-dark.vh-100 {
        padding-left: 0;
        margin-left: 0;
    }

    .navbar {
        padding-left: 0 !important;
        padding-right: 0 !important;
    }

    .navbar-brand {
        margin-left: 0 !important;
        margin-right: 0 !important;
    }
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }
    private ClaimsPrincipal authUser;
    private bool isAuthenticated = false;
    private bool success, errors, isSubmitting = false;
    private string[] errorList = [];
    private bool collapseNavMenu = false;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private bool siOpera=false, siAdmin = false, siStock = true;
    private int IMyAcc = 2;
    private bool isSubParaVisible = false;
    private bool isSubRecepVisible = false;
    private bool isSubMoveVisible = false;
    private bool isSubTransVisible = false;
    
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        authUser = authState.User;
        isAuthenticated = authUser.Identity.IsAuthenticated;
        if (!isAuthenticated)
        {
            Console.WriteLine("Authentication Utilisateur ECHEC");
            return;
        }
        else
        {
            Console.WriteLine("Authentication MainMenu SUCCESS");
        }
        //_appState.OnChange += StateHasChanged;
    }
    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
    private void ToggleSubPara()
    {
        isSubParaVisible = !isSubParaVisible;
    }
    private void ToggleSubRecep()
    {
        isSubRecepVisible = !isSubRecepVisible;
    }
    private void ToggleSubMove()
    {
        isSubMoveVisible = !isSubMoveVisible;
    }
    private void ToggleSubTrans()
    {
        isSubTransVisible = !isSubTransVisible;
    }
    
    private bool Entest = false;
    public void Dispose()
    {
        //_appState.OnChange -= StateHasChanged;
    }
}
