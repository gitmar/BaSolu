@page "/items-attribute"
@using GxWapi.DaModels
@using GxShared.Helpers
@using GxStk.Services
@using GxStk.ClieModels
@using GxShared.Sess
@using Microsoft.EntityFrameworkCore;

<div class="container mt-3">
    <h4>Stock Attributes</h4>

    <Button Color="ButtonColor.Success" @onclick="() => StartAdd()">Add New Attribute</Button>

    <Grid TItem="Stkatr" Data="@curOrga?.Stkatrs" AllowPaging="true" Responsive="true">
        <GridColumns>
            <GridColumn TItem="Stkatr" HeaderText="Id" Class="xcol1">
                <ChildContent Context="item">@item.Id</ChildContent>
            </GridColumn>
            <GridColumn TItem="Stkatr" HeaderText="Label" Class="xcol3">
                <ChildContent Context="item">
                    @if (editRowguid == item.Rowguid)
                    {
                        <InputText @bind-Value="draftAtr.Liba" />
                    }
                    else
                    {
                        @item.Liba
                    }
                </ChildContent>
            </GridColumn>
            <GridColumn TItem="Stkatr" HeaderText="Type" Class="xcol2">
                <ChildContent Context="item">
                    @if (editRowguid == item.Rowguid)
                    {
                        <InputNumber @bind-Value="draftAtr.Atyp" />
                    }
                    else
                    {
                        @item.Atyp
                    }
                </ChildContent>
            </GridColumn>
            <GridColumn TItem="Stkatr" HeaderText="Actions">
                <ChildContent Context="item">
                    @if (editRowguid == item.Rowguid)
                    {
                        <Button Color="ButtonColor.Primary" Size="ButtonSize.Small"
                                @onclick="() => SaveEdit(item)">
                            Save
                        </Button>
                        <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small"
                                @onclick="() => CancelEdit()">
                            Cancel
                        </Button>
                    }
                    else
                    {
                        <Button Color="ButtonColor.Warning" Size="ButtonSize.Small"
                                @onclick="() => StartEdit(item)">
                            Edit
                        </Button>
                        <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                @onclick="() => DeleteAttribute(item)">
                            Delete
                        </Button>
                    }
                </ChildContent>
            </GridColumn>
        </GridColumns>
    </Grid>

    @if (isAdding)
    {
        <div class="mt-3">
            <h5>New Attribute</h5>
            <InputText @bind-Value="draftAtr.Liba" placeholder="Label" />
            <InputNumber @bind-Value="draftAtr.Atyp" placeholder="Type" />
            <Button Color="ButtonColor.Success" @onclick="() => SaveAdd()">Add</Button>
            <Button Color="ButtonColor.Secondary" @onclick="() => CancelAdd()">Cancel</Button>
        </div>
    }
</div>

@code {
    [Parameter] public MyODataContext curODContext { get; set; }
    [Parameter] public Gxorga curOrga { get; set; }
    [Parameter] public MyShareVars toChild { get; set; }
    [Parameter] public int toMenu { get; set; }
    [Parameter] 
    public List<Gpdivh> LsDivs { get; set; }

    // Guard
    [Parameter] public PendingChangesGuard _guard { get; set; }
    [Parameter] public EventCallback<PendingState> OnPendingStateChanged { get; set; }
    [Parameter] public int NbChanges { get; set; }
    [Parameter] public EventCallback<int> NbChangesChanged { get; set; }

    // [Parameter] public ItemClientService ItemService { get; set; }
    // [Parameter] public StockClientService StockService { get; set; }

    private Guid? editRowguid;
    private bool isAdding = false;
    private Stkatr draftAtr = new();

    private void CancelAdd() => isAdding = false;

    private void StartEdit(Stkatr atr)
    {
        editRowguid = atr.Rowguid;
        draftAtr = new Stkatr { Id = atr.Id, Liba = atr.Liba, Atyp = atr.Atyp, Rowguid = atr.Rowguid };
    }

    private async Task SaveEdit(Stkatr atr)
    {
        atr.Liba = draftAtr.Liba;
        atr.Atyp = draftAtr.Atyp;

        // Register update with OData context
        curODContext.UpdateObject(atr);

        editRowguid = null;
        await NotifyPendingChanges();
    }

    private void CancelEdit() => editRowguid = null;

    private async Task DeleteAttribute(Stkatr atr)
    {
        curOrga.Stkatrs.Remove(atr);

        // Register delete with OData context
        curODContext.DeleteObject(atr);

        await NotifyPendingChanges();
    }

    private void StartAdd()
    {
        isAdding = true;
        draftAtr = new Stkatr();
    }

    private async Task SaveAdd()
    {
        draftAtr.Rowguid = Guid.NewGuid();

        // Register add with OData context
        curODContext.AddObject("Stkatrs", draftAtr);

        curOrga.Stkatrs.Add(draftAtr);
        isAdding = false;

        await NotifyPendingChanges();
    }

    // Notify guard/UI of pending changes
    private async Task NotifyPendingChanges()
    {
        await OnPendingStateChanged.InvokeAsync(new PendingState(
            _guard.HasPendingChanges(),
            _guard.GetPendingChangesCount()
        ));

        NbChanges = _guard.GetPendingChangesCount();
        await NbChangesChanged.InvokeAsync(NbChanges);
        StateHasChanged();
    }
}