@page "/items-unit"

@using GxShared.Helpers
@using GxStk.Services
@using GxShared.Helpers
@using GxShared.Sess
@using GxShared.GxDtos
@using GxShared.Interfaces
@using Simple.OData.Client
@using Microsoft.EntityFrameworkCore;

<div class="container mt-3">
    <h4>Stock Units</h4>

    <Button Color="ButtonColor.Success" @onclick="() => StartAdd()">Add New Unit</Button>
    @* @if (curItu != null && curItu.Stkuns.Any())
    { *@
    <div class="mt-3">
        <h5>New Transfer Line</h5>
        <InputSelect @bind-Value="IMyItu">
            @foreach (var item in curOrga.Stkitus.ToList())
            {
                <option value=@item.Id @onclick="() => SelPuns()">@item.Liba</option>
            }
        </InputSelect>
    </div>
        <Grid TItem="StkunDto" Data="@DaStkuns" AllowPaging="true" Responsive="true">
            <GridColumns>
                <GridColumn TItem="StkunDto" HeaderText="Id" Class="xcol1">
                    <ChildContent Context="item">@item.Id</ChildContent>
                </GridColumn>
                <GridColumn TItem="StkunDto" HeaderText="Label" Class="xcol3">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputText @bind-Value="draftUn.Liba" />                             
                        }
                        else
                        {
                            @item.Liba

                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkunDto" HeaderText="Abrege" Class="xcol2">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputText @bind-Value="draftUn.Abg" />                             
                        }
                        else
                        {
                            @item.Abg

                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkunDto" HeaderText="Nom" Class="xcol2">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputText @bind-Value="draftUn.Nom" />                             
                        }
                        else
                        {
                            @item.Nom

                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkunDto" HeaderText="Description" Class="xcol3">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputText @bind-Value="draftUn.Description" />                             
                        }
                        else
                        {
                            @item.Description

                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkunDto" HeaderText="Symbol" Class="xcol1">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
