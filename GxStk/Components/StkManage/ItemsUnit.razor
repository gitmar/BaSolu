                        }
                    </ChildContent>
                </GridColumn>
                <GridColumn TItem="StkunDto" HeaderText="Conv Factor" Class="xcol2">
                    <ChildContent Context="item">
                        @if (editRowguid == item.Rowguid)
                        {
                            <InputNumber @bind-Value="draftUn.ConvFactor" />                             
                        }
                        else
                        {
