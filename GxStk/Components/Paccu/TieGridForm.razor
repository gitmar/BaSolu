@code {
    [Parameter] public bool IsVisible { get; set; } = true;

    //[Parameter] public Func<EntPerson, bool> IsEditingRow { get; set; } = entity => false;
    [Parameter] public RenderFragment<EntPerson>? ActionsAndFields { get; set; }


    [Parameter] public IEnumerable<EntPerson> FilteredData { get; set; } = Enumerable.Empty<EntPerson>();
    [Parameter] public Dictionary<string, bool> Visibility { get; set; } = new();
    [Parameter] public string RenderKey { get; set; } = "";


    //[Parameter] public Func<EntPerson, bool>? IsEditingRow { get; set; }

    [Parameter] public Guid? EdRowguid { get; set; }
    private bool IsEditingRow<TDto>(TDto entity, Guid? edRowguid, TDto? draftEntity)
    where TDto : IHasRowguid
    {
        return entity.Rowguid == edRowguid && draftEntity != null;
    }

    // Pass in both the draft entity (being edited) and the selected entity
    [Parameter] public EntPerson? DraftEntity { get; set; }
    [Parameter] public EntPerson? SelectedEntity { get; set; }

    [Parameter] public IEnumerable<dynamic> TbItems { get; set; } = Enumerable.Empty<dynamic>();

   

}

