    [Parameter] public Func<TItem, string> GetEntityId { get; set; } = entity => "";
    [Parameter] public Func<TItem, string> GetEntityXmatri { get; set; } = entity => "";
    [Parameter] public Func<TItem, string> GetEntityNom { get; set; } = entity => "";
    [Parameter] public Func<TItem, string> GetEntityPnom { get; set; } = entity => "";
    [Parameter] public Func<TItem, bool> IsEditingRow { get; set; } = entity => false;
    
    [Parameter] public RenderFragment<TItem>? ActionsAndFields { get; set; }

    // 🔥 BINDING PROPERTIES - Updated on each render
    private string contextXmatri
    {
        get => GetDraftValue("Xmatri");
        set => SetDraftValue("Xmatri", value);
    }
    private string contextNom
    {
        get => GetDraftValue("Nom");
        set => SetDraftValue("Nom", value);
    }
    private string contextPnom
    {
        get => GetDraftValue("Pnom");
        set => SetDraftValue("Pnom", value);
    }

    private string GetDraftValue(string propertyName) => "";
    private void SetDraftValue(string propertyName, string value) { }
} *@


