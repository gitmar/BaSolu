@using GxStk.ClieModels

<div class="card">
    <div class="card-body p-3">
        <Grid TItem="EntPerson"
              Data="@FilteredData"
              AllowPaging="true"
              Responsive="true"
              @key="@RenderKey">
            <GridColumns>
                <GridColumn TItem="EntPerson" HeaderText="">
                    <ChildContent Context="entity">
                        <!-- FIELD 1: ID -->
                        <div class="row mb-2">
                            <label class="fw-bold col-md-3 col-form-label text-nowrap">ID:</label>
                            <div class="form-control-plaintext col-md-9">@entity.Id</div>
                        </div>
                        @{
                            var isGridEditing = IsEditingRow(entity, EdRowguid, DraftEntity);
                        }

                        <!-- FIELD 2: Dossier -->
                        @if (Visibility.GetValueOrDefault("Xmatri", true))
                        {
                            <div class="row mb-2">
                                <label class="fw-bold col-md-3 col-form-label text-nowrap">Dossier:</label>
                                @if (isGridEditing)
                                {
                                    <InputText @bind-Value="entity.Xmatri" class="form-control col-md-9" />
                                }
                                else
                                {
                                    <div class="form-control-plaintext col-md-9">@entity.Xmatri</div>
                                }
                            </div>
                        }

                        <!-- FIELD 3: Nom -->
                        @if (Visibility.GetValueOrDefault("Nom", true))
                        {
                            <div class="row mb-2">
                                <label class="fw-bold col-md-3 col-form-label text-nowrap">Nom:</label>
                                @if (isGridEditing)
                                {
                                    <InputText @bind-Value="entity.Nom" class="form-control col-md-9" />
                                }
                                else
                                {
                                    <div class="form-control-plaintext col-md-9">@entity.Nom</div>
                                }
                            </div>
                        }
                        <!-- FIELD 4: Pnom -->
                        @if (Visibility.GetValueOrDefault("Pnom", true))
                        {
                            <div class="row mb-2">
                                <label class="fw-bold col-md-3 col-form-label text-nowrap">Pnom:</label>
                                @if (isGridEditing)
                                {
                                    <InputText @bind-Value="entity.Pnom" class="form-control col-md-9" />
                                }
                                else
                                {
                                    <div class="form-control-plaintext col-md-9">@entity.Pnom</div>
                                }
                            </div>
                        }
                        <!-- FIELD 5: Nom de Jeune fille -->
                        @if (Visibility.GetValueOrDefault("Bnom", true))
                        {
                            <div class="row mb-2">
                                <label class="fw-bold col-md-3 col-form-label text-nowrap">Nom de Jeune fille:</label>
                                @if (isGridEditing)
                                {
                                    <InputText @bind-Value="DraftEntity.Bnom" class="form-control col-md-9" />
                                }
                                else
                                {
                                    <div class="form-control-plaintext col-md-9">@entity.Bnom</div>
                                }
                            </div>
                        }

                        <!-- FIELD 6: Statut -->
                        @if (Visibility.GetValueOrDefault("Statut", true))
                        {
                            <div class="row mb-2">
                                <label class="fw-bold col-md-3 col-form-label text-nowrap">Statut:</label>
                                @if (isGridEditing)
                                {
                                    <InputSelect @bind-Value="DraftEntity.Statut" class="form-select col-md-9">
                                        <option value="0">?choisir</option>
                                        @foreach (var tob in TbItems.Where(ut => ut.Pxcod == 11))
                                        {
                                            <option value="@tob.Elea">@tob.Liba</option>
                                        }
                                    </InputSelect>
                                }
                                else
                                {
                                    <InputSelect @bind-Value="entity.Statut" disabled="true" class="form-select col-md-9">
                                        <option value="0">?choisir</option>
