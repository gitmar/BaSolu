    private async Task ConfOneAfilGener(Gsgfix mygafl)
    {
        if (mygafl == null)
        {
            Imessage = "type affilie absent";
            return;
        }
        //création des colonnes de base
        // --- Affiliates ---
        int svelea = 1;
        var nwlscolsAff = new List<LSelCol>();
        foreach (var cfx in LsOcols)
        {
            nwlscolsAff.Add(new LSelCol
            {
                ColNo = cfx?.Gp3 ?? 0,
                ColName = cfx?.Scdrub ?? "",
                IsVisible = cfx.Gp5 == 1,
                Olabel = cfx.Liba,
                Ulabel = cfx.Liba
            });
        }
        string storecolsAff = ColsPreferences.SerializePreferences(nwlscolsAff);
        await OnOptcolsSave(storecolsAff, 2, mygafl.Elea);
    }
}
