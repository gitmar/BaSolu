            .ToList();
        // If no stored prefs, initialize defaults
        if (!Columns.Any())
        {
            foreach(var st in LsOcols)
            {
                var cola = new LSelCol
                {
                    EtRef = EtRef.ToString(),
                    ColNo = st.Elea,
                    ColName = st.Scdrub,
                    IsVisible = true,
                    Olabel = st.Liba,
                    Ulabel = st.Liba
                };
                Columns.Add(cola);
            }
        }
    }

    private async Task SavePreferences()
    {
        var serialized = SerializePreferences(Columns);
        if (OnPreferencesSaved.HasDelegate)
            await OnPreferencesSaved.InvokeAsync(serialized);
    }

    // --- Serialization helpers ---
    public static string SerializePreferences(IEnumerable<LSelCol> prefs)
    {
        return string.Join("/", prefs.Select(p =>
            $"{p.EtRef};{p.ColNo};{p.ColName};{p.IsVisible};{p.Olabel};{p.Ulabel}"));
    }

    public static List<LSelCol> DeserializePreferences(string data)
    {
        var prefs = new List<LSelCol>();
        if (string.IsNullOrWhiteSpace(data)) return prefs;

        foreach (var entry in data.Split('/', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = entry.Split(';');
            if (parts.Length == 5)
            {
                prefs.Add(new LSelCol
                {
                    EtRef = parts[0],
                    ColNo = Int16.Parse(parts[1]),
                    ColName = parts[2],
                    IsVisible = bool.Parse(parts[3]),
                    Olabel = parts[4],
                    Ulabel = parts[5]
                });
            }
        }
        return prefs;
    }
    public class LSelCol
    {
        public string EtRef { get; set; } = string.Empty;    
        public int ColNo { get; set; } = 0; //irang
        public string ColName { get; set; } = string.Empty;
        public bool IsVisible { get; set; } = false;
        public string Olabel { get; set; } = string.Empty;
        public string Ulabel { get; set; } = string.Empty;
    }



